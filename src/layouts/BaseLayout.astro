---
import { ClientRouter } from "astro:transitions";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { APP_NAME } from "@lib/config";
import { getActiveBanner } from "@lib/banner";

interface Props {
  title: string;
  /** Font Awesome icon class (e.g. "fa-music") to tile as a subtle scrolling background pattern */
  backgroundIcon?: string;
}

const { title, backgroundIcon } = Astro.props;

const activeBanner = await getActiveBanner();
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={APP_NAME} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bulma@1.0.0/css/bulma.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <script is:inline>
      const THEME_ICON_CSS =
        '.theme-icon-dark{display:none}[data-theme="dark"] .theme-icon-light{display:none}[data-theme="dark"] .theme-icon-dark{display:inline}.theme-label-dark{display:none}[data-theme="dark"] .theme-label-light{display:none}[data-theme="dark"] .theme-label-dark{display:inline}';

      // Inject theme icon styles (must be global, not scoped by Astro)
      (function () {
        const s = document.createElement("style");
        s.textContent = THEME_ICON_CSS;
        document.head.appendChild(s);
      })();

      // Set theme immediately to prevent flash on hard load
      (function () {
        const savedTheme = localStorage.getItem("theme");
        const theme =
          savedTheme ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();

      // Preserve data-theme and re-inject styles into the incoming document
      document.addEventListener("astro:before-swap", (e) => {
        const theme = document.documentElement.getAttribute("data-theme");
        if (theme)
          e.newDocument.documentElement.setAttribute("data-theme", theme);
        const s = e.newDocument.createElement("style");
        s.textContent = THEME_ICON_CSS;
        e.newDocument.head.appendChild(s);
      });
    </script>
    <ClientRouter />
    <title>{title} - {APP_NAME}</title>
    <style>
      :root {
        --navbar-bg: #363636;
        --navbar-text: #fff;
        --body-bg: #fff;
        --body-text: #4a4a4a;
        --box-bg: #fff;
        --box-shadow:
          0 0.5em 1em -0.125em rgba(10, 10, 10, 0.1),
          0 0px 0 1px rgba(10, 10, 10, 0.02);
        --input-bg: #fff;
        --input-border: #dbdbdb;
        --footer-bg: #fafafa;
      }

      [data-theme="dark"] {
        --navbar-bg: #1a1a1a;
        --navbar-text: #f5f5f5;
        --body-bg: #0a0a0a;
        --body-text: #e0e0e0;
        --box-bg: #1a1a1a;
        --box-shadow:
          0 0.5em 1em -0.125em rgba(0, 0, 0, 0.5),
          0 0px 0 1px rgba(255, 255, 255, 0.1);
        --input-bg: #2a2a2a;
        --input-border: #4a4a4a;
        --footer-bg: #0f0f0f;
      }

      [data-theme="dark"] body {
        background-color: var(--body-bg);
        color: var(--body-text);
      }

      [data-theme="dark"] .box {
        background-color: var(--box-bg);
        box-shadow: var(--box-shadow);
        color: var(--body-text);
      }

      [data-theme="dark"] .input,
      [data-theme="dark"] .textarea,
      [data-theme="dark"] .select select {
        background-color: var(--input-bg);
        border-color: var(--input-border);
        color: var(--body-text);
      }

      [data-theme="dark"] .input:disabled,
      [data-theme="dark"] .textarea:disabled {
        background-color: #1a1a1a;
        color: #888;
      }

      [data-theme="dark"] .table {
        background-color: var(--box-bg);
        color: var(--body-text);
      }

      [data-theme="dark"] .table thead th {
        color: var(--body-text);
      }

      [data-theme="dark"] .table tbody tr {
        background-color: var(--box-bg);
      }

      [data-theme="dark"] .table.is-striped tbody tr:nth-child(even) {
        background-color: #151515;
      }

      [data-theme="dark"] .navbar.is-dark {
        background-color: var(--navbar-bg);
      }

      [data-theme="dark"] .footer {
        background-color: var(--footer-bg);
        color: var(--body-text);
      }

      [data-theme="dark"] .title,
      [data-theme="dark"] .subtitle {
        color: var(--body-text);
      }

      [data-theme="dark"] .notification.is-info.is-light {
        background-color: #1a3a52;
        color: #b8d4e8;
      }

      [data-theme="dark"] .notification.is-warning.is-light {
        background-color: #4a3a1a;
        color: #e8d4b8;
      }

      [data-theme="dark"] .help {
        color: #aaa;
      }

      [data-theme="dark"] .label {
        color: var(--body-text);
      }

      [data-theme="dark"] .file-name {
        background-color: var(--input-bg);
        border-color: var(--input-border);
        color: var(--body-text);
      }

      [data-theme="dark"] .select:not(.is-multiple):not(.is-loading)::after {
        border-color: var(--body-text);
      }

      #site-banner {
        padding: 0.6rem 1.5rem;
        text-align: center;
        font-weight: 500;
      }
      .site-banner-info {
        background-color: #3e8ed0;
        color: #fff;
      }
      .site-banner-success {
        background-color: #48c78e;
        color: #fff;
      }
      .site-banner-warning {
        background-color: #ffe08a;
        color: rgba(0, 0, 0, 0.7);
      }
      .site-banner-danger {
        background-color: #f14668;
        color: #fff;
      }
      .site-banner-primary {
        background-color: #00d1b2;
        color: #fff;
      }
      .site-banner-link {
        background-color: #485fc7;
        color: #fff;
      }

      #page-bg-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        width: 100%;
        height: 100%;
      }

      #site-header,
      main {
        position: relative;
        z-index: 1;
      }
    </style>
  </head>
  <body style="min-height: 100vh; display: flex; flex-direction: column;">
    <canvas id="page-bg-canvas" aria-hidden="true" transition:persist="page-bg-canvas" data-icon={backgroundIcon || ''}></canvas>
    <script is:inline>
        (function () {
          if (window.__bgCanvasRunning) return;
          window.__bgCanvasRunning = true;

          const SPEED = 12; // px per second
          const COLS = 8;
          const FONT_SIZE = 32;
          const GAP = 80; // px between icon centres

          function getColor() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            return isDark ? '#ffffff' : '#000000';
          }

          let canvas, ctx, W, H, dpr, colW, rows, glyph, color, fontStr;

          function setup() {
            canvas = document.getElementById('page-bg-canvas');
            if (!canvas) return false;

            const icon = canvas.dataset.icon;
            canvas.style.display = icon ? '' : 'none';
            if (!icon) return false;

            dpr = window.devicePixelRatio || 1;
            W = window.innerWidth;
            H = window.innerHeight;
            canvas.width = W * dpr;
            canvas.height = H * dpr;
            canvas.style.width = W + 'px';
            canvas.style.height = H + 'px';

            ctx = canvas.getContext('2d');
            ctx.scale(dpr, dpr);
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';

            colW = W / COLS;
            rows = Math.ceil(H / GAP) + 4;
            color = getColor();

            // Resolve font family and glyph from a real FA element
            const el = document.createElement('i');
            el.className = 'fas ' + icon;
            el.style.cssText = 'position:absolute;visibility:hidden;font-size:0';
            document.body.appendChild(el);
            const cs = getComputedStyle(el);
            const csBefore = getComputedStyle(el, '::before');
            fontStr = cs.fontWeight + ' ' + FONT_SIZE + 'px ' + cs.fontFamily;
            glyph = csBefore.content.replace(/['"]/g, '');
            document.body.removeChild(el);

            ctx.font = fontStr;
            return glyph.length > 0;
          }

          function draw(ts) {
            if (!canvas || !ctx || !glyph) return;

            ctx.clearRect(0, 0, W, H);
            ctx.fillStyle = color;
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            ctx.globalAlpha = isDark ? 0.025 : 0.06;
            ctx.font = fontStr;

            const tileH = GAP * 2;
            const offsetY = (ts / 1000 * SPEED) % tileH;

            for (let row = -2; row < rows; row++) {
              const isOddRow = (row & 1) !== 0;
              const xShift = isOddRow ? colW / 2 : 0;
              const y = row * GAP + offsetY;
              for (let col = 0; col < COLS; col++) {
                ctx.fillText(glyph, col * colW + colW / 2 + xShift, y);
              }
            }

            requestAnimationFrame(draw);
          }

          window.addEventListener('resize', setup);

          // Re-read color when theme changes
          new MutationObserver(() => { color = getColor(); })
            .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
          document.addEventListener('visibilitychange', () => {
            if (!document.hidden) requestAnimationFrame(draw);
          });

          // Before the swap, copy the incoming page's icon onto the persisted canvas
          document.addEventListener('astro:before-swap', (e) => {
            const incoming = e.newDocument.getElementById('page-bg-canvas');
            const current = document.getElementById('page-bg-canvas');
            if (current && incoming) {
              current.dataset.icon = incoming.dataset.icon || '';
            }
          });

          // After swap, re-resolve glyph/font in case icon changed
          document.addEventListener('astro:after-swap', () => {
            const wasActive = !!glyph;
            if (setup() && !wasActive) {
              // Loop had stopped (no icon on previous page) — restart it
              requestAnimationFrame(draw);
            }
          });

          document.fonts.ready.then(() => {
            if (setup()) requestAnimationFrame(draw);
          });
        })();
      </script>
    <div id="site-header" style="position: sticky; top: 0; z-index: 30;">
      {
        activeBanner && (
          <div id="site-banner" class={`site-banner-${activeBanner.color}`}>
            {activeBanner.message}
          </div>
        )
      }
      <Header>
        <slot name="navbar-start" slot="navbar-start" />
      </Header>
    </div>

    <main class="section" style="flex: 1;">
      <div class="container">
        <slot />
      </div>
    </main>

    <Footer />
  </body>
</html>
