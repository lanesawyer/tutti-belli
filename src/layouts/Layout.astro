---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { APP_NAME } from '../lib/config';
import { getActiveBanner } from '../lib/banner';

interface Props {
  title: string;
  /** Font Awesome icon class (e.g. "fa-music") to tile as a subtle background pattern */
  backgroundIcon?: string;
}

const { title, backgroundIcon } = Astro.props;

const activeBanner = await getActiveBanner();
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={APP_NAME} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.0/css/bulma.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script is:inline>
      const THEME_ICON_CSS = '.theme-icon-dark{display:none}[data-theme="dark"] .theme-icon-light{display:none}[data-theme="dark"] .theme-icon-dark{display:inline}';

      // Inject theme icon styles (must be global, not scoped by Astro)
      (function() {
        const s = document.createElement('style');
        s.textContent = THEME_ICON_CSS;
        document.head.appendChild(s);
      })();

      // Set theme immediately to prevent flash on hard load
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();

      // Preserve data-theme and re-inject styles into the incoming document
      document.addEventListener('astro:before-swap', (e) => {
        const theme = document.documentElement.getAttribute('data-theme');
        if (theme) e.newDocument.documentElement.setAttribute('data-theme', theme);
        const s = e.newDocument.createElement('style');
        s.textContent = THEME_ICON_CSS;
        e.newDocument.head.appendChild(s);
      });
    </script>
    <ClientRouter />
    <title>{title} - {APP_NAME}</title>
    <style>
      :root {
        --navbar-bg: #363636;
        --navbar-text: #fff;
        --body-bg: #fff;
        --body-text: #4a4a4a;
        --box-bg: #fff;
        --box-shadow: 0 0.5em 1em -0.125em rgba(10, 10, 10, 0.1), 0 0px 0 1px rgba(10, 10, 10, 0.02);
        --input-bg: #fff;
        --input-border: #dbdbdb;
        --footer-bg: #fafafa;
      }

      [data-theme="dark"] {
        --navbar-bg: #1a1a1a;
        --navbar-text: #f5f5f5;
        --body-bg: #0a0a0a;
        --body-text: #e0e0e0;
        --box-bg: #1a1a1a;
        --box-shadow: 0 0.5em 1em -0.125em rgba(0, 0, 0, 0.5), 0 0px 0 1px rgba(255, 255, 255, 0.1);
        --input-bg: #2a2a2a;
        --input-border: #4a4a4a;
        --footer-bg: #0f0f0f;
      }

      [data-theme="dark"] body {
        background-color: var(--body-bg);
        color: var(--body-text);
      }

      [data-theme="dark"] .box {
        background-color: var(--box-bg);
        box-shadow: var(--box-shadow);
        color: var(--body-text);
      }

      [data-theme="dark"] .input,
      [data-theme="dark"] .textarea,
      [data-theme="dark"] .select select {
        background-color: var(--input-bg);
        border-color: var(--input-border);
        color: var(--body-text);
      }

      [data-theme="dark"] .input:disabled,
      [data-theme="dark"] .textarea:disabled {
        background-color: #1a1a1a;
        color: #888;
      }

      [data-theme="dark"] .table {
        background-color: var(--box-bg);
        color: var(--body-text);
      }

      [data-theme="dark"] .table thead th {
        color: var(--body-text);
      }

      [data-theme="dark"] .table tbody tr {
        background-color: var(--box-bg);
      }

      [data-theme="dark"] .table.is-striped tbody tr:nth-child(even) {
        background-color: #151515;
      }

      [data-theme="dark"] .navbar.is-dark {
        background-color: var(--navbar-bg);
      }

      [data-theme="dark"] .footer {
        background-color: var(--footer-bg);
        color: var(--body-text);
      }

      [data-theme="dark"] .title,
      [data-theme="dark"] .subtitle {
        color: var(--body-text);
      }

      [data-theme="dark"] .notification.is-info.is-light {
        background-color: #1a3a52;
        color: #b8d4e8;
      }

      [data-theme="dark"] .notification.is-warning.is-light {
        background-color: #4a3a1a;
        color: #e8d4b8;
      }

      [data-theme="dark"] .help {
        color: #aaa;
      }

      [data-theme="dark"] .label {
        color: var(--body-text);
      }

      [data-theme="dark"] .file-name {
        background-color: var(--input-bg);
        border-color: var(--input-border);
        color: var(--body-text);
      }

      [data-theme="dark"] .select:not(.is-multiple):not(.is-loading)::after {
        border-color: var(--body-text);
      }

      #site-banner {
        padding: 0.6rem 1.5rem;
        text-align: center;
        font-weight: 500;
      }
      .site-banner-info    { background-color: #3e8ed0; color: #fff; }
      .site-banner-success { background-color: #48c78e; color: #fff; }
      .site-banner-warning { background-color: #ffe08a; color: rgba(0,0,0,0.7); }
      .site-banner-danger  { background-color: #f14668; color: #fff; }
      .site-banner-primary { background-color: #00d1b2; color: #fff; }
      .site-banner-link    { background-color: #485fc7; color: #fff; }

      .page-bg-pattern {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 0;
        pointer-events: none;
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        align-content: start;
        gap: 3rem 3rem;
        padding: 2rem;
        opacity: 0.04;
        user-select: none;
        will-change: transform;
      }

      .page-bg-pattern i {
        font-size: 2rem;
        color: currentColor;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Offset every other row by half a column to create a diagonal diamond pattern */
      .page-bg-pattern i:nth-child(16n+9),
      .page-bg-pattern i:nth-child(16n+10),
      .page-bg-pattern i:nth-child(16n+11),
      .page-bg-pattern i:nth-child(16n+12),
      .page-bg-pattern i:nth-child(16n+13),
      .page-bg-pattern i:nth-child(16n+14),
      .page-bg-pattern i:nth-child(16n+15),
      .page-bg-pattern i:nth-child(16n+16) {
        transform: translateX(50%);
      }

      /* Ensure page content sits above the background */
      #site-header,
      main {
        position: relative;
        z-index: 1;
      }

    </style>
  </head>
  <body style="min-height: 100vh; display: flex; flex-direction: column;">
    <div class="page-bg-pattern" aria-hidden="true" transition:persist="page-bg-pattern" data-icon={backgroundIcon || ''}>
      {Array.from({ length: 192 }).map(() => (
        <i class={backgroundIcon ? `fas ${backgroundIcon}` : ''}></i>
      ))}
    </div>
    <script is:inline>
      // JS-driven animation using wall-clock time so it never resets on navigation.
      // The rAF loop starts once and runs for the lifetime of the page session.
      (function () {
        const DURATION = 200000; // ms for one full cycle, must stay in sync with any CSS changes
        let rafId = null;

        function tick() {
          const el = document.querySelector('.page-bg-pattern');
          if (el && el.dataset.icon) {
            // progress 0..1 based on wall clock, loops seamlessly
            const progress = (Date.now() % DURATION) / DURATION;
            // drift from -50% to 0% (icons scroll upward into view from bottom)
            const y = -50 + progress * 50;
            el.style.transform = `translateY(${y}%)`;
          }
          rafId = requestAnimationFrame(tick);
        }

        // Only start one loop ever, even across Astro's client-side navigations
        if (!window.__bgPatternRaf) {
          window.__bgPatternRaf = true;
          tick();
        }

        // Update icon class when navigating to a page with a different (or no) icon
        document.addEventListener('astro:before-swap', (e) => {
          const incoming = e.newDocument.querySelector('.page-bg-pattern');
          const current = document.querySelector('.page-bg-pattern');
          if (!current) return;
          const icon = incoming ? incoming.dataset.icon : '';
          current.dataset.icon = icon;
          current.querySelectorAll('i').forEach(i => {
            i.className = icon ? `fas ${icon}` : '';
          });
          current.style.display = icon ? '' : 'none';
        });
      })();
    </script>
    <div id="site-header" style="position: sticky; top: 0; z-index: 30;">
      {activeBanner && (
        <div id="site-banner" class={`site-banner-${activeBanner.color}`}>
          {activeBanner.message}
        </div>
      )}
      <Header>
        <slot name="navbar-start" slot="navbar-start" />
      </Header>
    </div>

    <main class="section" style="flex: 1;">
      <div class="container">
        <slot />
      </div>
    </main>

    <Footer />
  </body>
</html>
