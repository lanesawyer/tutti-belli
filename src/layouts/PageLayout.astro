---
import Layout from './Layout.astro';
import Notification from '../components/Notification.astro';

interface Props {
  title: string;
  pageTitle: string;
  pageSubtitle?: string;
  message?: string;
  messageType?: 'link' | 'primary' | 'info' | 'success' | 'warning' | 'danger';
  backgroundIcon?: string;
}

const {
  title,
  pageTitle,
  pageSubtitle,
  message,
  messageType = 'success',
  backgroundIcon,
} = Astro.props;
---

<Layout title={title} backgroundIcon={backgroundIcon}>
  <slot name="navbar-start" slot="navbar-start" />

  <slot name="before" />

  <div class="level mb-4">
    <div class="level-left">
      <div class="level-item">
        <div>
          <h1 class="title">{pageTitle}</h1>
          {pageSubtitle && <p class="subtitle">{pageSubtitle}</p>}
        </div>
      </div>
    </div>
    <div class="level-right">
      <div class="level-item">
        <slot name="action" />
      </div>
    </div>
  </div>

  {message && (
    <Notification color={messageType} light class="mb-4">
      {message}
    </Notification>
  )}

  <slot />
  <slot name="modals" />
</Layout>
