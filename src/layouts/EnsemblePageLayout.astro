---
import Layout from './Layout.astro';

interface Props {
  title: string;
  ensembleName: string;
  ensembleId: string;
  pageTitle: string;
  pageSubtitle?: string;
  /** Extra breadcrumb entries before the active page. Each is [label, href]. */
  extraBreadcrumbs?: [string, string][];
  message?: string;
  messageType?: string;
}

const {
  title,
  ensembleName,
  ensembleId,
  pageTitle,
  pageSubtitle,
  extraBreadcrumbs = [],
  message,
  messageType,
} = Astro.props;
---

<Layout title={title}>
  <nav class="breadcrumb" aria-label="breadcrumbs">
    <ul>
      <li><a href="/ensembles">Ensembles</a></li>
      <li><a href={`/ensembles/${ensembleId}`}>{ensembleName}</a></li>
      {extraBreadcrumbs.map(([label, href]) => (
        <li><a href={href}>{label}</a></li>
      ))}
      <li class="is-active"><a href="#" aria-current="page">{pageTitle}</a></li>
    </ul>
  </nav>

  <div class="level mb-4">
    <div class="level-left">
      <div class="level-item">
        <div>
          <h1 class="title">{pageTitle}</h1>
          {pageSubtitle && <p class="subtitle">{pageSubtitle}</p>}
        </div>
      </div>
    </div>
    <div class="level-right">
      <div class="level-item">
        <slot name="action" />
      </div>
    </div>
  </div>

  {message && (
    <div class={`notification is-${messageType} mb-4`}>
      {message}
    </div>
  )}

  <slot />
  <slot name="modals" />
</Layout>
