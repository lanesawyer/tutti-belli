---
import Layout from '../layouts/Layout.astro';
import Button from '../components/elements/Button.astro';
import Image from '../components/elements/Image.astro';
import FileInput from '../components/FileInput.astro';
import Icon from '../components/elements/Icon.astro';
import TextInput from '../components/elements/TextInput.astro';
import Notification from '../components/elements/Notification.astro';
import Tag from '../components/elements/Tag.astro';
import { actions } from 'astro:actions';
import { getMembershipsWithParts } from '../lib/profile';
import { getUserTasksAcrossEnsembles } from '../lib/tasks';

const user = Astro.locals.user!;

const updateNameResult = Astro.getActionResult(actions.profile.updateName);
const updatePhoneResult = Astro.getActionResult(actions.profile.updatePhone);
const updateInfoResult = Astro.getActionResult(actions.profile.updateInfo);
const updatePartsResult = Astro.getActionResult(actions.profile.updateParts);
const changeEmailResult = Astro.getActionResult(actions.profile.changeEmail);
const deleteAccountResult = Astro.getActionResult(actions.profile.deleteAccount);

if (deleteAccountResult && !deleteAccountResult.error) {
  return Astro.redirect('/');
}

if (updateNameResult && !updateNameResult.error) return Astro.redirect('/profile?saved=1');
if (updatePhoneResult && !updatePhoneResult.error) return Astro.redirect('/profile?saved=1');
if (updateInfoResult && !updateInfoResult.error) return Astro.redirect('/profile?saved=1');
if (updatePartsResult && !updatePartsResult.error) return Astro.redirect('/profile?saved=1');
if (changeEmailResult && !changeEmailResult.error) return Astro.redirect('/profile?emailChangePending=1');

const errorResult =
  updateNameResult?.error ||
  updatePhoneResult?.error ||
  updateInfoResult?.error ||
  updatePartsResult?.error ||
  changeEmailResult?.error ||
  deleteAccountResult?.error;

const emailChangePending = Astro.url.searchParams.get('emailChangePending') === '1';
const saved = Astro.url.searchParams.get('saved') === '1';

const { memberships, partsByEnsemble, partsByMembership } = await getMembershipsWithParts(user.id);
const tasksByEnsemble = await getUserTasksAcrossEnsembles(user.id);
---

<Layout title="Profile">
  <div class="container">
    <h1 class="title">My Profile</h1>

    {saved && (
      <Notification color="success">
        Changes saved successfully.
      </Notification>
    )}

    {errorResult && (
      <Notification color="danger">
        {errorResult.message}
      </Notification>
    )}

    <div class="columns">
      <div class="column is-half">
        <div class="box">
          <div class="is-flex is-align-items-center mb-5" style="gap: 1rem;">
            {user.avatarUrl
              ? (
                <Image src={user.avatarUrl} alt={user.name} size="96x96" rounded style="flex-shrink: 0;" imgStyle="object-fit: cover;" />
              )
              : (
                <span class="icon" style="flex-shrink: 0; width: 96px; height: 96px; font-size: 96px; line-height: 1;">
                  <i class="fas fa-user-circle"></i>
                </span>
              )
            }
            <div>
              <p class="title is-4 mb-1">{user.name}</p>
              <div class="tags mb-0">
                <Tag color={user.role === 'admin' ? 'danger' : 'info'}>
                  {user.role === 'admin' ? 'Site Administrator' : 'User'}
                </Tag>
              </div>
            </div>
          </div>

          <form method="POST" enctype="multipart/form-data" action={actions.profile.updateInfo}>
            <TextInput name="name" label="Name" value={user.name} required />
            <TextInput name="phone" label="Phone Number" type="tel" value={user.phone ?? ''} placeholder="333-333-3333" pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}" title="###-###-####" />

            <div class="field">
              <label class="label">Profile Picture</label>
              {user.avatarUrl && (
                <label class="checkbox mb-2" style="display: block;">
                  <input type="checkbox" name="removeAvatar" value="true" />
                  Remove current avatar
                </label>
              )}
              <FileInput
                name="avatar"
                id="avatarInput"
                accept="image/*"
                ctaLabel={user.avatarUrl ? 'Change avatar…' : 'Upload avatar…'}
                help="Max 2MB. Square images work best."
              />
            </div>

            <div class="field">
              <div class="control">
                <Button type="submit" color="primary">
                  <Icon icon="fa-save" />
                  <span>Save</span>
                </Button>
              </div>
            </div>
          </form>

          <hr />

          <div class="field">
            <label class="label">Email</label>
            <div class="control">
              <TextInput name="email" type="email" value={user.email} disabled standalone />
            </div>

            {emailChangePending && (
              <Notification color="info" light class="mt-2">
                <strong>Verification email sent.</strong> Check your new inbox and click the link to confirm the change. The link expires in 1 hour.
              </Notification>
            )}

            <details class="mt-3">
              <summary style="cursor: pointer; display: inline-block;">
                <span class="button is-warning is-outlined is-small">
                  <Icon icon="fa-envelope" />
                  <span>Change Email Address</span>
                </span>
              </summary>
              <div class="box mt-3">
                <p class="mb-3">Enter your new email address. A verification link will be sent there. Your current email continues to work for login until verified.</p>
                <form method="POST" action={actions.profile.changeEmail}>
                  <div class="field has-addons">
                    <div class="control is-expanded">
                      <TextInput name="newEmail" type="email" placeholder="new@example.com" required standalone />
                    </div>
                    <div class="control">
                      <Button type="submit" color="warning">
                        <Icon icon="fa-paper-plane" />
                        <span>Send Verification</span>
                      </Button>
                    </div>
                  </div>
                </form>
              </div>
            </details>
          </div>
        </div>
      </div>

      <div class="column is-half">
        <div class="box">
          <h2 class="title is-4">My Parts</h2>
          <p class="subtitle is-6">Select your part(s) for each ensemble</p>

          {memberships.length === 0 ? (
            <Notification color="info" light>
              <p>You are not a member of any ensembles yet.</p>
              <Button href="/ensembles" color="primary" class="mt-3">
                <Icon icon="fa-plus" />
                <span>Join an Ensemble</span>
              </Button>
            </Notification>
          ) : (
            <div class="content">
              {memberships.map((membership) => {
                const parts = partsByEnsemble.get(membership.ensembleId) || [];

                return (
                  <div class="box">
                    <h3 class="title is-5">{membership.ensembleName}</h3>

                    {parts.length === 0 ? (
                      <Notification color="warning" light>
                        <p class="is-size-7">No parts defined for this ensemble yet. Contact an ensemble admin to add parts.</p>
                      </Notification>
                    ) : (
                      <form method="POST" action={actions.profile.updateParts}>
                        <input type="hidden" name="membershipId" value={membership.membershipId} />

                        <div class="field">
                          {parts.map((part) => {
                            const currentParts = partsByMembership.get(membership.membershipId) ?? [];
                            return (
                              <label class="checkbox" style="display: block; margin-bottom: 0.5rem;">
                                <input
                                  type="checkbox"
                                  name="partIds"
                                  value={part.id}
                                  checked={currentParts.some((p) => p.id === part.id)}
                                />
                                {' '}{part.name}
                              </label>
                            );
                          })}
                        </div>

                        <div class="field">
                          <div class="control">
                            <Button type="submit" color="primary">
                              <Icon icon="fa-save" />
                              <span>Update</span>
                            </Button>
                          </div>
                        </div>
                      </form>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>

    {tasksByEnsemble.length > 0 && (
      <div class="box mt-5">
        <h2 class="title is-4">My Season Tasks</h2>
        <p class="subtitle is-6">Task completion status across your ensembles</p>

        {tasksByEnsemble.map((group) => (
          <div class="box">
            <h3 class="title is-5">{group.ensembleName}</h3>
            <p class="subtitle is-7 has-text-grey">{group.seasonName}</p>

            <ul>
              {group.tasks.map((task) => (
                <li class="mb-2">
                  <span class="icon-text">
                    {task.completed
                      ? <Icon icon="fa-check-circle" color="success" />
                      : <Icon icon="fa-circle" variant="far" color="grey-light" />}
                    <span class:list={['ml-1', { 'has-text-grey': task.completed }]}>{task.title}</span>
                    {task.completed && <Tag color="success" class="ml-2">Done</Tag>}
                  </span>
                  {task.description && (
                    <p class="is-size-7 has-text-grey" style="margin-left: 1.5rem;">{task.description}</p>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}

    <div class="box mt-5" style="border: 2px solid hsl(var(--bulma-danger-h), var(--bulma-danger-s), var(--bulma-danger-l));">
      <h2 class="title is-4 has-text-danger">Danger Zone</h2>
      <p class="mb-4">Permanently delete your account and all associated data. This action cannot be undone.</p>

      {user.role === 'admin' && (
        <Notification color="warning" light>
          Site administrators cannot delete their own account. Transfer admin rights first.
        </Notification>
      )}

      {user.role !== 'admin' && (
        <details>
          <summary class="button is-danger is-outlined" style="cursor: pointer;">
            <Icon icon="fa-trash-alt" />
            <span>Delete My Account</span>
          </summary>

          <div class="box mt-4">
            <p class="mb-3 has-text-weight-semibold">Enter your password to confirm account deletion:</p>
            <form method="POST" action={actions.profile.deleteAccount}>
              <div class="field has-addons">
                <div class="control is-expanded">
                  <TextInput name="password" type="password" placeholder="Your current password" color="danger" required autocomplete="current-password" standalone />
                </div>
                <div class="control">
                  <Button type="submit" color="danger">
                    <Icon icon="fa-trash-alt" />
                    <span>Delete Account</span>
                  </Button>
                </div>
              </div>
            </form>
          </div>
        </details>
      )}
    </div>
  </div>

</Layout>
