---
import Layout from '../layouts/Layout.astro';
import { getMembershipsWithParts, updateName, updatePhone, updateAvatar, updatePart, deleteAccount, initiateEmailChange } from '../lib/profile';

const user = Astro.locals.user!;

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  let result = null;

  if (action === 'update-name') {
    result = await updateName(user.id, formData.get('name')?.toString());
  } else if (action === 'update-phone') {
    result = await updatePhone(user.id, formData.get('phone')?.toString());
  } else if (action === 'update-avatar') {
    try {
      result = await updateAvatar(
        user.id,
        user.avatarUrl,
        formData.get('avatar') as File,
        formData.get('removeAvatar')?.toString() === 'true'
      );
    } catch (error) {
      console.error('Error updating avatar:', error);
      message = 'Failed to update avatar';
      messageType = 'danger';
    }
  } else if (action === 'update-part') {
    result = await updatePart(
      formData.get('membershipId')?.toString(),
      formData.get('partId')?.toString()
    );
  } else if (action === 'delete-account') {
    result = await deleteAccount(user.id, user.role, formData.get('password')?.toString());
  } else if (action === 'change-email') {
    result = await initiateEmailChange(user.id, user.name, user.email, formData.get('newEmail')?.toString());
  }

  if (result?.type === 'redirect') {
    if (action === 'delete-account') {
      Astro.cookies.delete('session', { path: '/' });
    }
    return Astro.redirect(result.url);
  } else if (result?.type === 'error') {
    message = result.message;
    messageType = 'danger';
  }
}

const emailChangePending = Astro.url.searchParams.get('emailChangePending') === '1';

const { memberships, partsByEnsemble } = await getMembershipsWithParts(user.id);
---

<Layout title="Profile">
  <div class="container">
    <h1 class="title">My Profile</h1>
    
    {message && (
      <div class={`notification is-${messageType}`}>
        {message}
      </div>
    )}

    <div class="columns">
      <div class="column is-half">
        <div class="box">
          <h2 class="title is-4">Personal Information</h2>
          
          {user.avatarUrl && (
            <div class="mb-4 has-text-centered">
              <figure class="image is-128x128" style="margin: 0 auto;">
                <img src={user.avatarUrl} alt={user.name} style="object-fit: cover; border-radius: 50%;" />
              </figure>
            </div>
          )}

          <form method="POST" enctype="multipart/form-data" class="mb-5">
            <input type="hidden" name="action" value="update-avatar" />
            
            <div class="field">
              <label class="label">Profile Picture</label>
              {user.avatarUrl && (
                <label class="checkbox mb-2">
                  <input type="checkbox" name="removeAvatar" value="true" />
                  Remove current avatar
                </label>
              )}
              <div class="control">
                <div class="file has-name is-fullwidth">
                  <label class="file-label">
                    <input
                      class="file-input"
                      type="file"
                      name="avatar"
                      accept="image/*"
                      id="avatarInput"
                    />
                    <span class="file-cta">
                      <span class="file-icon">
                        <i class="fas fa-upload"></i>
                      </span>
                      <span class="file-label">
                        {user.avatarUrl ? 'Change avatar…' : 'Upload avatar…'}
                      </span>
                    </span>
                    <span class="file-name" id="avatarFileName">
                      No file selected
                    </span>
                  </label>
                </div>
              </div>
              <p class="help">Max 2MB. Square images work best.</p>
            </div>

            <div class="field">
              <div class="control">
                <button type="submit" class="button is-primary">
                  <span class="icon">
                    <i class="fas fa-save"></i>
                  </span>
                  <span>Update Avatar</span>
                </button>
              </div>
            </div>
          </form>

          <hr />
          
          <form method="POST" class="mt-4">
            <input type="hidden" name="action" value="update-name" />
            
            <div class="field">
              <label class="label" for="name">Name</label>
              <div class="field has-addons">
                <div class="control is-expanded">
                  <input
                    class="input"
                    type="text"
                    id="name"
                    name="name"
                    value={user.name}
                    required
                  />
                </div>
                <div class="control">
                  <button type="submit" class="button is-primary">
                    <span class="icon">
                      <i class="fas fa-save"></i>
                    </span>
                    <span>Save</span>
                  </button>
                </div>
              </div>
            </div>
          </form>

          <form method="POST" class="mt-4">
            <input type="hidden" name="action" value="update-phone" />

            <div class="field">
              <label class="label" for="phone">Phone Number</label>
              <div class="field has-addons">
                <div class="control is-expanded">
                  <input
                    class="input"
                    type="tel"
                    id="phone"
                    name="phone"
                    value={user.phone ?? ''}
                    placeholder="333-333-3333"
                    pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}"
                  />
                </div>
                <div class="control">
                  <button type="submit" class="button is-primary">
                    <span class="icon">
                      <i class="fas fa-save"></i>
                    </span>
                    <span>Save</span>
                  </button>
                </div>
              </div>
            </div>
          </form>

          <div class="field">
            <label class="label">Email</label>
            <div class="control">
              <input class="input" type="text" value={user.email} disabled />
            </div>

            {emailChangePending && (
              <div class="notification is-info is-light mt-2">
                <strong>Verification email sent.</strong> Check your new inbox and click the link to confirm the change. The link expires in 1 hour.
              </div>
            )}

            <details class="mt-3">
              <summary style="cursor: pointer; display: inline-block;">
                <span class="button is-warning is-outlined is-small">
                  <span class="icon">
                    <i class="fas fa-envelope"></i>
                  </span>
                  <span>Change Email Address</span>
                </span>
              </summary>
              <div class="box mt-3">
                <p class="mb-3">Enter your new email address. A verification link will be sent there. Your current email continues to work for login until verified.</p>
                <form method="POST">
                  <input type="hidden" name="action" value="change-email" />
                  <div class="field has-addons">
                    <div class="control is-expanded">
                      <input
                        class="input"
                        type="email"
                        name="newEmail"
                        placeholder="new@example.com"
                        required
                      />
                    </div>
                    <div class="control">
                      <button type="submit" class="button is-warning">
                        <span class="icon">
                          <i class="fas fa-paper-plane"></i>
                        </span>
                        <span>Send Verification</span>
                      </button>
                    </div>
                  </div>
                </form>
              </div>
            </details>
          </div>

          <div class="field">
            <label class="label">Account Type</label>
            <div class="control">
              <span class={`tag is-medium ${user.role === 'admin' ? 'is-danger' : 'is-info'}`}>
                {user.role === 'admin' ? 'Site Administrator' : 'User'}
              </span>
            </div>
          </div>

          <div class="field">
            <label class="label">Member Since</label>
            <div class="control">
              <input class="input" type="text" value={new Date(user.createdAt).toLocaleDateString()} disabled />
            </div>
          </div>
        </div>
      </div>

      <div class="column is-half">
        <div class="box">
          <h2 class="title is-4">My Parts</h2>
          <p class="subtitle is-6">Select your part for each ensemble</p>
          
          {memberships.length === 0 ? (
            <div class="notification is-info is-light">
              <p>You are not a member of any ensembles yet.</p>
              <a href="/ensembles" class="button is-primary mt-3">
                <span class="icon">
                  <i class="fas fa-plus"></i>
                </span>
                <span>Join an Ensemble</span>
              </a>
            </div>
          ) : (
            <div class="content">
              {memberships.map((membership) => {
                const parts = partsByEnsemble.get(membership.ensembleId) || [];
                
                return (
                  <div class="box">
                    <h3 class="title is-5">{membership.ensembleName}</h3>
                    
                    {parts.length === 0 ? (
                      <div class="notification is-warning is-light">
                        <p class="is-size-7">No parts defined for this ensemble yet. Contact an ensemble admin to add parts.</p>
                      </div>
                    ) : (
                      <form method="POST">
                        <input type="hidden" name="action" value="update-part" />
                        <input type="hidden" name="membershipId" value={membership.membershipId} />
                        
                        <div class="field has-addons">
                          <div class="control is-expanded">
                            <div class="select is-fullwidth">
                              <select name="partId">
                                <option value="">-- No Part --</option>
                                {parts.map((part: any) => (
                                  <option 
                                    value={part.id}
                                    selected={part.id === membership.partId}
                                  >
                                    {part.name}
                                  </option>
                                ))}
                              </select>
                            </div>
                          </div>
                          <div class="control">
                            <button type="submit" class="button is-primary">
                              <span class="icon">
                                <i class="fas fa-save"></i>
                              </span>
                              <span>Update</span>
                            </button>
                          </div>
                        </div>
                      </form>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>

    <div class="buttons mt-5">
      <a href="/ensembles" class="button is-primary">
        <span class="icon">
          <i class="fas fa-users"></i>
        </span>
        <span>My Ensembles</span>
      </a>
    </div>

    <div class="box mt-5" style="border: 2px solid hsl(var(--bulma-danger-h), var(--bulma-danger-s), var(--bulma-danger-l));">
      <h2 class="title is-4 has-text-danger">Danger Zone</h2>
      <p class="mb-4">Permanently delete your account and all associated data. This action cannot be undone.</p>

      {user.role === 'admin' && (
        <div class="notification is-warning is-light">
          Site administrators cannot delete their own account. Transfer admin rights first.
        </div>
      )}

      {user.role !== 'admin' && (
        <details>
          <summary class="button is-danger is-outlined" style="cursor: pointer;">
            <span class="icon">
              <i class="fas fa-trash-alt"></i>
            </span>
            <span>Delete My Account</span>
          </summary>

          <div class="box mt-4">
            <p class="mb-3 has-text-weight-semibold">Enter your password to confirm account deletion:</p>
            <form method="POST">
              <input type="hidden" name="action" value="delete-account" />
              <div class="field has-addons">
                <div class="control is-expanded">
                  <input
                    class="input is-danger"
                    type="password"
                    name="password"
                    placeholder="Your current password"
                    required
                    autocomplete="current-password"
                  />
                </div>
                <div class="control">
                  <button type="submit" class="button is-danger">
                    <span class="icon">
                      <i class="fas fa-trash-alt"></i>
                    </span>
                    <span>Delete Account</span>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </details>
      )}
    </div>
  </div>

  <script>
    // Update file name display for avatar upload
    const avatarInput = document.getElementById('avatarInput') as HTMLInputElement;
    const avatarFileName = document.getElementById('avatarFileName');
    
    avatarInput?.addEventListener('change', () => {
      if (avatarInput.files && avatarInput.files.length > 0) {
        const file = avatarInput.files[0];
        if (avatarFileName) {
          avatarFileName.textContent = file.name;
        }
      } else if (avatarFileName) {
        avatarFileName.textContent = 'No file selected';
      }
    });
  </script>
</Layout>
