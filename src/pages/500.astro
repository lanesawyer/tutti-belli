---
import Layout from "../layouts/Layout.astro";
import Button from "../components/elements/Button.astro";
import Icon from "../components/elements/Icon.astro";
---

<Layout title="500 – Something Went Wrong">
  <div class="has-text-centered" style="padding: 4rem 1rem;">
    <div style="font-size: 6rem; line-height: 1; margin-bottom: 1rem;">
      &#x1D10A;
    </div>
    <h1 class="title is-1">500</h1>
    <h2 class="subtitle is-3">The ensemble lost the beat</h2>
    <p class="block" style="max-width: 480px; margin: 0 auto 2rem;">
      Something backstage went wrong — a wrong note, a missed cue, maybe the
      oboist came in early again. Our stagehands have been notified. Please try
      again in a moment.
    </p>
    <Button href="/" color="warning">
      <Icon icon="fa-rotate-right" />
      <span>Try from the Top</span>
    </Button>
  </div>
</Layout>
