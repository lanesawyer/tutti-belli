---
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import Button from "@components/elements/Button.astro";
import TextInput from "@components/forms/TextInput.astro";
import Notification from "@components/elements/Notification.astro";
import { actions } from "astro:actions";
import { validatePasswordResetToken } from "@lib/profile";

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect("/ensembles");
}

const token = Astro.url.searchParams.get("token");

if (!token) {
  return Astro.redirect("/forgot-password");
}

const tokenValid = await validatePasswordResetToken(token);

const result = Astro.getActionResult(actions.auth.resetPassword);
const success = result && !result.error;
let error = "";

if (!tokenValid && !success) {
  error =
    "This password reset link is invalid or has expired. Please request a new one.";
} else if (result?.error) {
  error = result.error.message ?? "An error occurred. Please try again.";
}
---

<SingleColumnLayout title="Reset Password">
  <h1 class="title">Reset Password</h1>

  {
    error && (
      <Notification color="danger" light>
        <p>{error}</p>
        {error.includes("invalid or has expired") && (
          <p class="mt-2">
            <a href="/forgot-password">Request a new reset link</a>
          </p>
        )}
      </Notification>
    )
  }

  {
    success ? (
      <Notification color="success" light>
        <p>
          <strong>Password updated!</strong>
        </p>
        <p class="mt-2">Your password has been changed successfully.</p>
        <p class="mt-3">
          <Button href="/login" color="primary">
            Log In
          </Button>
        </p>
      </Notification>
    ) : !error ||
      error.includes("fields") ||
      error.includes("characters") ||
      error.includes("match") ? (
      <form method="POST" action={actions.auth.resetPassword}>
        <input type="hidden" name="token" value={token} />
        <TextInput
          name="password"
          label="New Password"
          type="password"
          placeholder="••••••••"
          iconLeft="fa-lock"
          minlength="6"
          required
          autofocus
          help="Minimum 6 characters"
        />
        <TextInput
          name="confirmPassword"
          label="Confirm New Password"
          type="password"
          placeholder="••••••••"
          iconLeft="fa-lock"
          minlength="6"
          required
        />

        <div class="field">
          <div class="control">
            <Button color="primary" fullwidth type="submit">
              Set New Password
            </Button>
          </div>
        </div>
      </form>
    ) : null
  }

  <div class="has-text-centered mt-4">
    <a href="/login">Back to Log In</a>
  </div>
</SingleColumnLayout>
