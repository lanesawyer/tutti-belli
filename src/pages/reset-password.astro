---
import Layout from '../layouts/Layout.astro';
import Button from '../components/elements/Button.astro';
import TextInput from '../components/elements/TextInput.astro';
import Notification from '../components/elements/Notification.astro';
import { db, eq, and, gt, isNull, User, PasswordResetToken } from 'astro:db';
import { hashPassword } from '../lib/auth';

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect('/ensembles');
}

const token = Astro.url.searchParams.get('token');
let error = '';
let success = false;

if (!token) {
  return Astro.redirect('/forgot-password');
}

// Validate the token
const now = new Date();
const [resetToken] = await db
  .select()
  .from(PasswordResetToken)
  .where(
    and(
      eq(PasswordResetToken.token, token),
      gt(PasswordResetToken.expiresAt, now),
      isNull(PasswordResetToken.usedAt),
    )
  );

if (!resetToken) {
  error = 'This password reset link is invalid or has expired. Please request a new one.';
}

if (Astro.request.method === 'POST' && resetToken) {
  try {
    const formData = await Astro.request.formData();
    const password = formData.get('password')?.toString();
    const confirmPassword = formData.get('confirmPassword')?.toString();

    if (!password || !confirmPassword) {
      error = 'Please fill in all fields.';
    } else if (password.length < 8) {
      error = 'Password must be at least 8 characters.';
    } else if (password !== confirmPassword) {
      error = 'Passwords do not match.';
    } else {
      const passwordHash = await hashPassword(password);

      await db
        .update(User)
        .set({ passwordHash })
        .where(eq(User.id, resetToken.userId));

      await db
        .update(PasswordResetToken)
        .set({ usedAt: new Date() })
        .where(eq(PasswordResetToken.id, resetToken.id));

      success = true;
    }
  } catch (e) {
    console.error('Reset password error:', e);
    error = 'An error occurred. Please try again.';
  }
}
---

<Layout title="Reset Password">
  <div class="columns is-centered">
    <div class="column is-5-tablet is-4-desktop">
      <h1 class="title">Reset Password</h1>

      {error && (
        <Notification color="danger" light>
          <p>{error}</p>
          {error.includes('invalid or has expired') && (
            <p class="mt-2"><a href="/forgot-password">Request a new reset link</a></p>
          )}
        </Notification>
      )}

      {success ? (
        <Notification color="success" light>
          <p><strong>Password updated!</strong></p>
          <p class="mt-2">Your password has been changed successfully.</p>
          <p class="mt-3"><Button href="/login" color="primary">Log In</Button></p>
        </Notification>
      ) : !error || error.includes('fields') || error.includes('characters') || error.includes('match') ? (
        <form method="POST">
          <TextInput name="password" label="New Password" type="password" placeholder="••••••••" iconLeft="fa-lock" minlength="8" required autofocus help="Minimum 8 characters" />
          <TextInput name="confirmPassword" label="Confirm New Password" type="password" placeholder="••••••••" iconLeft="fa-lock" minlength="8" required />

          <div class="field">
            <div class="control">
              <Button color="primary" fullwidth type="submit">
                Set New Password
              </Button>
            </div>
          </div>
        </form>
      ) : null}

      <div class="has-text-centered mt-4">
        <a href="/login">Back to Log In</a>
      </div>
    </div>
  </div>
</Layout>
