---
import Layout from '../layouts/Layout.astro';
import { db, eq, User } from 'astro:db';
import { hashPassword } from '../lib/auth';
import { createSession } from '../lib/session';
import { getRedirectUrl } from '../lib/redirect';
import { sendWelcomeEmail } from '../lib/email';

const customRedirect = Astro.url.searchParams.get('redirect');
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString();
    const password = formData.get('password')?.toString();
    const name = formData.get('name')?.toString();

    if (!email || !password || !name) {
      error = 'Please fill in all fields';
    } else if (password.length < 6) {
      error = 'Password must be at least 6 characters';
    } else {
      // Check if user already exists
      const [existingUser] = await db.select().from(User).where(eq(User.email, email));

      if (existingUser) {
        error = 'An account with this email already exists';
      } else {
        // Create new user
        const userId = crypto.randomUUID();
        const passwordHash = await hashPassword(password);

        await db.insert(User).values({
          id: userId,
          email,
          passwordHash,
          name,
          role: 'user',
        });

        // Create session and log in
        const sessionId = createSession(userId);
        Astro.cookies.set('session', sessionId, {
          path: '/',
          httpOnly: true,
          secure: import.meta.env.PROD,
          sameSite: 'lax',
          maxAge: 60 * 60 * 24 * 30, // 30 days
        });

        // Fire-and-forget: don't block registration if email fails
        sendWelcomeEmail(email, name).catch(() => {});

        const redirectUrl = await getRedirectUrl(userId, customRedirect);
        return Astro.redirect(redirectUrl);
      }
    }
  } catch (e) {
    error = 'An error occurred. Please try again.';
  }
}

// Redirect if already logged in
if (Astro.locals.user) {
  const redirectUrl = await getRedirectUrl(Astro.locals.user.id, customRedirect);
  return Astro.redirect(redirectUrl);
}
---

<Layout title="Sign Up">
  <div class="columns is-centered">
    <div class="column is-5-tablet is-4-desktop">
      <h1 class="title">Sign Up</h1>
      
      {error && (
        <div class="notification is-danger is-light">
          {error}
        </div>
      )}

      <form method="POST">
        <div class="field">
          <label class="label" for="name">Full Name</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="text"
              id="name"
              name="name"
              placeholder="John Doe"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-user"></i>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="label" for="email">Email</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-envelope"></i>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="label" for="password">Password</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              minlength="6"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-lock"></i>
            </span>
          </div>
          <p class="help">Must be at least 6 characters</p>
        </div>

        <div class="field">
          <div class="control">
            <button class="button is-primary is-fullwidth" type="submit">
              Sign Up
            </button>
          </div>
        </div>
      </form>

      <div class="has-text-centered mt-4">
        <p>Already have an account? <a href="/login">Log in</a></p>
      </div>
    </div>
  </div>
</Layout>
