---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Notification from '../components/Notification.astro';
import { actions } from 'astro:actions';
import { getRedirectUrl } from '../lib/redirect';

const customRedirect = Astro.url.searchParams.get('redirect');

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect(await getRedirectUrl(Astro.locals.user.id, customRedirect));
}

const result = Astro.getActionResult(actions.profile.register);
if (result && !result.error) {
  return Astro.redirect(await getRedirectUrl(result.data.userId, customRedirect));
}

const error = result?.error?.message ?? '';
---

<Layout title="Sign Up">
  <div class="columns is-centered">
    <div class="column is-5-tablet is-4-desktop">
      <h1 class="title">Sign Up</h1>

      {error && (
        <Notification color="danger" light>
          {error}
        </Notification>
      )}

      <form method="POST" action={actions.profile.register}>
        {customRedirect && <input type="hidden" name="redirect" value={customRedirect} />}
        <div class="field">
          <label class="label" for="name">Full Name</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="text"
              id="name"
              name="name"
              placeholder="John Doe"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-user"></i>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="label" for="email">Email</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-envelope"></i>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="label" for="password">Password</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              minlength="6"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-lock"></i>
            </span>
          </div>
          <p class="help">Must be at least 6 characters</p>
        </div>

        <div class="field">
          <div class="control">
            <Button color="primary" fullwidth type="submit">
              Sign Up
            </Button>
          </div>
        </div>
      </form>

      <div class="has-text-centered mt-4">
        <p>Already have an account? <a href="/login">Log in</a></p>
      </div>
    </div>
  </div>
</Layout>
