---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { db, eq, and, Event, Attendance, Ensemble } from 'astro:db';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/login?redirect=/checkin/${Astro.params.code}`);
}

const { code } = Astro.params;
if (!code) {
  return Astro.redirect('/ensembles');
}

// Find event by check-in code
const [event] = await db
  .select()
  .from(Event)
  .where(eq(Event.checkInCode, code.toUpperCase()));

if (!event) {
  return new Response('Invalid check-in code', { status: 404 });
}

// Get ensemble with check-in window settings
const [ensemble] = await db.select().from(Ensemble).where(eq(Ensemble.id, event.ensembleId));

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

// Calculate check-in window
const now = new Date();
const scheduledTime = new Date(event.scheduledAt);
const checkInStartTime = new Date(scheduledTime.getTime() - (ensemble.checkInStartMinutes * 60 * 1000));
const checkInEndTime = new Date(scheduledTime.getTime() + (ensemble.checkInEndMinutes  * 60 * 1000));

const canCheckIn = now >= checkInStartTime && now <= checkInEndTime;
const isTooEarly = now < checkInStartTime;
const isTooLate = now > checkInEndTime;

let message = '';
let success = false;

if (Astro.request.method === 'POST') {
  // Check time window
  if (!canCheckIn) {
    if (isTooEarly) {
      const minutesUntilOpen = Math.ceil((checkInStartTime.getTime() - now.getTime()) / (60 * 1000));
      message = `Check-in opens ${ensemble.checkInStartMinutes} minutes before the event (in ${minutesUntilOpen} minutes).`;
      success = false;
    } else if (isTooLate) {
      message = `Check-in closed ${ensemble.checkInEndMinutes} minutes after event start.`;
      success = false;
    }
  } else {
    // Check if already checked in
    const [existing] = await db
      .select()
      .from(Attendance)
      .where(and(eq(Attendance.eventId, event.id), eq(Attendance.userId, user.id)));

    if (!existing) {
      await db.insert(Attendance).values({
        id: crypto.randomUUID(),
        eventId: event.id,
        userId: user.id,
        checkedInMethod: 'qr',
      });
      message = 'Successfully checked in!';
      success = true;
    } else {
      message = 'You have already checked in for this event.';
      success = false;
    }
  }
}

const scheduledDate = new Date(event.scheduledAt);
const isPerformance = event.category === 'performance';
---

<Layout title="Check In">
  <div class="columns is-centered">
    <div class="column is-6-tablet is-5-desktop">
      <div class="box has-text-centered">
        <span class="icon is-large has-text-primary mb-3">
          <i class="fas fa-qrcode fa-3x"></i>
        </span>

        <h1 class="title">Event Check-In</h1>

        {ensemble && (
          <p class="subtitle">{ensemble.name}</p>
        )}

        <div class="content mt-4">
          <p>
            <strong>{event.title}</strong>
            <span class={`tag ml-2 ${isPerformance ? 'is-warning' : 'is-primary'}`}>
              {isPerformance ? 'Performance' : 'Rehearsal'}
            </span>
          </p>
          <p>
            <span class="icon-text">
              <span class="icon">
                <i class="fas fa-calendar"></i>
              </span>
              <span>{scheduledDate.toLocaleDateString()}</span>
            </span>
            <span class="ml-3 icon-text">
              <span class="icon">
                <i class="fas fa-clock"></i>
              </span>
              <span>{scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
            </span>
          </p>
          {event.location && (
            <p>
              <span class="icon-text">
                <span class="icon">
                  <i class="fas fa-map-marker-alt"></i>
                </span>
                <span>{event.location}</span>
              </span>
            </p>
          )}
        </div>

        <div class="notification is-info is-light mt-4">
          <p class="has-text-weight-semibold">Check-in Window:</p>
          <p>Opens {ensemble.checkInStartMinutes} minutes before event</p>
          <p>Closes {ensemble.checkInEndMinutes} minutes after event start</p>
        </div>

        {message && (
          <div class={`notification ${success ? 'is-success' : 'is-warning'} is-light mt-4`}>
            {message}
          </div>
        )}

        {!message && canCheckIn && (
          <form method="POST" class="mt-5">
            <Button type="submit" color="primary" size="large" fullwidth>
              <span class="icon">
                <i class="fas fa-check"></i>
              </span>
              <span>Check In Now</span>
            </Button>
          </form>
        )}

        {!message && !canCheckIn && (
          <div class="mt-5">
            <Button type="button" size="large" fullwidth disabled>
              <span class="icon">
                <i class="fas fa-lock"></i>
              </span>
              <span>Check-in {isTooEarly ? 'Not Yet Available' : 'Closed'}</span>
            </Button>
            <p class="help mt-2">
              {isTooEarly && `Check-in opens ${ensemble.checkInStartMinutes} minutes before event`}
              {isTooLate && `Check-in closed ${ensemble.checkInEndMinutes} minutes after event start`}
            </p>
          </div>
        )}

        {success && (
          <div class="mt-4">
            <Button href={`/ensembles/${event.ensembleId}/events/${event.id}`} color="info">
              View Event Details
            </Button>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
