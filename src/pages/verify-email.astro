---
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import Button from "@components/elements/Button.astro";
import Notification from "@components/elements/Notification.astro";
import { verifyEmailToken } from "@lib/profile";
import { createSession } from "@lib/session";
import { getRedirectUrl } from "@lib/redirect";

const token = Astro.url.searchParams.get("token");
const customRedirect = Astro.url.searchParams.get("redirect");
let error = "";

if (!token) {
  error = "Invalid verification link.";
} else {
  const result = await verifyEmailToken(token);

  if (!result) {
    error = "This verification link is invalid or has expired.";
  } else {
    const sessionToken = createSession(result.userId);
    Astro.cookies.set("session", sessionToken, {
      path: "/",
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 30,
    });

    return Astro.redirect(await getRedirectUrl(result.userId, customRedirect));
  }
}
---

<SingleColumnLayout title="Verify Email">
      <h1 class="title">Email Verification</h1>

      {
        error && (
          <Notification color="danger" light>
            <p>{error}</p>
            <p class="mt-3">
              <Button href="/resend-verification" color="light">
                Resend verification email
              </Button>
            </p>
          </Notification>
        )
      }
</SingleColumnLayout>
