---
import Layout from "../layouts/Layout.astro";
import Button from "../components/elements/Button.astro";
import Notification from "../components/elements/Notification.astro";
import {
  db,
  eq,
  and,
  gt,
  isNull,
  User,
  EmailVerificationToken,
} from "astro:db";
import { createSession } from "../lib/session";
import { getRedirectUrl } from "../lib/redirect";

const token = Astro.url.searchParams.get("token");
const customRedirect = Astro.url.searchParams.get("redirect");
let error = "";

if (!token) {
  error = "Invalid verification link.";
} else {
  const now = new Date();

  const verifyToken = await db
    .select()
    .from(EmailVerificationToken)
    .where(
      and(
        eq(EmailVerificationToken.token, token),
        gt(EmailVerificationToken.expiresAt, now),
        isNull(EmailVerificationToken.usedAt),
      ),
    )
    .get();

  if (!verifyToken) {
    error = "This verification link is invalid or has expired.";
  } else {
    await db
      .update(User)
      .set({ emailVerifiedAt: now })
      .where(eq(User.id, verifyToken.userId));

    await db
      .update(EmailVerificationToken)
      .set({ usedAt: now })
      .where(eq(EmailVerificationToken.id, verifyToken.id));

    const sessionToken = createSession(verifyToken.userId);
    Astro.cookies.set("session", sessionToken, {
      path: "/",
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 30,
    });

    return Astro.redirect(
      await getRedirectUrl(verifyToken.userId, customRedirect),
    );
  }
}
---

<Layout title="Verify Email">
  <div class="columns is-centered">
    <div class="column is-5-tablet is-4-desktop">
      <h1 class="title">Email Verification</h1>

      {
        error && (
          <Notification color="danger" light>
            <p>{error}</p>
            <p class="mt-3">
              <Button href="/resend-verification" color="light">
                Resend verification email
              </Button>
            </p>
          </Notification>
        )
      }
    </div>
  </div>
</Layout>
