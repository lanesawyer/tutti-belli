---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Notification from '../../components/Notification.astro';
import { db, eq, and, EnsembleInvite, EnsembleMember, Ensemble } from 'astro:db';
import { APP_NAME } from '../../lib/config';

const user = Astro.locals.user;

let error = '';
let success = false;
let ensemble = null;

const codeParam = Astro.url.searchParams.get('code');
if (codeParam) {
  // Pre-fetch ensemble info if code is in URL
  const [invite] = await db
    .select()
    .from(EnsembleInvite)
    .where(eq(EnsembleInvite.code, codeParam.toUpperCase()));
  
  if (invite) {
    [ensemble] = await db
      .select()
      .from(Ensemble)
      .where(eq(Ensemble.id, invite.ensembleId));
  }
}

if (Astro.request.method === 'POST') {
  if (!user) {
    return Astro.redirect('/login');
  }

  const formData = await Astro.request.formData();
  const code = formData.get('code')?.toString()?.trim().toUpperCase();
  const agreedToCodeOfConduct = formData.get('agreedToCodeOfConduct')?.toString() === 'on';

  if (!code) {
    error = 'Please enter an invite code';
  } else {
    // Check if invite exists and is valid
    const [invite] = await db
      .select()
      .from(EnsembleInvite)
      .where(eq(EnsembleInvite.code, code));

    if (!invite) {
      error = 'Invalid invite code';
    } else if (invite.expiresAt && new Date(invite.expiresAt) < new Date()) {
      error = 'This invite code has expired';
    } else {
      // Fetch ensemble to check for code of conduct
      [ensemble] = await db
        .select()
        .from(Ensemble)
        .where(eq(Ensemble.id, invite.ensembleId));

      // Check if code of conduct agreement is required
      if (ensemble?.codeOfConduct && !agreedToCodeOfConduct) {
        error = 'You must agree to the code of conduct to join this ensemble';
      } else {
        // Check if already a member
        const [existing] = await db
          .select()
          .from(EnsembleMember)
          .where(
            and(
              eq(EnsembleMember.ensembleId, invite.ensembleId),
              eq(EnsembleMember.userId, user.id)
            )
          );

        if (existing) {
          error = 'You are already a member of this ensemble';
        } else {
          // Add user to ensemble with pending status
          await db.insert(EnsembleMember).values({
            id: crypto.randomUUID(),
            ensembleId: invite.ensembleId,
            userId: user.id,
            role: 'member',
            status: 'pending',
            agreedToCodeOfConductAt: ensemble?.codeOfConduct ? new Date() : null,
          });

          return Astro.redirect(`/ensembles/${invite.ensembleId}?joined=pending`);
        }
      }
    }
  }
}
---

<Layout title="Join Ensemble">
  <div class="columns is-centered">
    <div class="column is-8-tablet is-7-desktop">
      <h1 class="title">Join an Ensemble</h1>
      <p class="subtitle">{user ? 'Enter your invite code to join an ensemble' : 'Sign in or create an account to join'}</p>

      {error && (
        <Notification color="danger" light>
          {error}
        </Notification>
      )}

      {success && (
        <Notification color="success" light>
          Successfully joined the ensemble!
        </Notification>
      )}

      {!user && ensemble && (
        <div class="box mb-5">
          <h2 class="title is-4">{ensemble.name}</h2>
          <p class="subtitle is-6">You've been invited to join this ensemble</p>
        </div>
      )}

      {!user && ensemble?.codeOfConduct && (
        <div class="box mb-5">
          <h2 class="title is-5">Code of Conduct</h2>
          <p class="subtitle is-6 mb-4">This ensemble requires agreement to its code of conduct</p>
          <div class="content" style="max-height: 400px; overflow-y: auto; border: 1px solid #4a4a4a; border-radius: 4px; padding: 1.25rem; background-color: #363636; color: #f5f5f5;">
            <div style="white-space: pre-wrap;">{ensemble.codeOfConduct}</div>
          </div>
        </div>
      )}

      {!user ? (
        <div class="box">
          <div class="content has-text-centered mb-5">
            <p class="is-size-5">You need a {APP_NAME} account to join</p>
          </div>
          <div class="buttons is-centered">
            <Button href={`/register?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`} color="primary" size="large">
              <span class="icon">
                <i class="fas fa-user-plus"></i>
              </span>
              <span>Create Account</span>
            </Button>
            <Button href={`/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`} color="light" size="large">
              <span class="icon">
                <i class="fas fa-sign-in-alt"></i>
              </span>
              <span>Sign In</span>
            </Button>
          </div>
          <p class="has-text-centered mt-4 help">Already have an account? Click "Sign In" to continue</p>
        </div>
      ) : (
      <form method="POST">
        <div class="field">
          <label class="label" for="code">Invite Code</label>
          <div class="control has-icons-left">
            <input
              class="input is-large"
              type="text"
              id="code"
              name="code"
              value={codeParam || ''}
              placeholder="ABCD1234"
              style="text-transform: uppercase;"
              required
              autofocus
            />
            <span class="icon is-left">
              <i class="fas fa-ticket"></i>
            </span>
          </div>
          <p class="help">Enter the 8-character code provided by your ensemble admin</p>
        </div>

        {ensemble?.codeOfConduct && (
          <div class="box mt-5">
            <h2 class="title is-5">Code of Conduct</h2>
            <p class="subtitle is-6 mb-4">Please review and agree to the {ensemble.name} code of conduct</p>
            <div class="content" style="max-height: 400px; overflow-y: auto; border: 1px solid #4a4a4a; border-radius: 4px; padding: 1.25rem; background-color: #363636; color: #f5f5f5;">
              <div style="white-space: pre-wrap;">{ensemble.codeOfConduct}</div>
            </div>
            <label class="checkbox mt-4">
              <input type="checkbox" name="agreedToCodeOfConduct" required />
              <strong class="ml-2">I have read and agree to the code of conduct</strong>
            </label>
          </div>
        )}

        <div class="field is-grouped mt-5">
          <div class="control">
            <Button type="submit" color="primary" size="large">
              <span class="icon">
                <i class="fas fa-check"></i>
              </span>
              <span>Join Ensemble</span>
            </Button>
          </div>
          <div class="control">
            <Button href="/ensembles" color="light" size="large">
              Cancel
            </Button>
          </div>
        </div>
      </form>
      )}
    </div>
  </div>
</Layout>
