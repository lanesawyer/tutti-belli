---
import Layout from '../../layouts/Layout.astro';
import { db, eq, and, EnsembleInvite, EnsembleMember } from 'astro:db';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const code = formData.get('code')?.toString()?.trim().toUpperCase();

  if (!code) {
    error = 'Please enter an invite code';
  } else {
    // Check if invite exists and is valid
    const [invite] = await db
      .select()
      .from(EnsembleInvite)
      .where(eq(EnsembleInvite.code, code));

    if (!invite) {
      error = 'Invalid invite code';
    } else if (invite.expiresAt && new Date(invite.expiresAt) < new Date()) {
      error = 'This invite code has expired';
    } else {
      // Check if already a member
      const [existing] = await db
        .select()
        .from(EnsembleMember)
        .where(
          and(
            eq(EnsembleMember.ensembleId, invite.ensembleId),
            eq(EnsembleMember.userId, user.id)
          )
        );

      if (existing) {
        error = 'You are already a member of this ensemble';
      } else {
        // Add user to ensemble
        await db.insert(EnsembleMember).values({
          id: crypto.randomUUID(),
          ensembleId: invite.ensembleId,
          userId: user.id,
          role: 'member',
        });

        return Astro.redirect(`/ensembles/${invite.ensembleId}`);
      }
    }
  }
}
---

<Layout title="Join Ensemble">
  <div class="columns is-centered">
    <div class="column is-6-tablet is-5-desktop">
      <h1 class="title">Join an Ensemble</h1>
      <p class="subtitle">Enter your invite code to join an ensemble</p>

      {error && (
        <div class="notification is-danger is-light">
          {error}
        </div>
      )}

      {success && (
        <div class="notification is-success is-light">
          Successfully joined the ensemble!
        </div>
      )}

      <form method="POST">
        <div class="field">
          <label class="label" for="code">Invite Code</label>
          <div class="control has-icons-left">
            <input
              class="input is-large"
              type="text"
              id="code"
              name="code"
              placeholder="ABCD1234"
              style="text-transform: uppercase;"
              required
              autofocus
            />
            <span class="icon is-left">
              <i class="fas fa-ticket"></i>
            </span>
          </div>
          <p class="help">Enter the 8-character code provided by your ensemble admin</p>
        </div>

        <div class="field is-grouped">
          <div class="control">
            <button type="submit" class="button is-primary">
              Join Ensemble
            </button>
          </div>
          <div class="control">
            <a href="/ensembles" class="button is-light">
              Cancel
            </a>
          </div>
        </div>
      </form>
    </div>
  </div>
</Layout>
