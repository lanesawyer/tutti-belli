---
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import { Button, TextInput, Notification } from "astro-bulma";
import { actions } from "astro:actions";

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect("/ensembles");
}

const result = Astro.getActionResult(actions.auth.forgotPassword);
const submitted = result && !result.error;
const error = result?.error?.message ?? "";
---

<SingleColumnLayout title="Forgot Password">
  <h1 class="title">Forgot Password</h1>

  {
    error && (
      <Notification color="danger" light>
        {error}
      </Notification>
    )
  }

  {
    submitted ? (
      <Notification color="success" light>
        <p>
          <strong>Check your email.</strong>
        </p>
        <p class="mt-2">
          If an account exists for that address, we've sent a link to reset your
          password. It will expire in 1 hour.
        </p>
      </Notification>
    ) : (
      <form method="POST" action={actions.auth.forgotPassword}>
        <p class="mb-4 has-text-grey">
          Enter your email address and we'll send you a link to reset your
          password.
        </p>

        <TextInput
          name="email"
          label="Email"
          type="email"
          placeholder="you@example.com"
          iconLeft="fa-envelope"
          required
          autofocus
        />

        <div class="field">
          <div class="control">
            <Button color="primary" fullwidth type="submit">
              Send Reset Link
            </Button>
          </div>
        </div>
      </form>
    )
  }

  <div class="has-text-centered mt-4">
    <a href="/login">Back to Log In</a>
  </div>
</SingleColumnLayout>
