---
import Layout from '../layouts/Layout.astro';
import Button from '../components/elements/Button.astro';
import Icon from '../components/elements/Icon.astro';
import Notification from '../components/elements/Notification.astro';
import { db, eq, User, PasswordResetToken } from 'astro:db';
import { sendPasswordResetEmail } from '../lib/email';

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect('/ensembles');
}

let submitted = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString();

    if (!email) {
      error = 'Please enter your email address.';
    } else {
      const [user] = await db.select().from(User).where(eq(User.email, email));

      if (user) {
        const token = crypto.randomUUID();
        const expiresAt = new Date(Date.now() + 60 * 60 * 1000); // 1 hour

        await db.insert(PasswordResetToken).values({
          id: crypto.randomUUID(),
          userId: user.id,
          token,
          expiresAt,
        });

        const result = await sendPasswordResetEmail(user.email, user.name, token);
        if (!result.success) {
          console.error('Email send failed:', result.error);
          // Surface error in dev so it's easier to debug
          if (import.meta.env.DEV) {
            error = `Email failed: ${result.error}`;
          }
        }
      }

      // Always show success to avoid leaking whether the email exists
      if (!error) submitted = true;
    }
  } catch (e) {
    console.error('Forgot password error:', e);
    error = 'An error occurred. Please try again.';
  }
}
---

<Layout title="Forgot Password">
  <div class="columns is-centered">
    <div class="column is-5-tablet is-4-desktop">
      <h1 class="title">Forgot Password</h1>

      {error && (
        <Notification color="danger" light>
          {error}
        </Notification>
      )}

      {submitted ? (
        <Notification color="success" light>
          <p><strong>Check your email.</strong></p>
          <p class="mt-2">If an account exists for that address, we've sent a link to reset your password. It will expire in 1 hour.</p>
        </Notification>
      ) : (
        <form method="POST">
          <p class="mb-4 has-text-grey">Enter your email address and we'll send you a link to reset your password.</p>

          <div class="field">
            <label class="label" for="email">Email</label>
            <div class="control has-icons-left">
              <input
                class="input"
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                required
                autofocus
              />
              <Icon icon="fa-envelope" size="small" position="left" />
            </div>
          </div>

          <div class="field">
            <div class="control">
              <Button color="primary" fullwidth type="submit">
                Send Reset Link
              </Button>
            </div>
          </div>
        </form>
      )}

      <div class="has-text-centered mt-4">
        <a href="/login">Back to Log In</a>
      </div>
    </div>
  </div>
</Layout>
