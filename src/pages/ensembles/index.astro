---
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/Button.astro';
import Notification from '../../components/Notification.astro';
import Tag from '../../components/Tag.astro';
import { db, eq, Ensemble, EnsembleMember } from 'astro:db';
import { getEnsembleUrlId } from '../../lib/slug';

const user = Astro.locals.user!;

// Get all ensembles the user is a member of
const userEnsembles = await db
  .select({
    id: Ensemble.id,
    slug: Ensemble.slug,
    name: Ensemble.name,
    description: Ensemble.description,
    role: EnsembleMember.role,
    joinedAt: EnsembleMember.joinedAt,
  })
  .from(EnsembleMember)
  .innerJoin(Ensemble, eq(EnsembleMember.ensembleId, Ensemble.id))
  .where(eq(EnsembleMember.userId, user.id));
---

<PageLayout title="My Ensembles" pageTitle="My Ensembles">
  <div slot="action" class="buttons">
    <Button href="/invite/join" color="light">
      <span class="icon">
        <i class="fas fa-ticket"></i>
      </span>
      <span>Join with Invite Code</span>
    </Button>
    <Button href="/ensembles/new" color="primary">
      <span class="icon">
        <i class="fas fa-plus"></i>
      </span>
      <span>Create Ensemble</span>
    </Button>
  </div>

  {userEnsembles.length > 0 ? (
    <div class="columns is-multiline">
      {userEnsembles.map((ensemble) => (
        <div class="column is-4">
          <div class="card">
            <div class="card-content">
              <p class="title is-4">{ensemble.name}</p>
              {ensemble.description && (
                <p class="subtitle is-6">{ensemble.description}</p>
              )}
              <div class="tags mt-2">
                <Tag color={ensemble.role === 'admin' ? 'warning' : 'info'}>
                  {ensemble.role === 'admin' ? 'Ensemble Admin' : 'Member'}
                </Tag>
              </div>
            </div>
            <footer class="card-footer">
              <a href={`/ensembles/${getEnsembleUrlId(ensemble)}`} class="card-footer-item">
                View Details
              </a>
            </footer>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <Notification color="info" light>
      <p>You haven't joined any ensembles yet. Ask your ensemble admin for an invite code!</p>
    </Notification>
  )}
</PageLayout>
