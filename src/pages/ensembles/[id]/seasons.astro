---
import EnsemblePageLayout from '../../../layouts/EnsemblePageLayout.astro';
import Table from '../../../components/Table.astro';
import Modal from '../../../components/Modal.astro';
import Button from '../../../components/Button.astro';
import Notification from '../../../components/Notification.astro';
import { db, eq, and, desc, EnsembleMember, Season, SeasonMembership, User, Event } from 'astro:db';
import { getEnsembleBySlugOrId, getEnsembleAccess } from '../../../lib/ensemble';
import { getEnsembleUrlId } from '../../../lib/slug';

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === 'GET' && id !== canonicalId) {
  return Astro.redirect(Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`), 301);
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return new Response('Unauthorized - Not a member', { status: 403 });
const { isAdmin } = access;

let message = '';
let messageType = '';

// Handle form submission
if (Astro.request.method === 'POST') {
  if (!isAdmin) {
    return new Response('Unauthorized', { status: 403 });
  }

  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create') {
    const name = formData.get('name')?.toString();
    const startDate = formData.get('startDate')?.toString();
    const endDate = formData.get('endDate')?.toString();
    const setActive = formData.get('setActive')?.toString() === 'on';

    if (!name || !name.trim()) {
      message = 'Season name is required';
      messageType = 'danger';
    } else {
      if (setActive) {
        await db.update(Season).set({ isActive: 0 }).where(eq(Season.ensembleId, ensemble.id));
      }

      await db.insert(Season).values({
        id: crypto.randomUUID(),
        ensembleId: ensemble.id,
        name: name.trim(),
        startDate: startDate ? new Date(startDate) : undefined,
        endDate: endDate ? new Date(endDate) : undefined,
        isActive: setActive ? 1 : 0,
      });

      message = 'Season created successfully!';
      messageType = 'success';
    }
  } else if (action === 'edit') {
    const seasonId = formData.get('seasonId')?.toString();
    const name = formData.get('name')?.toString();
    const startDate = formData.get('startDate')?.toString();
    const endDate = formData.get('endDate')?.toString();
    const setActive = formData.get('setActive')?.toString() === 'on';

    if (seasonId && name && name.trim()) {
      if (setActive) {
        await db.update(Season).set({ isActive: 0 }).where(eq(Season.ensembleId, ensemble.id));
      }

      await db
        .update(Season)
        .set({
          name: name.trim(),
          startDate: startDate ? new Date(startDate) : undefined,
          endDate: endDate ? new Date(endDate) : undefined,
          isActive: setActive ? 1 : 0,
        })
        .where(eq(Season.id, seasonId));

      message = 'Season updated successfully!';
      messageType = 'success';
    }
  } else if (action === 'delete') {
    const seasonId = formData.get('seasonId')?.toString();
    if (seasonId) {
      const rehearsals = await db
        .select()
        .from(Event)
        .where(eq(Event.seasonId, seasonId))
        .limit(1);

      if (rehearsals.length > 0) {
        message = 'Cannot delete a season that has rehearsals.';
        messageType = 'danger';
      } else {
        await db.delete(SeasonMembership).where(eq(SeasonMembership.seasonId, seasonId));
        await db.delete(Season).where(eq(Season.id, seasonId));
        message = 'Season deleted successfully!';
        messageType = 'success';
      }
    }
  } else if (action === 'toggle-member') {
    const seasonId = formData.get('seasonId')?.toString();
    const userId = formData.get('userId')?.toString();

    if (seasonId && userId) {
      const [existing] = await db
        .select()
        .from(SeasonMembership)
        .where(and(eq(SeasonMembership.seasonId, seasonId), eq(SeasonMembership.userId, userId)));

      if (existing) {
        await db.delete(SeasonMembership).where(eq(SeasonMembership.id, existing.id));
      } else {
        await db.insert(SeasonMembership).values({
          id: crypto.randomUUID(),
          seasonId,
          userId,
        });
      }
    }
  }
}

// Get all seasons
const seasons = await db
  .select()
  .from(Season)
  .where(eq(Season.ensembleId, ensemble.id))
  .orderBy(desc(Season.createdAt));

// Get all ensemble members
const allMembers = await db
  .select({ id: User.id, name: User.name, email: User.email })
  .from(EnsembleMember)
  .innerJoin(User, eq(EnsembleMember.userId, User.id))
  .where(eq(EnsembleMember.ensembleId, ensemble.id));

// Get season memberships
const seasonMemberships = await db
  .select({ seasonId: SeasonMembership.seasonId, userId: SeasonMembership.userId, userName: User.name })
  .from(SeasonMembership)
  .innerJoin(User, eq(SeasonMembership.userId, User.id));

const membershipsBySeasonId = seasonMemberships.reduce((acc, m) => {
  if (!acc[m.seasonId]) acc[m.seasonId] = [];
  acc[m.seasonId].push(m);
  return acc;
}, {} as Record<string, typeof seasonMemberships>);
---

<EnsemblePageLayout
  title={`Seasons - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Seasons"
  message={message}
  messageType={messageType}
  isAdmin={isAdmin}
>
  {isAdmin && (
    <Button slot="action" color="primary" id="create-season-btn">
      <span class="icon"><i class="fas fa-plus"></i></span>
      <span>Create Season</span>
    </Button>
  )}

  {seasons.length === 0 ? (
    <Notification color="info" light>
      No seasons yet. {isAdmin && 'Create one to get started!'}
    </Notification>
  ) : (
    <Table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Dates</th>
          <th>Members</th>
          <th>Status</th>
          {isAdmin && <th style="width: 160px;">Actions</th>}
        </tr>
      </thead>
      <tbody>
        {seasons.map((season) => {
          const members = membershipsBySeasonId[season.id] || [];
          const startDate = season.startDate ? new Date(season.startDate).toLocaleDateString() : null;
          const endDate = season.endDate ? new Date(season.endDate).toLocaleDateString() : null;
          return (
            <tr>
              <td><strong>{season.name}</strong></td>
              <td>
                {startDate || endDate
                  ? `${startDate || '?'} – ${endDate || '?'}`
                  : '-'}
              </td>
              <td>{members.length}</td>
              <td>
                {season.isActive === 1
                  ? <span class="tag is-success">Active</span>
                  : <span class="tag is-light">Inactive</span>}
              </td>
              {isAdmin && (
                <td>
                  <div class="buttons are-small">
                    <Button
                      color="info"
                      class="manage-members-btn"
                      data-season-id={season.id}
                      data-season-name={season.name}
                    >
                      <span class="icon"><i class="fas fa-users"></i></span>
                    </Button>
                    <Button
                      color="warning"
                      class="edit-season-btn"
                      data-season-id={season.id}
                      data-season-name={season.name}
                      data-season-start={season.startDate ? new Date(season.startDate).toISOString().split('T')[0] : ''}
                      data-season-end={season.endDate ? new Date(season.endDate).toISOString().split('T')[0] : ''}
                      data-season-active={season.isActive === 1 ? 'true' : 'false'}
                    >
                      <span class="icon"><i class="fas fa-edit"></i></span>
                    </Button>
                    <Button
                      color="danger"
                      class="delete-season-btn"
                      data-season-id={season.id}
                    >
                      <span class="icon"><i class="fas fa-trash"></i></span>
                    </Button>
                  </div>
                </td>
              )}
            </tr>
          );
        })}
      </tbody>
    </Table>
  )}

  <Fragment slot="modals">
<!-- Create Season Modal -->
{isAdmin && (
  <Modal id="create-modal" title="Create Season">
    <form id="createForm" method="POST">
      <input type="hidden" name="action" value="create" />

      <div class="field">
        <label class="label" for="create-name">Season Name *</label>
        <div class="control">
          <input class="input" type="text" id="create-name" name="name" placeholder="e.g., Fall 2026, Spring 2027" required />
        </div>
      </div>

      <div class="columns">
        <div class="column">
          <div class="field">
            <label class="label" for="create-startDate">Start Date</label>
            <div class="control">
              <input class="input" type="date" id="create-startDate" name="startDate" />
            </div>
          </div>
        </div>
        <div class="column">
          <div class="field">
            <label class="label" for="create-endDate">End Date</label>
            <div class="control">
              <input class="input" type="date" id="create-endDate" name="endDate" />
            </div>
          </div>
        </div>
      </div>

      <div class="field">
        <div class="control">
          <label class="checkbox">
            <input type="checkbox" name="setActive" />
            Set as active season
          </label>
        </div>
        <p class="help">Only one season can be active at a time. New rehearsals use the active season.</p>
      </div>
    </form>

    <div slot="footer">
      <Button type="submit" form="createForm" color="primary">Create Season</Button>
      <Button type="button" data-modal-close>Cancel</Button>
    </div>
  </Modal>
)}

<!-- Edit Season Modal -->
{isAdmin && (
  <Modal id="edit-modal" title="Edit Season">
    <form id="editForm" method="POST">
      <input type="hidden" name="action" value="edit" />
      <input type="hidden" name="seasonId" id="edit-seasonId" />

      <div class="field">
        <label class="label" for="edit-name">Season Name *</label>
        <div class="control">
          <input class="input" type="text" id="edit-name" name="name" required />
        </div>
      </div>

      <div class="columns">
        <div class="column">
          <div class="field">
            <label class="label" for="edit-startDate">Start Date</label>
            <div class="control">
              <input class="input" type="date" id="edit-startDate" name="startDate" />
            </div>
          </div>
        </div>
        <div class="column">
          <div class="field">
            <label class="label" for="edit-endDate">End Date</label>
            <div class="control">
              <input class="input" type="date" id="edit-endDate" name="endDate" />
            </div>
          </div>
        </div>
      </div>

      <div class="field">
        <div class="control">
          <label class="checkbox">
            <input type="checkbox" name="setActive" id="edit-setActive" />
            Set as active season
          </label>
        </div>
      </div>
    </form>

    <div slot="footer">
      <Button type="submit" form="editForm" color="primary">Save Changes</Button>
      <Button type="button" data-modal-close>Cancel</Button>
    </div>
  </Modal>
)}

<!-- Manage Members Modal -->
{isAdmin && (
  <Modal id="members-modal" title="Manage Season Members">
    <input type="hidden" id="members-seasonId" />
    <p class="mb-3">Select which members participate in this season:</p>
    {allMembers.map((member) => (
      <div class="field">
        <div class="control">
          <label class="checkbox">
            <input type="checkbox" class="member-checkbox" data-user-id={member.id} />
            {member.name}
          </label>
        </div>
      </div>
    ))}

    <div slot="footer">
      <Button type="button" id="close-members-btn">Done</Button>
    </div>
  </Modal>
)}

<!-- Delete Confirmation Modal -->
{isAdmin && (
  <Modal id="delete-modal" title="Delete Season">
    <p>Are you sure you want to delete this season? This action cannot be undone.</p>
    <p class="has-text-danger mt-2"><strong>Note:</strong> Seasons with rehearsals cannot be deleted.</p>
    <form id="deleteForm" method="POST">
      <input type="hidden" name="action" value="delete" />
      <input type="hidden" name="seasonId" id="delete-seasonId" />
    </form>

    <div slot="footer">
      <Button type="submit" form="deleteForm" color="danger">Delete</Button>
      <Button type="button" data-modal-close>Cancel</Button>
    </div>
  </Modal>
)}

<script is:inline define:vars={{ membershipsBySeasonId }}>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('create-season-btn')?.addEventListener('click', () => {
      document.getElementById('create-modal')?.classList.add('is-active');
    });

    document.querySelectorAll('.edit-season-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('edit-seasonId').value = btn.getAttribute('data-season-id');
        document.getElementById('edit-name').value = btn.getAttribute('data-season-name');
        document.getElementById('edit-startDate').value = btn.getAttribute('data-season-start');
        document.getElementById('edit-endDate').value = btn.getAttribute('data-season-end');
        document.getElementById('edit-setActive').checked = btn.getAttribute('data-season-active') === 'true';
        document.getElementById('edit-modal')?.classList.add('is-active');
      });
    });

    document.querySelectorAll('.manage-members-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const seasonId = btn.getAttribute('data-season-id');
        document.getElementById('members-seasonId').value = seasonId;

        const seasonMembers = membershipsBySeasonId[seasonId] || [];
        const memberUserIds = new Set(seasonMembers.map(m => m.userId));

        document.querySelectorAll('.member-checkbox').forEach(checkbox => {
          checkbox.checked = memberUserIds.has(checkbox.getAttribute('data-user-id'));
        });

        document.getElementById('members-modal')?.classList.add('is-active');
      });
    });

    document.querySelectorAll('.member-checkbox').forEach(checkbox => {
      checkbox.addEventListener('change', async () => {
        const seasonId = document.getElementById('members-seasonId').value;
        const userId = checkbox.getAttribute('data-user-id');

        const formData = new FormData();
        formData.append('action', 'toggle-member');
        formData.append('seasonId', seasonId);
        formData.append('userId', userId);

        await fetch('', { method: 'POST', body: formData });
      });
    });

    document.getElementById('close-members-btn')?.addEventListener('click', () => {
      document.getElementById('members-modal')?.classList.remove('is-active');
      window.location.reload();
    });

    document.querySelectorAll('.delete-season-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('delete-seasonId').value = btn.getAttribute('data-season-id');
        document.getElementById('delete-modal')?.classList.add('is-active');
      });
    });
  });
</script>
  </Fragment>
</EnsemblePageLayout>
