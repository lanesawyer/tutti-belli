---
import EnsemblePageLayout from "@layouts/EnsemblePageLayout.astro";
import {
  Table,
  Modal,
  Button,
  Icon,
  TextInput,
  Checkbox,
  Notification,
  Tag,
} from "astro-bulma";
import { actions } from "astro:actions";
import { getEnsembleBySlugOrId, getEnsembleAccess } from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import {
  getEnsembleSeasons,
  getSeasonMembershipsWithUsers,
  getEnsembleMembersBasic,
} from "@lib/seasons";

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);

if (!ensemble) {
  return new Response("Ensemble not found", { status: 404 });
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(
    Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`),
    301,
  );
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access)
  return new Response("Unauthorized - Not a member", { status: 403 });
const { isAdmin } = access;

const createResult = Astro.getActionResult(actions.seasons.create);
const updateResult = Astro.getActionResult(actions.seasons.update);
const deleteResult = Astro.getActionResult(actions.seasons.delete);

let message = "";
let messageType: "success" | "danger" | undefined;

if (createResult?.error) {
  message = createResult.error.message ?? "Failed to create season.";
  messageType = "danger";
} else if (createResult) {
  message = "Season created successfully!";
  messageType = "success";
} else if (updateResult?.error) {
  message = updateResult.error.message ?? "Failed to update season.";
  messageType = "danger";
} else if (updateResult) {
  message = "Season updated successfully!";
  messageType = "success";
} else if (deleteResult?.error) {
  message = deleteResult.error.message ?? "Failed to delete season.";
  messageType = "danger";
} else if (deleteResult) {
  message = "Season deleted successfully!";
  messageType = "success";
}

const seasons = await getEnsembleSeasons(ensemble.id);
const allMembers = await getEnsembleMembersBasic(ensemble.id);
const seasonMemberships = await getSeasonMembershipsWithUsers(ensemble.id);

const membershipsBySeasonId = seasonMemberships.reduce(
  (acc, m) => {
    if (!acc[m.seasonId]) acc[m.seasonId] = [];
    acc[m.seasonId].push(m);
    return acc;
  },
  {} as Record<string, typeof seasonMemberships>,
);
---

<EnsemblePageLayout
  title={`Seasons - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Seasons"
  message={message}
  messageType={messageType}
  isAdmin={isAdmin}
>
  {
    isAdmin && (
      <Button slot="action" color="primary" id="create-season-btn">
        <Icon icon="fa-plus" />
        <span>Create Season</span>
      </Button>
    )
  }

  {
    seasons.length === 0 ? (
      <Notification color="info" light>
        No seasons yet. {isAdmin && "Create one to get started!"}
      </Notification>
    ) : (
      <Table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Dates</th>
            <th>Members</th>
            <th>Status</th>
            {isAdmin && <th style="width: 160px;">Actions</th>}
          </tr>
        </thead>
        <tbody>
          {seasons.map((season) => {
            const members = membershipsBySeasonId[season.id] || [];
            const startDate = season.startDate
              ? new Date(season.startDate).toLocaleDateString()
              : null;
            const endDate = season.endDate
              ? new Date(season.endDate).toLocaleDateString()
              : null;
            return (
              <tr>
                <td>
                  <strong>{season.name}</strong>
                </td>
                <td>
                  {startDate || endDate
                    ? `${startDate || "?"} – ${endDate || "?"}`
                    : "-"}
                </td>
                <td>{members.length}</td>
                <td>
                  {season.isActive === 1 ? (
                    <Tag color="success">Active</Tag>
                  ) : (
                    <Tag color="light">Inactive</Tag>
                  )}
                </td>
                {isAdmin && (
                  <td>
                    <div class="buttons are-small">
                      <Button
                        color="info"
                        class="manage-members-btn"
                        data-season-id={season.id}
                        data-season-name={season.name}
                      >
                        <Icon icon="fa-users" />
                      </Button>
                      <Button
                        color="warning"
                        class="edit-season-btn"
                        data-season-id={season.id}
                        data-season-name={season.name}
                        data-season-start={
                          season.startDate
                            ? new Date(season.startDate)
                                .toISOString()
                                .split("T")[0]
                            : ""
                        }
                        data-season-end={
                          season.endDate
                            ? new Date(season.endDate)
                                .toISOString()
                                .split("T")[0]
                            : ""
                        }
                        data-season-active={
                          season.isActive === 1 ? "true" : "false"
                        }
                      >
                        <Icon icon="fa-edit" />
                      </Button>
                      <Button
                        color="danger"
                        class="delete-season-btn"
                        data-season-id={season.id}
                      >
                        <Icon icon="fa-trash" />
                      </Button>
                    </div>
                  </td>
                )}
              </tr>
            );
          })}
        </tbody>
      </Table>
    )
  }

  <Fragment slot="modals">
    <!-- Create Season Modal -->
    {
      isAdmin && (
        <Modal id="create-modal" title="Create Season">
          <form id="createForm" method="POST" action={actions.seasons.create}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />

            <TextInput
              name="name"
              id="create-name"
              label="Season Name *"
              placeholder="e.g., Fall 2026, Spring 2027"
              required
            />

            <div class="columns">
              <div class="column">
                <TextInput
                  name="startDate"
                  id="create-startDate"
                  label="Start Date"
                  type="date"
                />
              </div>
              <div class="column">
                <TextInput
                  name="endDate"
                  id="create-endDate"
                  label="End Date"
                  type="date"
                />
              </div>
            </div>

            <div class="field">
              <div class="control">
                <Checkbox name="setActive" label="Set as active season" />
              </div>
              <p class="help">
                Only one season can be active at a time. New rehearsals use the
                active season.
              </p>
            </div>
          </form>

          <div slot="footer">
            <Button type="submit" form="createForm" color="primary">
              Create Season
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Edit Season Modal -->
    {
      isAdmin && (
        <Modal id="edit-modal" title="Edit Season">
          <form id="editForm" method="POST" action={actions.seasons.update}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="seasonId" id="edit-seasonId" />

            <TextInput
              name="name"
              id="edit-name"
              label="Season Name *"
              required
            />

            <div class="columns">
              <div class="column">
                <TextInput
                  name="startDate"
                  id="edit-startDate"
                  label="Start Date"
                  type="date"
                />
              </div>
              <div class="column">
                <TextInput
                  name="endDate"
                  id="edit-endDate"
                  label="End Date"
                  type="date"
                />
              </div>
            </div>

            <div class="field">
              <div class="control">
                <Checkbox
                  name="setActive"
                  id="edit-setActive"
                  label="Set as active season"
                />
              </div>
            </div>
          </form>

          <div slot="footer">
            <Button type="submit" form="editForm" color="primary">
              Save Changes
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Manage Members Modal -->
    {
      isAdmin && (
        <Modal id="members-modal" title="Manage Season Members">
          <input type="hidden" id="members-seasonId" />
          <p class="mb-3">Select which members participate in this season:</p>
          {allMembers.map((member) => (
            <div class="field">
              <div class="control">
                <Checkbox
                  name="member"
                  class="member-checkbox"
                  data-user-id={member.id}
                  label={member.name}
                />
              </div>
            </div>
          ))}

          <div slot="footer">
            <Button type="button" id="close-members-btn">
              Done
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Delete Confirmation Modal -->
    {
      isAdmin && (
        <Modal id="delete-modal" title="Delete Season">
          <p>
            Are you sure you want to delete this season? This action cannot be
            undone.
          </p>
          <p class="has-text-danger mt-2">
            <strong>Note:</strong> Seasons with rehearsals cannot be deleted.
          </p>
          <form id="deleteForm" method="POST" action={actions.seasons.delete}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="seasonId" id="delete-seasonId" />
          </form>

          <div slot="footer">
            <Button type="submit" form="deleteForm" color="danger">
              Delete
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <script
      is:inline
      define:vars={{ membershipsBySeasonId, ensembleId: ensemble.id }}
    >
      document.addEventListener("astro:page-load", () => {
        document
          .getElementById("create-season-btn")
          ?.addEventListener("click", () => {
            document.getElementById("create-modal")?.classList.add("is-active");
          });

        document.querySelectorAll(".edit-season-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("edit-seasonId").value =
              btn.getAttribute("data-season-id");
            document.getElementById("edit-name").value =
              btn.getAttribute("data-season-name");
            document.getElementById("edit-startDate").value =
              btn.getAttribute("data-season-start");
            document.getElementById("edit-endDate").value =
              btn.getAttribute("data-season-end");
            document.getElementById("edit-setActive").checked =
              btn.getAttribute("data-season-active") === "true";
            document.getElementById("edit-modal")?.classList.add("is-active");
          });
        });

        document.querySelectorAll(".manage-members-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            const seasonId = btn.getAttribute("data-season-id");
            document.getElementById("members-seasonId").value = seasonId;

            const seasonMembers = membershipsBySeasonId[seasonId] || [];
            const memberUserIds = new Set(seasonMembers.map((m) => m.userId));

            document
              .querySelectorAll(".member-checkbox")
              .forEach((checkbox) => {
                checkbox.checked = memberUserIds.has(
                  checkbox.getAttribute("data-user-id"),
                );
              });

            document
              .getElementById("members-modal")
              ?.classList.add("is-active");
          });
        });

        document.querySelectorAll(".member-checkbox").forEach((checkbox) => {
          checkbox.addEventListener("change", async () => {
            const seasonId = document.getElementById("members-seasonId").value;
            const userId = checkbox.getAttribute("data-user-id");

            const formData = new FormData();
            formData.append("ensembleId", ensembleId);
            formData.append("seasonId", seasonId);
            formData.append("userId", userId);

            await fetch("/_actions/seasons.toggleMember", {
              method: "POST",
              body: formData,
            });
          });
        });

        document
          .getElementById("close-members-btn")
          ?.addEventListener("click", () => {
            document
              .getElementById("members-modal")
              ?.classList.remove("is-active");
            window.location.reload();
          });

        document.querySelectorAll(".delete-season-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("delete-seasonId").value =
              btn.getAttribute("data-season-id");
            document.getElementById("delete-modal")?.classList.add("is-active");
          });
        });
      });
    </script>
  </Fragment>
</EnsemblePageLayout>
