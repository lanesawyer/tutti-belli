---
import Layout from '../../../layouts/Layout.astro';
import { db, eq, and, Ensemble, EnsembleMember } from 'astro:db';
import { fileToDataUri, validateImageFile } from '../../../lib/upload';
import { canManageEnsemble } from '../../../lib/permissions';
import { ensembleAdminTools } from '../../../lib/config';

const user = Astro.locals.user!;

const { id } = Astro.params;

// Get the ensemble
const ensemble = await db
  .select()
  .from(Ensemble)
  .where(eq(Ensemble.id, id!))
  .get();

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

// Check if user is an admin of this ensemble
const membership = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.userId, user.id)))
  .get();

const isAdmin = canManageEnsemble(user, membership);

if (!isAdmin) {
  return new Response('Unauthorized', { status: 403 });
}

let message = '';
let messageType = '';

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = formData.get('name')?.toString();
  const description = formData.get('description')?.toString();
  const discordLink = formData.get('discordLink')?.toString();
  const codeOfConduct = formData.get('codeOfConduct')?.toString();
  const imageFile = formData.get('image') as File;
  const removeImage = formData.get('removeImage')?.toString() === 'true';
  const checkInStartMinutes = parseInt(formData.get('checkInStartMinutes')?.toString() || '30');
  const checkInEndMinutes = parseInt(formData.get('checkInEndMinutes')?.toString() || '15');

  if (!name || !name.trim()) {
    message = 'Ensemble name is required';
    messageType = 'danger';
  } else {
    try {
      let imageUrl = ensemble.imageUrl;

      // Handle image removal
      if (removeImage && imageUrl) {
        imageUrl = null;
      }

      // Handle new image upload
      if (imageFile && imageFile.size > 0) {
        const validation = validateImageFile(imageFile, 5);
        if (!validation.valid) {
          message = validation.error!;
          messageType = 'danger';
        } else {
          // Convert image to data URI and store in database
          imageUrl = await fileToDataUri(imageFile);
        }
      }

      if (!message) {
        await db
          .update(Ensemble)
          .set({
            name: name.trim(),
            description: description?.trim() || null,
            discordLink: discordLink?.trim() || null,
            codeOfConduct: codeOfConduct?.trim() || null,
            imageUrl,
            checkInStartMinutes,
            checkInEndMinutes,
          })
          .where(eq(Ensemble.id, id!));

        return Astro.redirect(`/ensembles/${id}`);
      }
    } catch (error) {
      console.error('Error updating ensemble:', error);
      message = 'Failed to update ensemble';
      messageType = 'danger';
    }
  }
}
---

<Layout title={`Edit ${ensemble.name}`}>
  <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
    <a class="navbar-link">{ensemble.name}</a>
    <div class="navbar-dropdown">
      <a class={`navbar-item${Astro.url.pathname === `/ensembles/${id}` ? ' is-active' : ''}`} href={`/ensembles/${id}`}>
        <span class="icon is-small mr-1"><i class="fas fa-home"></i></span>
        Dashboard
      </a>
      <hr class="navbar-divider" />
      {ensembleAdminTools.map((tool) => {
        const href = tool.href(id!);
        return (
          <a class={`navbar-item${Astro.url.pathname.startsWith(href) ? ' is-active' : ''}`} href={href}>
            <span class="icon is-small mr-1"><i class={`fas ${tool.icon}`}></i></span>
            {tool.label}
          </a>
        );
      })}
    </div>
  </div>
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumbs">
        <ul>
          <li><a href="/ensembles">Ensembles</a></li>
          <li><a href={`/ensembles/${id}`}>{ensemble.name}</a></li>
          <li class="is-active"><a href="#" aria-current="page">Edit</a></li>
        </ul>
      </nav>

      <h1 class="title">Edit Ensemble</h1>

      {message && (
        <div class={`notification is-${messageType}`}>
          {message}
        </div>
      )}

      <div class="columns">
        <div class="column is-two-thirds">
          <div class="box">
            <form method="POST" enctype="multipart/form-data">
              <div class="field">
                <label class="label" for="name">Ensemble Name</label>
                <div class="control">
                  <input
                    class="input"
                    type="text"
                    id="name"
                    name="name"
                    value={ensemble.name}
                    required
                  />
                </div>
              </div>

              <div class="field">
                <label class="label" for="description">Description</label>
                <div class="control">
                  <textarea
                    class="textarea"
                    id="description"
                    name="description"
                    rows="4"
                    placeholder="Optional description..."
                  >{ensemble.description || ''}</textarea>
                </div>
              </div>

              <div class="field">
                <label class="label" for="discordLink">Discord Link</label>
                <div class="control has-icons-left">
                  <input
                    class="input"
                    type="url"
                    id="discordLink"
                    name="discordLink"
                    value={ensemble.discordLink || ''}
                    placeholder="https://discord.gg/..."
                  />
                  <span class="icon is-small is-left">
                    <i class="fab fa-discord"></i>
                  </span>
                </div>
                <p class="help">Optional Discord server invite link for this ensemble</p>
              </div>

              <div class="field">
                <label class="label" for="codeOfConduct">Code of Conduct</label>
                <div class="control">
                  <textarea
                    class="textarea"
                    id="codeOfConduct"
                    name="codeOfConduct"
                    rows="8"
                    placeholder="Optional code of conduct for new members. If set, new members must agree to these terms before joining."
                  >{ensemble.codeOfConduct || ''}</textarea>
                </div>
                <p class="help">New members will be required to read and agree to this code of conduct before joining</p>
              </div>

              <div class="field">
                <label class="label">Ensemble Image</label>
                {ensemble.imageUrl && (
                  <div class="mb-3">
                    <p class="mb-2 has-text-weight-semibold">Current Image:</p>
                    <figure class="image is-128x128">
                      <img src={ensemble.imageUrl} alt={ensemble.name} style="object-fit: cover; border-radius: 8px;" />
                    </figure>
                    <label class="checkbox mt-2">
                      <input type="checkbox" name="removeImage" value="true" />
                      Remove current image
                    </label>
                  </div>
                )}
                <div class="control">
                  <div class="file has-name is-fullwidth">
                    <label class="file-label">
                      <input
                        class="file-input"
                        type="file"
                        name="image"
                        accept="image/*"
                        id="imageInput"
                      />
                      <span class="file-cta">
                        <span class="file-icon">
                          <i class="fas fa-upload"></i>
                        </span>
                        <span class="file-label">
                          {ensemble.imageUrl ? 'Replace image…' : 'Choose an image…'}
                        </span>
                      </span>
                      <span class="file-name" id="fileName">
                        No file selected
                      </span>
                    </label>
                  </div>
                </div>
                <p class="help">Maximum file size: 5MB. Supported formats: JPG, PNG, GIF, WebP</p>
              </div>

              <div class="field">
                <label class="label">Check-in Window Settings</label>
                <p class="help mb-3">Configure when members can check in for rehearsals</p>
                
                <div class="columns">
                  <div class="column is-6">
                    <div class="field">
                      <label class="label" for="checkInStartMinutes">Check-in opens (minutes before)</label>
                      <div class="control">
                        <input
                          class="input"
                          type="number"
                          id="checkInStartMinutes"
                          name="checkInStartMinutes"
                          value={ensemble.checkInStartMinutes}
                          min="0"
                          max="180"
                          required
                        />
                      </div>
                      <p class="help">Default: 30 minutes before rehearsal</p>
                    </div>
                  </div>
                  <div class="column is-6">
                    <div class="field">
                      <label class="label" for="checkInEndMinutes">Check-in closes (minutes after start)</label>
                      <div class="control">
                        <input
                          class="input"
                          type="number"
                          id="checkInEndMinutes"
                          name="checkInEndMinutes"
                          value={ensemble.checkInEndMinutes}
                          min="0"
                          max="180"
                          required
                        />
                      </div>
                      <p class="help">Default: 15 minutes after rehearsal starts</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="field is-grouped">
                <div class="control">
                  <button type="submit" class="button is-primary">
                    <span class="icon">
                      <i class="fas fa-save"></i>
                    </span>
                    <span>Save Changes</span>
                  </button>
                </div>
                <div class="control">
                  <a href={`/ensembles/${id}`} class="button is-light">
                    Cancel
                  </a>
                </div>
              </div>
            </form>
          </div>
        </div>

        <div class="column">
          <div class="box">
            <h2 class="title is-5">Tips</h2>
            <div class="content">
              <ul>
                <li>Choose a descriptive name for your ensemble</li>
                <li>Add a description to help members understand the ensemble's purpose</li>
                <li>Upload a logo or photo that represents your ensemble</li>
                <li>Square images work best for display</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Update file name display
    const fileInput = document.getElementById('imageInput') as HTMLInputElement;
    const fileName = document.getElementById('fileName');
    
    fileInput?.addEventListener('change', () => {
      if (fileInput.files && fileInput.files.length > 0) {
        const file = fileInput.files[0];
        if (fileName) {
          fileName.textContent = file.name;
        }
      } else if (fileName) {
        fileName.textContent = 'No file selected';
      }
    });
  </script>
</Layout>
