---
import BaseLayout from "@layouts/BaseLayout.astro";
import { actions } from "astro:actions";
import { canManageEnsemble } from "@lib/permissions";
import { ensembleAdminTools } from "@lib/config";
import {
  getEnsembleBySlugOrId,
  getEnsembleMembership,
  getEnsembleLinks,
} from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import {
  Box,
  Button,
  Image,
  Icon,
  TextInput,
  Checkbox,
  Breadcrumb,
  FileInput,
} from "astro-bulma";

const user = Astro.locals.user!;

const { id } = Astro.params;

const ensemble = await getEnsembleBySlugOrId(id!);

if (!ensemble) {
  return new Response("Ensemble not found", { status: 404 });
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(`/ensembles/${canonicalId}/edit`, 301);
}

const membership = await getEnsembleMembership(ensemble.id, user.id);
const isAdmin = canManageEnsemble(user, membership);

if (!isAdmin) {
  return new Response("Unauthorized", { status: 403 });
}

const updateResult = Astro.getActionResult(actions.ensembles.update);
const addLinkResult = Astro.getActionResult(actions.ensembles.addLink);
const deleteLinkResult = Astro.getActionResult(actions.ensembles.deleteLink);

if (updateResult?.data) {
  const newSlug = updateResult.data.newSlug;
  return Astro.redirect(`/ensembles/${newSlug || ensemble.id}`);
}
if (addLinkResult && !addLinkResult.error) {
  return Astro.redirect(`/ensembles/${canonicalId}/edit`);
}
if (deleteLinkResult && !deleteLinkResult.error) {
  return Astro.redirect(`/ensembles/${canonicalId}/edit`);
}

const ensembleLinks = await getEnsembleLinks(ensemble.id);

let message = "";
let messageType = "";
if (updateResult?.error) {
  message = updateResult.error.message ?? "Failed to update ensemble.";
  messageType = "danger";
} else if (addLinkResult?.error) {
  message = addLinkResult.error.message ?? "Failed to add link.";
  messageType = "danger";
} else if (deleteLinkResult?.error) {
  message = deleteLinkResult.error.message ?? "Failed to delete link.";
  messageType = "danger";
}
---

<BaseLayout title={`Edit ${ensemble.name}`}>
  <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
    <a class="navbar-link">{ensemble.name}</a>
    <div class="navbar-dropdown">
      <a
        class={`navbar-item${Astro.url.pathname === `/ensembles/${canonicalId}` ? " is-active" : ""}`}
        href={`/ensembles/${canonicalId}`}
      >
        <Icon icon="fa-home" size="small" class="mr-1" />
        Dashboard
      </a>
      <hr class="navbar-divider" />
      {
        ensembleAdminTools.map((tool) => {
          const href = tool.href(canonicalId);
          return (
            <a
              class={`navbar-item${Astro.url.pathname.startsWith(href) ? " is-active" : ""}`}
              href={href}
            >
              <Icon icon={tool.icon} size="small" class="mr-1" />
              {tool.label}
            </a>
          );
        })
      }
    </div>
  </div>
  <section class="section">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Ensembles", href: "/ensembles" },
          { label: ensemble.name, href: `/ensembles/${canonicalId}` },
          { label: "Edit" },
        ]}
      />

      <h1 class="title">Edit Ensemble</h1>

      {message && <div class={`notification is-${messageType}`}>{message}</div>}

      <div class="columns">
        <div class="column is-two-thirds">
          <Box>
            <form
              method="POST"
              enctype="multipart/form-data"
              action={actions.ensembles.update}
            >
              <input type="hidden" name="ensembleId" value={ensemble.id} />
              <input
                type="hidden"
                name="currentImageUrl"
                value={ensemble.imageUrl ?? ""}
              />
              <TextInput
                name="name"
                label="Ensemble Name"
                value={ensemble.name}
                required
              />
              <div class="field">
                <label class="label" for="slug">URL Slug</label>
                <div class="control">
                  <TextInput
                    name="slug"
                    id="slug"
                    value={ensemble.slug || ""}
                    placeholder="my-ensemble-name"
                    standalone
                  />
                </div>
                <p class="help">
                  Used in URLs: <code
                    >/ensembles/{ensemble.slug || ensemble.id}</code
                  >. Lowercase letters, numbers, and hyphens only. Leave blank
                  to use the ID.
                </p>
              </div>

              <div class="field">
                <label class="label" for="description">Description</label>
                <div class="control">
                  <textarea
                    class="textarea"
                    id="description"
                    name="description"
                    rows="4"
                    placeholder="Optional description..."
                    >{ensemble.description || ""}</textarea
                  >
                </div>
              </div>

              <TextInput
                name="discordLink"
                label="Discord Link"
                type="url"
                value={ensemble.discordLink || ""}
                placeholder="https://discord.gg/..."
                iconLeft="fa-discord"
                iconLeftVariant="fab"
                help="Optional Discord server invite link for this ensemble"
              />

              <TextInput
                name="discordWebhookUrl"
                label="Discord Webhook URL"
                type="url"
                value={ensemble.discordWebhookUrl || ""}
                placeholder="https://discord.com/api/webhooks/..."
                iconLeft="fa-discord"
                iconLeftVariant="fab"
                help="Paste a Discord webhook URL to enable posting announcements to a channel"
              />

              <div class="field">
                <label class="label">Links</label>
                <p class="help mb-3">
                  Add arbitrary links (e.g. sheet music, website, calendar)
                  shown on the ensemble page
                </p>

                {
                  ensembleLinks.length > 0 && (
                    <div class="mb-3">
                      {ensembleLinks.map((link) => (
                        <div class="field has-addons mb-2">
                          <div class="control is-expanded">
                            <TextInput
                              name="_link-display"
                              type="text"
                              value={`${link.label} — ${link.url}`}
                              static
                              readonly
                              standalone
                            />
                          </div>
                          <div class="control">
                            <Button
                              type="submit"
                              form={`delete-link-${link.id}`}
                              color="danger"
                              light
                              title="Remove link"
                            >
                              <Icon icon="fa-times" />
                            </Button>
                          </div>
                        </div>
                      ))}
                    </div>
                  )
                }

                <div class="field is-grouped">
                  <div class="control" style="flex: 0 0 10rem;">
                    <TextInput
                      name="label"
                      type="text"
                      form="add-link-form"
                      placeholder="Label"
                      maxlength="50"
                      standalone
                    />
                  </div>
                  <div class="control is-expanded">
                    <TextInput
                      name="url"
                      type="url"
                      form="add-link-form"
                      placeholder="https://..."
                      standalone
                    />
                  </div>
                  <div class="control">
                    <Button
                      type="submit"
                      form="add-link-form"
                      color="link"
                      light
                    >
                      <Icon icon="fa-plus" />
                      <span>Add</span>
                    </Button>
                  </div>
                </div>
              </div>

              <div class="field">
                <label class="label" for="codeOfConduct">Code of Conduct</label>
                <div class="control">
                  <textarea
                    class="textarea"
                    id="codeOfConduct"
                    name="codeOfConduct"
                    rows="8"
                    placeholder="Optional code of conduct for new members. If set, new members must agree to these terms before joining."
                    >{ensemble.codeOfConduct || ""}</textarea
                  >
                </div>
                <p class="help">
                  New members will be required to read and agree to this code of
                  conduct before joining
                </p>
              </div>

              <div class="field">
                <label class="label">Ensemble Image</label>
                {
                  ensemble.imageUrl && (
                    <div class="mb-3">
                      <p class="mb-2 has-text-weight-semibold">
                        Current Image:
                      </p>
                      <Image
                        src={ensemble.imageUrl}
                        alt={ensemble.name}
                        size="128x128"
                        imgStyle="object-fit: cover; border-radius: 8px;"
                      />
                      <Checkbox
                        name="removeImage"
                        value="true"
                        label="Remove current image"
                        class="mt-2"
                      />
                    </div>
                  )
                }
                <FileInput
                  name="image"
                  id="imageInput"
                  accept="image/*"
                  ctaLabel={ensemble.imageUrl
                    ? "Replace image…"
                    : "Choose an image…"}
                  help="Maximum file size: 5MB. Supported formats: JPG, PNG, GIF, WebP"
                />
              </div>

              <div class="field">
                <label class="label">Check-in Window Settings</label>
                <p class="help mb-3">
                  Configure when members can check in for rehearsals
                </p>

                <div class="columns">
                  <div class="column is-6">
                    <TextInput
                      name="checkInStartMinutes"
                      label="Check-in opens (minutes before)"
                      type="number"
                      value={ensemble.checkInStartMinutes}
                      min="0"
                      max="180"
                      required
                      help="Default: 30 minutes before rehearsal"
                    />
                  </div>
                  <div class="column is-6">
                    <TextInput
                      name="checkInEndMinutes"
                      label="Check-in closes (minutes after start)"
                      type="number"
                      value={ensemble.checkInEndMinutes}
                      min="0"
                      max="180"
                      required
                      help="Default: 15 minutes after rehearsal starts"
                    />
                  </div>
                </div>
              </div>

              <div class="field is-grouped">
                <div class="control">
                  <Button type="submit" color="primary">
                    <Icon icon="fa-save" />
                    <span>Save Changes</span>
                  </Button>
                </div>
                <div class="control">
                  <Button href={`/ensembles/${canonicalId}`} color="light">
                    Cancel
                  </Button>
                </div>
              </div>
            </form>

            <!-- Out-of-band forms for links (nested forms are invalid HTML) -->
            <form
              id="add-link-form"
              method="POST"
              action={actions.ensembles.addLink}
            >
              <input type="hidden" name="ensembleId" value={ensemble.id} />
            </form>
            {
              ensembleLinks.map((link) => (
                <form
                  id={`delete-link-${link.id}`}
                  method="POST"
                  action={actions.ensembles.deleteLink}
                >
                  <input type="hidden" name="ensembleId" value={ensemble.id} />
                  <input type="hidden" name="linkId" value={link.id} />
                </form>
              ))
            }
          </Box>
        </div>

        <div class="column">
          <Box>
            <h2 class="title is-5">Tips</h2>
            <div class="content">
              <ul>
                <li>Choose a descriptive name for your ensemble</li>
                <li>
                  Add a description to help members understand the ensemble's
                  purpose
                </li>
                <li>Upload a logo or photo that represents your ensemble</li>
                <li>Square images work best for display</li>
              </ul>
            </div>
          </Box>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
