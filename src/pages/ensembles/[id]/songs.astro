---
import Layout from '../../../layouts/Layout.astro';
import { db, eq, and, Ensemble, EnsembleMember, Song, SongPart, Part, Season, SeasonSong } from 'astro:db';
import { canManageEnsemble } from '../../../lib/permissions';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

// Get the ensemble
const ensemble = await db
  .select()
  .from(Ensemble)
  .where(eq(Ensemble.id, id!))
  .get();

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

// Check if user is an admin of this ensemble
const membership = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.userId, user.id)))
  .get();

const isAdmin = canManageEnsemble(user, membership);

if (!isAdmin) {
  return new Response('Unauthorized', { status: 403 });
}

// Get all songs for this ensemble
const songs = await db
  .select()
  .from(Song)
  .where(eq(Song.ensembleId, id!))
  .all();

// Get all parts for this ensemble
const parts = await db
  .select()
  .from(Part)
  .where(eq(Part.ensembleId, id!))
  .all();

// Get all seasons for this ensemble
const seasons = await db
  .select()
  .from(Season)
  .where(eq(Season.ensembleId, id!))
  .all();

// Get song parts associations
const songPartsData = await db
  .select()
  .from(SongPart)
  .all();

// Get season songs associations
const seasonSongsData = await db
  .select()
  .from(SeasonSong)
  .all();

// Create maps for easy lookup
const songPartsMap = new Map();
for (const sp of songPartsData) {
  if (!songPartsMap.has(sp.songId)) {
    songPartsMap.set(sp.songId, []);
  }
  songPartsMap.get(sp.songId).push(sp.partId);
}

const songSeasonsMap = new Map();
for (const ss of seasonSongsData) {
  if (!songSeasonsMap.has(ss.songId)) {
    songSeasonsMap.set(ss.songId, []);
  }
  songSeasonsMap.get(ss.songId).push(ss.seasonId);
}

// Handle form submissions
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'add') {
    const name = formData.get('name') as string;
    const composer = formData.get('composer') as string;
    const arranger = formData.get('arranger') as string;
    const runTimeMinutes = parseInt(formData.get('runTimeMinutes') as string) || 0;
    const runTimeSeconds = parseInt(formData.get('runTimeSeconds') as string) || 0;
    const runTime = (runTimeMinutes * 60) + runTimeSeconds;
    const selectedParts = formData.getAll('parts');
    const selectedSeasons = formData.getAll('seasons');

    if (name) {
      const songId = crypto.randomUUID();
      
      await db.insert(Song).values({
        id: songId,
        ensembleId: id!,
        name: name.trim(),
        composer: composer.trim() || null,
        arranger: arranger.trim() || null,
        runTime: runTime > 0 ? runTime : null,
      });

      // Add part associations
      for (const partId of selectedParts) {
        await db.insert(SongPart).values({
          id: crypto.randomUUID(),
          songId,
          partId: partId as string,
        });
      }

      // Add season associations
      for (const seasonId of selectedSeasons) {
        await db.insert(SeasonSong).values({
          id: crypto.randomUUID(),
          songId,
          seasonId: seasonId as string,
        });
      }
    }
  } else if (action === 'edit') {
    const songId = formData.get('songId') as string;
    const name = formData.get('name') as string;
    const composer = formData.get('composer') as string;
    const arranger = formData.get('arranger') as string;
    const runTimeMinutes = parseInt(formData.get('runTimeMinutes') as string) || 0;
    const runTimeSeconds = parseInt(formData.get('runTimeSeconds') as string) || 0;
    const runTime = (runTimeMinutes * 60) + runTimeSeconds;
    const selectedParts = formData.getAll('parts');
    const selectedSeasons = formData.getAll('seasons');

    if (songId && name) {
      await db
        .update(Song)
        .set({ 
          name: name.trim(), 
          composer: composer.trim() || null,
          arranger: arranger.trim() || null,
          runTime: runTime > 0 ? runTime : null,
        })
        .where(eq(Song.id, songId));

      // Delete existing associations
      await db.delete(SongPart).where(eq(SongPart.songId, songId));
      await db.delete(SeasonSong).where(eq(SeasonSong.songId, songId));

      // Add new part associations
      for (const partId of selectedParts) {
        await db.insert(SongPart).values({
          id: crypto.randomUUID(),
          songId,
          partId: partId as string,
        });
      }

      // Add new season associations
      for (const seasonId of selectedSeasons) {
        await db.insert(SeasonSong).values({
          id: crypto.randomUUID(),
          songId,
          seasonId: seasonId as string,
        });
      }
    }
  } else if (action === 'delete') {
    const songId = formData.get('songId') as string;

    if (songId) {
      // Delete associated records
      await db.delete(SongPart).where(eq(SongPart.songId, songId));
      await db.delete(SeasonSong).where(eq(SeasonSong.songId, songId));
      await db.delete(Song).where(eq(Song.id, songId));
    }
  }

  return Astro.redirect(`/ensembles/${id}/songs`);
}

// Helper function to format runtime
function formatRuntime(seconds: number | null): string {
  if (!seconds) return '-';
  const mins = Math.floor(seconds / 60);
  const secs = seconds % 60;
  return `${mins}:${secs.toString().padStart(2, '0')}`;
}
---

<Layout title={`Manage Songs - ${ensemble.name}`}>
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumbs">
        <ul>
          <li><a href="/ensembles">Ensembles</a></li>
          <li><a href={`/ensembles/${id}`}>{ensemble.name}</a></li>
          <li class="is-active"><a href="#" aria-current="page">Manage Songs</a></li>
        </ul>
      </nav>

      <h1 class="title">Manage Songs</h1>
      <p class="subtitle">Configure repertoire for {ensemble.name}</p>

      <div class="columns">
        <div class="column is-two-thirds">
          <div class="box">
            <h2 class="title is-4">Current Songs</h2>
            {songs.length === 0 ? (
              <div class="notification is-info is-light">
                <p>No songs added yet. Add your first song below.</p>
              </div>
            ) : (
              <table class="table is-fullwidth is-hoverable">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Composer</th>
                    <th>Arranger</th>
                    <th>Runtime</th>
                    <th>Parts</th>
                    <th>Seasons</th>
                    <th style="width: 180px;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {songs.map((song) => {
                    const songParts = songPartsMap.get(song.id) || [];
                    const songSeasons = songSeasonsMap.get(song.id) || [];
                    return (
                      <tr>
                        <td><strong>{song.name}</strong></td>
                        <td>{song.composer || '-'}</td>
                        <td>{song.arranger || '-'}</td>
                        <td>{formatRuntime(song.runTime)}</td>
                        <td>
                          {songParts.length > 0 ? (
                            <div class="tags are-small">
                              {songParts.map((partId: string) => {
                                const part = parts.find(p => p.id === partId);
                                return part ? <span class="tag is-info">{part.name}</span> : null;
                              })}
                            </div>
                          ) : '-'}
                        </td>
                        <td>
                          {songSeasons.length > 0 ? (
                            <div class="tags are-small">
                              {songSeasons.map((seasonId: string) => {
                                const season = seasons.find(s => s.id === seasonId);
                                return season ? <span class="tag is-primary">{season.name}</span> : null;
                              })}
                            </div>
                          ) : '-'}
                        </td>
                        <td>
                          <div class="buttons are-small">
                            <button class="button is-info edit-btn" data-song-id={song.id}>
                              <span class="icon is-small">
                                <i class="fas fa-pencil"></i>
                              </span>
                            </button>
                            <button class="button is-danger delete-btn" data-song-id={song.id}>
                              <span class="icon is-small">
                                <i class="fas fa-trash"></i>
                              </span>
                            </button>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            )}
          </div>

          <a href={`/ensembles/${id}`} class="button">
            <span class="icon">
              <i class="fas fa-arrow-left"></i>
            </span>
            <span>Back to Ensemble</span>
          </a>
        </div>

        <div class="column">
          <div class="box">
            <h2 class="title is-5">Add New Song</h2>
            <form method="POST">
              <input type="hidden" name="action" value="add" />
              
              <div class="field">
                <label class="label" for="name">Song Name *</label>
                <div class="control">
                  <input
                    class="input"
                    type="text"
                    id="name"
                    name="name"
                    placeholder="Song name"
                    required
                  />
                </div>
              </div>

              <div class="field">
                <label class="label" for="composer">Composer</label>
                <div class="control">
                  <input
                    class="input"
                    type="text"
                    id="composer"
                    name="composer"
                    placeholder="Composer name"
                  />
                </div>
              </div>

              <div class="field">
                <label class="label" for="arranger">Arranger</label>
                <div class="control">
                  <input
                    class="input"
                    type="text"
                    id="arranger"
                    name="arranger"
                    placeholder="Arranger name"
                  />
                </div>
              </div>

              <div class="field">
                <label class="label">Runtime</label>
                <div class="field has-addons">
                  <div class="control">
                    <input
                      class="input"
                      type="number"
                      name="runTimeMinutes"
                      placeholder="Minutes"
                      min="0"
                      style="width: 100px;"
                    />
                  </div>
                  <div class="control">
                    <span class="button is-static">:</span>
                  </div>
                  <div class="control">
                    <input
                      class="input"
                      type="number"
                      name="runTimeSeconds"
                      placeholder="Seconds"
                      min="0"
                      max="59"
                      style="width: 100px;"
                    />
                  </div>
                </div>
                <p class="help">Leave blank if unknown</p>
              </div>

              {parts.length > 0 && (
                <div class="field">
                  <label class="label">Parts</label>
                  <div class="control">
                    {parts.map((part) => (
                      <label class="checkbox is-block mb-2">
                        <input type="checkbox" name="parts" value={part.id} />
                        {' '}{part.name}
                      </label>
                    ))}
                  </div>
                  <p class="help">Select which parts sing this song</p>
                </div>
              )}

              {seasons.length > 0 && (
                <div class="field">
                  <label class="label">Seasons</label>
                  <div class="control">
                    {seasons.map((season) => (
                      <label class="checkbox is-block mb-2">
                        <input type="checkbox" name="seasons" value={season.id} />
                        {' '}{season.name}
                      </label>
                    ))}
                  </div>
                  <p class="help">Assign to seasons (optional)</p>
                </div>
              )}

              <div class="field">
                <div class="control">
                  <button type="submit" class="button is-primary is-fullwidth">
                    <span class="icon">
                      <i class="fas fa-plus"></i>
                    </span>
                    <span>Add Song</span>
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Edit Modal -->
  <div id="editModal" class="modal">
    <div class="modal-background"></div>
    <div class="modal-card">
      <header class="modal-card-head">
        <p class="modal-card-title">Edit Song</p>
        <button class="delete" aria-label="close"></button>
      </header>
      <section class="modal-card-body">
        <form id="editForm" method="POST">
          <input type="hidden" name="action" value="edit" />
          <input type="hidden" name="songId" id="editSongId" />
          
          <div class="field">
            <label class="label" for="editName">Song Name *</label>
            <div class="control">
              <input
                class="input"
                type="text"
                id="editName"
                name="name"
                required
              />
            </div>
          </div>

          <div class="field">
            <label class="label" for="editComposer">Composer</label>
            <div class="control">
              <input
                class="input"
                type="text"
                id="editComposer"
                name="composer"
              />
            </div>
          </div>

          <div class="field">
            <label class="label" for="editArranger">Arranger</label>
            <div class="control">
              <input
                class="input"
                type="text"
                id="editArranger"
                name="arranger"
              />
            </div>
          </div>

          <div class="field">
            <label class="label">Runtime</label>
            <div class="field has-addons">
              <div class="control">
                <input
                  class="input"
                  type="number"
                  name="runTimeMinutes"
                  id="editRunTimeMinutes"
                  placeholder="Minutes"
                  min="0"
                  style="width: 100px;"
                />
              </div>
              <div class="control">
                <span class="button is-static">:</span>
              </div>
              <div class="control">
                <input
                  class="input"
                  type="number"
                  name="runTimeSeconds"
                  id="editRunTimeSeconds"
                  placeholder="Seconds"
                  min="0"
                  max="59"
                  style="width: 100px;"
                />
              </div>
            </div>
          </div>

          {parts.length > 0 && (
            <div class="field">
              <label class="label">Parts</label>
              <div class="control" id="editParts">
                {parts.map((part) => (
                  <label class="checkbox is-block mb-2">
                    <input type="checkbox" name="parts" value={part.id} />
                    {' '}{part.name}
                  </label>
                ))}
              </div>
            </div>
          )}

          {seasons.length > 0 && (
            <div class="field">
              <label class="label">Seasons</label>
              <div class="control" id="editSeasons">
                {seasons.map((season) => (
                  <label class="checkbox is-block mb-2">
                    <input type="checkbox" name="seasons" value={season.id} />
                    {' '}{season.name}
                  </label>
                ))}
              </div>
            </div>
          )}
        </form>
      </section>
      <footer class="modal-card-foot">
        <button type="submit" form="editForm" class="button is-primary">Save Changes</button>
        <button class="button cancel-btn">Cancel</button>
      </footer>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteModal" class="modal">
    <div class="modal-background"></div>
    <div class="modal-card">
      <header class="modal-card-head">
        <p class="modal-card-title">Delete Song</p>
        <button class="delete" aria-label="close"></button>
      </header>
      <section class="modal-card-body">
        <p>Are you sure you want to delete this song? This action cannot be undone.</p>
        <form id="deleteForm" method="POST">
          <input type="hidden" name="action" value="delete" />
          <input type="hidden" name="songId" id="deleteSongId" />
        </form>
      </section>
      <footer class="modal-card-foot">
        <button type="submit" form="deleteForm" class="button is-danger">Delete</button>
        <button class="button cancel-btn">Cancel</button>
      </footer>
    </div>
  </div>

  <script 
    is:inline
    data-songs={JSON.stringify(songs)}
    data-song-parts={JSON.stringify(Array.from(songPartsMap.entries()))}
    data-song-seasons={JSON.stringify(Array.from(songSeasonsMap.entries()))}
  ></script>

  <script is:inline>
    // Get data from previous script tag
    const dataScript = document.currentScript.previousElementSibling;
    const songsData = dataScript?.dataset.songs ? JSON.parse(dataScript.dataset.songs) : [];
    const songPartsData = dataScript?.dataset.songParts ? JSON.parse(dataScript.dataset.songParts) : [];
    const songSeasonsData = dataScript?.dataset.songSeasons ? JSON.parse(dataScript.dataset.songSeasons) : [];
    
    // Reconstruct maps from serialized data
    const songPartsMapJS = new Map(songPartsData);
    const songSeasonsMapJS = new Map(songSeasonsData);

    // Edit functionality
    const editModal = document.getElementById('editModal');
    const editBtns = document.querySelectorAll('.edit-btn');
    
    editBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const songId = btn.getAttribute('data-song-id');
        const song = songsData.find(s => s.id === songId);
        
        if (song) {
          document.getElementById('editSongId').value = song.id;
          document.getElementById('editName').value = song.name;
          document.getElementById('editComposer').value = song.composer || '';
          document.getElementById('editArranger').value = song.arranger || '';
          
          // Set runtime
          if (song.runTime) {
            const mins = Math.floor(song.runTime / 60);
            const secs = song.runTime % 60;
            document.getElementById('editRunTimeMinutes').value = mins;
            document.getElementById('editRunTimeSeconds').value = secs;
          } else {
            document.getElementById('editRunTimeMinutes').value = '';
            document.getElementById('editRunTimeSeconds').value = '';
          }
          
          // Set parts
          const songParts = songPartsMapJS.get(songId) || [];
          document.querySelectorAll('#editParts input[type="checkbox"]').forEach(cb => {
            cb.checked = songParts.includes(cb.value);
          });
          
          // Set seasons
          const songSeasons = songSeasonsMapJS.get(songId) || [];
          document.querySelectorAll('#editSeasons input[type="checkbox"]').forEach(cb => {
            cb.checked = songSeasons.includes(cb.value);
          });
          
          editModal.classList.add('is-active');
        }
      });
    });

    // Delete functionality
    const deleteModal = document.getElementById('deleteModal');
    const deleteBtns = document.querySelectorAll('.delete-btn');
    
    deleteBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const songId = btn.getAttribute('data-song-id');
        document.getElementById('deleteSongId').value = songId;
        deleteModal.classList.add('is-active');
      });
    });

    // Modal close functionality
    function closeModal(modal) {
      modal.classList.remove('is-active');
    }

    document.querySelectorAll('.modal .delete, .modal .cancel-btn, .modal-background').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const modal = el.closest('.modal');
        closeModal(modal);
      });
    });
  </script>
</Layout>
