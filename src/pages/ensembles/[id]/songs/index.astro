---
import EnsemblePageLayout from '../../../../layouts/EnsemblePageLayout.astro';
import Table from '../../../../components/elements/Table.astro';
import Modal from '../../../../components/Modal.astro';
import Button from '../../../../components/elements/Button.astro';
import Icon from '../../../../components/elements/Icon.astro';
import TextInput from '../../../../components/elements/TextInput.astro';
import Notification from '../../../../components/elements/Notification.astro';
import Tag from '../../../../components/elements/Tag.astro';
import { canManageEnsemble } from '../../../../lib/permissions';
import {
  getSongsPageData,
  getMembership,
  buildSongPartsMap,
  buildSongSeasonsMap,
  buildSongFilesMap,
  formatRuntime,
} from '../../../../lib/songs';
import { getEnsembleUrlId } from '../../../../lib/slug';
import { actions } from 'astro:actions';

const user = Astro.locals.user!;
const { id } = Astro.params;

const { ensemble, songs, parts, seasons, songPartsData, seasonSongsData, songFilesData } =
  await getSongsPageData(id!);

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

const canonicalId = getEnsembleUrlId(ensemble);
if (id !== canonicalId) {
  return Astro.redirect(Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`), 301);
}

const membership = await getMembership(ensemble.id, user.id);
const isAdmin = canManageEnsemble(user, membership);

const addResult = Astro.getActionResult(actions.songs.add);
const editResult = Astro.getActionResult(actions.songs.edit);
const deleteResult = Astro.getActionResult(actions.songs.delete);
const addFileResult = Astro.getActionResult(actions.songs.addFile);
const deleteFileResult = Astro.getActionResult(actions.songs.deleteFile);

if (
  (addResult && !addResult.error) ||
  (editResult && !editResult.error) ||
  (deleteResult && !deleteResult.error) ||
  (addFileResult && !addFileResult.error) ||
  (deleteFileResult && !deleteFileResult.error)
) {
  return Astro.redirect(`/ensembles/${canonicalId}/songs`);
}

const addError = addResult?.error?.message ?? (addResult?.error ? 'Failed to add song.' : null);
const editError = editResult?.error?.message ?? (editResult?.error ? 'Failed to update song.' : null);
const deleteError = deleteResult?.error?.message ?? (deleteResult?.error ? 'Failed to delete song.' : null);

const ensembleSongIds = new Set(songs.map((s) => s.id));
const songPartsMap = buildSongPartsMap(songPartsData);
const songSeasonsMap = buildSongSeasonsMap(seasonSongsData);
const songFilesMap = buildSongFilesMap(ensembleSongIds, songFilesData);
---

<EnsemblePageLayout
  title={`Songs - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Songs"
  pageSubtitle={`Repertoire for ${ensemble.name}`}
  isAdmin={isAdmin}
>
  {isAdmin && (
    <Button slot="action" color="primary" id="add-song-btn">
      <Icon icon="fa-plus" />
      <span>Add Song</span>
    </Button>
  )}

  {songs.length === 0 ? (
    <Notification color="info" light>
      No songs added yet. Click "Add Song" to get started.
    </Notification>
  ) : (
    <Table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Composer</th>
          <th>Arranger</th>
          <th>Runtime</th>
          <th>Parts</th>
          <th>Seasons</th>
          <th style={isAdmin ? "width: 130px;" : "width: 50px;"}>Files</th>
        </tr>
      </thead>
      <tbody>
        {songs.map((song) => {
          const songParts = songPartsMap.get(song.id) || [];
          const songSeasons = songSeasonsMap.get(song.id) || [];
          const songFiles = songFilesMap.get(song.id) || [];
          return (
            <tr>
              <td>
                <a href={`/ensembles/${canonicalId}/songs/${song.id}`} class="has-text-weight-bold">
                  {song.name}
                </a>
              </td>
              <td>{song.composer || '-'}</td>
              <td>{song.arranger || '-'}</td>
              <td>{formatRuntime(song.runTime)}</td>
              <td>
                {songParts.length > 0 ? (
                  <div class="tags are-small">
                    {songParts.map((partId: string) => {
                      const part = parts.find((p) => p.id === partId);
                      return part ? <Tag color="info">{part.name}</Tag> : null;
                    })}
                  </div>
                ) : '-'}
              </td>
              <td>
                {songSeasons.length > 0 ? (
                  <div class="tags are-small">
                    {songSeasons.map((seasonId: string) => {
                      const season = seasons.find((s) => s.id === seasonId);
                      return season ? <Tag color="primary">{season.name}</Tag> : null;
                    })}
                  </div>
                ) : '-'}
              </td>
              <td>
                <div class="buttons are-small">
                  <Button
                    class="is-linkspan files-btn"
                    data-song-id={song.id}
                    data-song-name={song.name}
                  >
                    <Icon icon="fa-folder-open" size="small" />
                    {songFiles.length > 0 && <span>{songFiles.length}</span>}
                  </Button>
                  {isAdmin && (
                    <>
                      <Button color="info" class="edit-btn" data-song-id={song.id}>
                        <Icon icon="fa-pencil" size="small" />
                      </Button>
                      <Button color="danger" class="delete-btn" data-song-id={song.id}>
                        <Icon icon="fa-trash" size="small" />
                      </Button>
                    </>
                  )}
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </Table>
  )}

  <Fragment slot="modals">
<!-- Add Song Modal -->
<Modal id="addModal" title="Add Song">
  {addError && (
    <Notification color="danger" light dismissible class="mb-4">
      {addError}
    </Notification>
  )}
  <form id="addForm" method="POST" action={actions.songs.add}>
    <input type="hidden" name="ensembleId" value={ensemble.id} />

    <TextInput name="name" label="Song Name *" placeholder="Song name" required />
    <TextInput name="composer" label="Composer" placeholder="Composer name" />
    <TextInput name="arranger" label="Arranger" placeholder="Arranger name" />

    <div class="field">
      <label class="label">Runtime</label>
      <div class="field has-addons">
        <div class="control">
          <TextInput name="runTimeMinutes" type="number" placeholder="Min" min="0" style="width: 80px;" standalone />
        </div>
        <div class="control">
          <span class="button is-static">:</span>
        </div>
        <div class="control">
          <TextInput name="runTimeSeconds" type="number" placeholder="Sec" min="0" max="59" style="width: 80px;" standalone />
        </div>
      </div>
      <p class="help">Leave blank if unknown</p>
    </div>

    {parts.length > 0 && (
      <div class="field">
        <label class="label">Parts</label>
        <div class="control">
          {parts.map((part) => (
            <label class="checkbox is-block mb-2">
              <input type="checkbox" name="parts" value={part.id} />
              {' '}{part.name}
            </label>
          ))}
        </div>
        <p class="help">Select which parts sing this song</p>
      </div>
    )}

    {seasons.length > 0 && (
      <div class="field">
        <label class="label">Seasons</label>
        <div class="control">
          {seasons.map((season) => (
            <label class="checkbox is-block mb-2">
              <input type="checkbox" name="seasons" value={season.id} />
              {' '}{season.name}
            </label>
          ))}
        </div>
        <p class="help">Assign to seasons (optional)</p>
      </div>
    )}
  </form>

  <div slot="footer">
    <Button type="submit" form="addForm" color="primary">Add Song</Button>
    <Button type="button" data-modal-close>Cancel</Button>
  </div>
</Modal>

<!-- Files Modal -->
<Modal id="filesModal" title="Files">
  <p class="modal-card-title-song mb-3">
    Song: <span id="filesModalSongName" class="has-text-weight-bold"></span>
  </p>

  <div id="filesModalList"></div>

  {isAdmin && (
    <>
      <hr />

      <h3 class="title is-6">Add File</h3>
      <form id="addFileForm" method="POST" action={actions.songs.addFile}>
        <input type="hidden" name="ensembleId" value={ensemble.id} />
        <input type="hidden" name="songId" id="addFileSongId" />

        <TextInput name="fileName" id="fileName" label="Display Name *" placeholder="e.g. Soprano Sheet Music" size="small" required />
        <TextInput name="fileUrl" id="fileUrl" label="File URL *" type="url" placeholder="https://..." size="small" required help="Paste the download URL for this file" />

        <div class="field">
          <label class="label is-small" for="category">Category</label>
          <div class="control">
            <div class="select is-small is-fullwidth">
              <select id="category" name="category">
                <option value="sheet_music">Sheet Music</option>
                <option value="rehearsal_track">Rehearsal Track</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
        </div>

        <div class="field">
          <div class="control">
            <Button type="submit" color="primary" size="small">
              <Icon icon="fa-plus" size="small" />
              <span>Add File</span>
            </Button>
          </div>
        </div>
      </form>
    </>
  )}

  <div slot="footer">
    <Button type="button" data-modal-close>Close</Button>
  </div>
</Modal>

<!-- Edit Modal -->
<Modal id="editModal" title="Edit Song">
  {editError && (
    <Notification color="danger" light dismissible class="mb-4">
      {editError}
    </Notification>
  )}
  <form id="editForm" method="POST" action={actions.songs.edit}>
    <input type="hidden" name="ensembleId" value={ensemble.id} />
    <input type="hidden" name="songId" id="editSongId" />

    <TextInput name="name" id="editName" label="Song Name *" required />
    <TextInput name="composer" id="editComposer" label="Composer" />
    <TextInput name="arranger" id="editArranger" label="Arranger" />

    <div class="field">
      <label class="label">Runtime</label>
      <div class="field has-addons">
        <div class="control">
          <TextInput name="runTimeMinutes" id="editRunTimeMinutes" type="number" placeholder="Min" min="0" style="width: 80px;" standalone />
        </div>
        <div class="control">
          <span class="button is-static">:</span>
        </div>
        <div class="control">
          <TextInput name="runTimeSeconds" id="editRunTimeSeconds" type="number" placeholder="Sec" min="0" max="59" style="width: 80px;" standalone />
        </div>
      </div>
    </div>

    {parts.length > 0 && (
      <div class="field">
        <label class="label">Parts</label>
        <div class="control" id="editParts">
          {parts.map((part) => (
            <label class="checkbox is-block mb-2">
              <input type="checkbox" name="parts" value={part.id} />
              {' '}{part.name}
            </label>
          ))}
        </div>
      </div>
    )}

    {seasons.length > 0 && (
      <div class="field">
        <label class="label">Seasons</label>
        <div class="control" id="editSeasons">
          {seasons.map((season) => (
            <label class="checkbox is-block mb-2">
              <input type="checkbox" name="seasons" value={season.id} />
              {' '}{season.name}
            </label>
          ))}
        </div>
      </div>
    )}
  </form>

  <div slot="footer">
    <Button type="submit" form="editForm" color="primary">Save Changes</Button>
    <Button type="button" data-modal-close>Cancel</Button>
  </div>
</Modal>

<!-- Delete Confirmation Modal -->
<Modal id="deleteModal" title="Delete Song">
  {deleteError && (
    <Notification color="danger" light dismissible class="mb-4">
      {deleteError}
    </Notification>
  )}
  <p>Are you sure you want to delete this song? This action cannot be undone.</p>
  <form id="deleteForm" method="POST" action={actions.songs.delete}>
    <input type="hidden" name="ensembleId" value={ensemble.id} />
    <input type="hidden" name="songId" id="deleteSongId" />
  </form>

  <div slot="footer">
    <Button type="submit" form="deleteForm" color="danger">Delete</Button>
    <Button type="button" data-modal-close>Cancel</Button>
  </div>
</Modal>

<script
  is:inline
  id="songs-data"
  data-songs={JSON.stringify(songs)}
  data-song-parts={JSON.stringify(Array.from(songPartsMap.entries()))}
  data-song-seasons={JSON.stringify(Array.from(songSeasonsMap.entries()))}
  data-song-files={JSON.stringify(Array.from(songFilesMap.entries()))}
  data-is-admin={isAdmin ? 'true' : 'false'}
  data-ensemble-id={ensemble.id}
  data-open-modal={addError ? 'addModal' : editError ? 'editModal' : deleteError ? 'deleteModal' : ''}
></script>

<script is:inline>
  function initSongsPage() {
    const dataScript = document.getElementById('songs-data');
    if (!dataScript) return;
    const ensembleId = dataScript.dataset.ensembleId || '';
    const songsData = JSON.parse(dataScript.dataset.songs || '[]');
    const songPartsMapJS = new Map(JSON.parse(dataScript.dataset.songParts || '[]'));
    const songSeasonsMapJS = new Map(JSON.parse(dataScript.dataset.songSeasons || '[]'));
    const songFilesMapJS = new Map(JSON.parse(dataScript.dataset.songFiles || '[]'));
    const isAdmin = dataScript.dataset.isAdmin === 'true';

    function categoryLabel(cat) {
      if (cat === 'sheet_music') return 'Sheet Music';
      if (cat === 'rehearsal_track') return 'Rehearsal Track';
      return 'Other';
    }

    function categoryTagClass(cat) {
      if (cat === 'sheet_music') return 'is-success';
      if (cat === 'rehearsal_track') return 'is-warning';
      return 'is-light';
    }

    // ── Auto-open modal on error (after form submission failure) ──────────────
    const openModal = dataScript.dataset.openModal;
    if (openModal) {
      document.getElementById(openModal)?.classList.add('is-active');
    }

    // ── Add modal ─────────────────────────────────────────────────────────────
    document.getElementById('add-song-btn')?.addEventListener('click', () => {
      document.getElementById('addModal')?.classList.add('is-active');
    });

    // ── Files modal ──────────────────────────────────────────────────────────

    const filesModal = document.getElementById('filesModal');

    function renderFilesList(songId) {
      const files = songFilesMapJS.get(songId) || [];
      const container = document.getElementById('filesModalList');
      if (files.length === 0) {
        container.innerHTML = '<p class="has-text-grey">No files yet.</p>';
        return;
      }
      container.innerHTML = files.map(f => `
        <div class="is-flex is-align-items-center mb-2" style="gap: 0.5rem;">
          <span class="tag ${categoryTagClass(f.category)} is-small" style="flex-shrink:0;">${categoryLabel(f.category)}</span>
          <a href="/files/${f.id}" class="has-text-weight-medium"
             style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${f.name}</a>
          ${isAdmin ? `
          <form method="POST" action="/_actions/songs.deleteFile" style="flex-shrink:0;" onsubmit="return confirm('Delete this file?');">
            <input type="hidden" name="ensembleId" value="${ensembleId}" />
            <input type="hidden" name="fileId" value="${f.id}" />
            <button type="submit" class="button is-danger is-small">
              <span class="icon is-small"><i class="fas fa-trash"></i></span>
            </button>
          </form>
          ` : ''}
        </div>
      `).join('');
    }

    document.querySelectorAll('.files-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const songId = btn.getAttribute('data-song-id');
        const songName = btn.getAttribute('data-song-name');
        document.getElementById('filesModalSongName').textContent = songName;
        document.getElementById('addFileSongId').value = songId;
        document.getElementById('fileName').value = '';
        document.getElementById('fileUrl').value = '';
        document.getElementById('category').value = 'sheet_music';
        renderFilesList(songId);
        filesModal.classList.add('is-active');
      });
    });

    // ── Edit modal ───────────────────────────────────────────────────────────

    const editModal = document.getElementById('editModal');

    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const songId = btn.getAttribute('data-song-id');
        const song = songsData.find(s => s.id === songId);
        if (!song) return;

        document.getElementById('editSongId').value = song.id;
        document.getElementById('editName').value = song.name;
        document.getElementById('editComposer').value = song.composer || '';
        document.getElementById('editArranger').value = song.arranger || '';

        if (song.runTime) {
          document.getElementById('editRunTimeMinutes').value = Math.floor(song.runTime / 60);
          document.getElementById('editRunTimeSeconds').value = song.runTime % 60;
        } else {
          document.getElementById('editRunTimeMinutes').value = '';
          document.getElementById('editRunTimeSeconds').value = '';
        }

        const songParts = songPartsMapJS.get(songId) || [];
        document.querySelectorAll('#editParts input[type="checkbox"]').forEach(cb => {
          cb.checked = songParts.includes(cb.value);
        });

        const songSeasons = songSeasonsMapJS.get(songId) || [];
        document.querySelectorAll('#editSeasons input[type="checkbox"]').forEach(cb => {
          cb.checked = songSeasons.includes(cb.value);
        });

        editModal.classList.add('is-active');
      });
    });

    // ── Delete modal ─────────────────────────────────────────────────────────

    const deleteModal = document.getElementById('deleteModal');

    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('deleteSongId').value = btn.getAttribute('data-song-id');
        deleteModal.classList.add('is-active');
      });
    });
  }

  document.addEventListener('astro:page-load', initSongsPage);
</script>
  </Fragment>
</EnsemblePageLayout>
