---
import EnsemblePageLayout from '../../../../layouts/EnsemblePageLayout.astro';
import {
  getSongDetailData,
  getMembership,
  formatRuntime,
  addSongFile,
  deleteSongFile,
} from '../../../../lib/songs';
import { canManageEnsemble } from '../../../../lib/permissions';

const user = Astro.locals.user!;
const { id, songId } = Astro.params;

const { ensemble, song, parts, seasons, songPartsData, seasonSongsData, songFiles } =
  await getSongDetailData(id!, songId!);

if (!ensemble) return new Response('Ensemble not found', { status: 404 });
if (!song || song.ensembleId !== id) return new Response('Song not found', { status: 404 });

const membership = await getMembership(id!, user.id);
const isAdmin = canManageEnsemble(user, membership);

let fileError: string | undefined;

if (Astro.request.method === 'POST') {
  if (!isAdmin) return new Response('Unauthorized', { status: 403 });

  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'add_file') {
    const result = await addSongFile(formData, user.id, id);
    if (result.error) {
      fileError = result.error;
    } else {
      return Astro.redirect(`/ensembles/${id}/songs/${songId}`);
    }
  } else if (action === 'delete_file') {
    await deleteSongFile(formData);
    return Astro.redirect(`/ensembles/${id}/songs/${songId}`);
  }
}

const songParts = songPartsData.map((sp) => parts.find((p) => p.id === sp.partId)).filter(Boolean);
const songSeasons = seasonSongsData.map((ss) => seasons.find((s) => s.id === ss.seasonId)).filter(Boolean);

function categoryLabel(cat: string) {
  if (cat === 'sheet_music') return 'Sheet Music';
  if (cat === 'rehearsal_track') return 'Rehearsal Track';
  if (cat === 'link') return 'Link';
  return 'Other';
}

function categoryTagClass(cat: string) {
  if (cat === 'sheet_music') return 'is-success';
  if (cat === 'rehearsal_track') return 'is-warning';
  if (cat === 'link') return 'is-info';
  return 'is-light';
}

function getYouTubeId(url: string): string | null {
  try {
    const u = new URL(url);
    if (u.hostname === 'youtu.be') return u.pathname.slice(1).split('?')[0];
    if (u.hostname.includes('youtube.com')) return u.searchParams.get('v');
  } catch {}
  return null;
}
---

<EnsemblePageLayout
  title={`${song.name} - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={id!}
  pageTitle={song.name}
  extraBreadcrumbs={[['Songs', `/ensembles/${id}/songs`]]}
  isAdmin={isAdmin}
>
  {isAdmin && (
    <a slot="action" href={`/ensembles/${id}/songs`} class="button">
      <span class="icon"><i class="fas fa-arrow-left"></i></span>
      <span>Back to Songs</span>
    </a>
  )}

  <!-- Song details -->
  <div class="box mb-5">
    <div class="columns is-multiline">
      <div class="column is-half">
        <p class="heading">Composer</p>
        <p class="is-size-5">{song.composer || <span class="has-text-grey">—</span>}</p>
      </div>
      <div class="column is-half">
        <p class="heading">Arranger</p>
        <p class="is-size-5">{song.arranger || <span class="has-text-grey">—</span>}</p>
      </div>
      <div class="column is-half">
        <p class="heading">Runtime</p>
        <p class="is-size-5">{formatRuntime(song.runTime)}</p>
      </div>
      <div class="column is-half">
        <p class="heading">Added</p>
        <p class="is-size-5">{new Date(song.createdAt).toLocaleDateString()}</p>
      </div>
      {songParts.length > 0 && (
        <div class="column is-half">
          <p class="heading">Parts</p>
          <div class="tags">
            {songParts.map((part) => (
              <span class="tag is-info">{part!.name}</span>
            ))}
          </div>
        </div>
      )}
      {songSeasons.length > 0 && (
        <div class="column is-half">
          <p class="heading">Seasons</p>
          <div class="tags">
            {songSeasons.map((season) => (
              <span class="tag is-primary">{season!.name}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Resources section -->
  <h2 class="title is-4">
    <span class="icon-text">
      <span class="icon"><i class="fas fa-folder-open"></i></span>
      <span>Resources</span>
    </span>
  </h2>

  {songFiles.length === 0 ? (
    <div class="notification is-info is-light">No resources attached to this song yet.</div>
  ) : (
    <div class="box mb-5">
      {songFiles.map((file) => {
        const isLink = file.category === 'link';
        const isAudio = !isLink && file.url.match(/\.(mp3)$/i);
        const isPdf = !isLink && file.url.match(/\.(pdf)$/i);
        const youtubeId = isLink ? getYouTubeId(file.url) : null;
        return (
          <div class="mb-4">
            <div class="is-flex is-align-items-center" style="gap: 0.75rem;">
              <span class={`tag ${categoryTagClass(file.category)} is-normal`} style="flex-shrink:0; min-width: 7rem; justify-content: center;">
                {categoryLabel(file.category)}
              </span>
              {isLink ? (
                <a
                  href={file.url}
                  class="has-text-weight-medium"
                  style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {file.name}
                </a>
              ) : (
                <span
                  class="has-text-weight-medium"
                  style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                >
                  {file.name}
                </span>
              )}
              <span class="has-text-grey is-size-7" style="flex-shrink:0; white-space:nowrap;">
                {file.uploaderName} &middot; {new Date(file.uploadedAt).toLocaleDateString()}
              </span>
              {isLink ? (
                <a
                  href={file.url}
                  class="button is-small is-info is-light"
                  target="_blank"
                  rel="noopener noreferrer"
                  title="Open link"
                >
                  <span class="icon is-small"><i class="fas fa-external-link-alt"></i></span>
                </a>
              ) : (
                <a
                  href={`/files/${file.id}`}
                  class="button is-small"
                  title="Download"
                >
                  <span class="icon is-small"><i class="fas fa-download"></i></span>
                </a>
              )}
              {isAdmin && (
                <form method="POST" style="flex-shrink:0;" onsubmit="return confirm('Delete this resource?');">
                  <input type="hidden" name="action" value="delete_file" />
                  <input type="hidden" name="fileId" value={file.id} />
                  <button type="submit" class="button is-danger is-small">
                    <span class="icon is-small"><i class="fas fa-trash"></i></span>
                  </button>
                </form>
              )}
            </div>
            {isAudio && (
              <audio
                controls
                class="mt-2"
                style="width: 100%;"
                src={`/files/${file.id}?inline`}
              />
            )}
            {isPdf && (
              <details class="mt-2">
                <summary class="is-clickable has-text-grey is-size-7" style="list-style: none; display: flex; align-items: center; gap: 0.3rem; width: fit-content;">
                  <span class="pdf-arrow" style="display: inline-block; transition: transform 0.15s;">▶</span>
                  <span>Show PDF</span>
                </summary>
                <embed
                  src={`/files/${file.id}?inline`}
                  type="application/pdf"
                  class="mt-2"
                  style="width: 100%; height: 600px;"
                />
              </details>
            )}
            {youtubeId && (
              <details class="mt-2">
                <summary class="is-clickable has-text-grey is-size-7" style="list-style: none; display: flex; align-items: center; gap: 0.3rem; width: fit-content;">
                  <span class="pdf-arrow" style="display: inline-block; transition: transform 0.15s;">▶</span>
                  <span>Show Video</span>
                </summary>
                <div class="mt-2" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
                  <iframe
                    src={`https://www.youtube.com/embed/${youtubeId}`}
                    title={file.name}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                  />
                </div>
              </details>
            )}
          </div>
        );
      })}
    </div>
  )}

  {isAdmin && (
    <div class="box">
      <h3 class="title is-5">Upload Resource</h3>
      {fileError && (
        <div class="notification is-danger is-light mb-4">{fileError}</div>
      )}
      <form method="POST" enctype="multipart/form-data">
        <input type="hidden" name="action" value="add_file" />
        <input type="hidden" name="songId" value={songId} />

        <div class="field">
          <label class="label">Type *</label>
          <div class="control">
            <div class="buttons has-addons">
              <label class="button is-selected is-success" id="btn-sheet_music">
                <input type="radio" name="category" value="sheet_music" checked hidden /> Sheet Music
              </label>
              <label class="button" id="btn-rehearsal_track">
                <input type="radio" name="category" value="rehearsal_track" hidden /> Rehearsal Track
              </label>
              <label class="button" id="btn-link">
                <input type="radio" name="category" value="link" hidden /> Link
              </label>
            </div>
          </div>
        </div>

        <div class="columns is-multiline mt-2">
          <div class="column is-full" id="file-input-field">
            <div class="field">
              <label class="label" for="file">File *</label>
              <div class="control">
                <input
                  class="input"
                  type="file"
                  id="file"
                  name="file"
                  accept=".pdf,.mp3,application/pdf,audio/mpeg"
                />
              </div>
              <p class="help">PDF or MP3, max 50 MB</p>
            </div>
          </div>
          <div class="column is-full" id="url-input-field" style="display:none;">
            <div class="field">
              <label class="label" for="fileUrl">URL *</label>
              <div class="control">
                <input class="input" type="url" id="fileUrl" name="fileUrl" placeholder="https://www.youtube.com/watch?v=..." />
              </div>
            </div>
          </div>
          <div class="column">
            <div class="field">
              <label class="label" for="fileName">Display Name *</label>
              <div class="control">
                <input class="input" type="text" id="fileName" name="fileName" placeholder="e.g. Soprano Sheet Music" required />
              </div>
            </div>
          </div>
          <div class="column is-narrow">
            <div class="field">
              <label class="label">&nbsp;</label>
              <div class="control">
                <button type="submit" class="button is-primary">
                  <span class="icon"><i class="fas fa-upload"></i></span>
                  <span>Upload</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </form>
    </div>
  )}

  <script>
    const fileInput = document.getElementById('file') as HTMLInputElement | null;
    const nameInput = document.getElementById('fileName') as HTMLInputElement | null;
    const fileField = document.getElementById('file-input-field') as HTMLElement | null;
    const urlField = document.getElementById('url-input-field') as HTMLElement | null;
    const radios = document.querySelectorAll<HTMLInputElement>('input[name="category"]');

    const categoryColors: Record<string, string> = {
      sheet_music: 'is-success',
      rehearsal_track: 'is-warning',
      link: 'is-info',
    };

    function onCategoryChange() {
      const selected = (document.querySelector('input[name="category"]:checked') as HTMLInputElement | null)?.value;
      const isLink = selected === 'link';
      if (fileField) fileField.style.display = isLink ? 'none' : '';
      if (urlField) urlField.style.display = isLink ? '' : 'none';
      if (fileInput) fileInput.required = !isLink;
      const urlInput = document.getElementById('fileUrl') as HTMLInputElement | null;
      if (urlInput) urlInput.required = isLink;

      radios.forEach((r) => {
        const btn = document.getElementById(`btn-${r.value}`);
        if (!btn) return;
        const color = categoryColors[r.value] ?? 'is-light';
        btn.classList.remove('is-selected', 'is-success', 'is-warning', 'is-info', 'is-light');
        if (r.value === selected) btn.classList.add('is-selected', color);
      });
    }

    radios.forEach((r) => r.addEventListener('change', onCategoryChange));
    onCategoryChange();

    if (fileInput && nameInput) {
      fileInput.addEventListener('change', () => {
        const file = fileInput.files?.[0];
        if (file && !nameInput.value) {
          nameInput.value = file.name.replace(/\.[^.]+$/, '').replace(/[_-]/g, ' ');
        }
      });
    }

    document.querySelectorAll('details').forEach((details) => {
      const arrow = details.querySelector('.pdf-arrow') as HTMLElement | null;
      if (!arrow) return;
      details.addEventListener('toggle', () => {
        arrow.style.transform = details.open ? 'rotate(90deg)' : '';
      });
    });
  </script>

  {!isAdmin && (
    <a href={`/ensembles/${id}/songs`} class="button">
      <span class="icon"><i class="fas fa-arrow-left"></i></span>
      <span>Back to Songs</span>
    </a>
  )}
</EnsemblePageLayout>
