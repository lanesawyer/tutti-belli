---
import Layout from '../../../../layouts/Layout.astro';
import Button from '../../../../components/Button.astro';
import { db, eq, EnsembleMember, Event, EventProgram, Attendance, User, SeasonSong, Song } from 'astro:db';
import { actions } from 'astro:actions';
import QRCode from 'qrcode';
import { ensembleAdminTools } from '../../../../lib/config';
import { getEnsembleBySlugOrId, getEnsembleAccess } from '../../../../lib/ensemble';
import { getEnsembleUrlId } from '../../../../lib/slug';

const user = Astro.locals.user!;

const { id, eventId } = Astro.params;
if (!id || !eventId) {
  return Astro.redirect('/ensembles');
}

const ensemble = await getEnsembleBySlugOrId(id);
if (!ensemble) {
  return Astro.redirect('/ensembles');
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === 'GET' && id !== canonicalId) {
  return Astro.redirect(Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`), 301);
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect('/ensembles');
const { isAdmin } = access;

// Get event details
const [event] = await db.select().from(Event).where(eq(Event.id, eventId));
if (!event) {
  return Astro.redirect(`/ensembles/${canonicalId}/events`);
}

// Calculate check-in window
const now = new Date();
const scheduledTime = new Date(event.scheduledAt);
const checkInStartTime = new Date(scheduledTime.getTime() - (ensemble.checkInStartMinutes * 60 * 1000));
const checkInEndTime = new Date(scheduledTime.getTime() + (ensemble.checkInEndMinutes * 60 * 1000));

const canCheckIn = now >= checkInStartTime && now <= checkInEndTime;
const isTooEarly = now < checkInStartTime;
const isTooLate = now > checkInEndTime;

// Re-fetch event after a potential edit so the page reflects the latest values
const editResult = Astro.getActionResult(actions.events.edit);
if (editResult && !editResult.error) {
  const [updatedEvent] = await db.select().from(Event).where(eq(Event.id, eventId));
  if (updatedEvent) Object.assign(event, updatedEvent);
}

const checkInResult = Astro.getActionResult(actions.events.checkIn);
const addAttendanceResult = Astro.getActionResult(actions.events.addAttendance);
const removeAttendanceResult = Astro.getActionResult(actions.events.removeAttendance);

let message = '';
if (checkInResult?.error) message = checkInResult.error.message || 'Check-in failed.';
else if (checkInResult) message = 'Successfully checked in!';
else if (addAttendanceResult && !addAttendanceResult.error) message = 'Member marked as present.';
else if (removeAttendanceResult && !removeAttendanceResult.error) message = 'Attendance removed.';
else if (editResult && !editResult.error) message = 'Event updated successfully!';
else if (editResult?.error) message = editResult.error.message || 'Failed to update event.';

// Get attendance records
const attendanceRecords = await db
  .select({
    id: Attendance.id,
    userId: User.id,
    userName: User.name,
    checkedInAt: Attendance.checkedInAt,
    checkedInMethod: Attendance.checkedInMethod,
  })
  .from(Attendance)
  .innerJoin(User, eq(Attendance.userId, User.id))
  .where(eq(Attendance.eventId, eventId));

// Get all members for admin to mark attendance
const allMembers = await db
  .select({
    id: User.id,
    name: User.name,
    email: User.email,
  })
  .from(EnsembleMember)
  .innerJoin(User, eq(EnsembleMember.userId, User.id))
  .where(eq(EnsembleMember.ensembleId, ensemble.id));

const attendedUserIds = new Set(attendanceRecords.map(a => a.userId));
const absentMembers = allMembers.filter(m => !attendedUserIds.has(m.id));

// Generate QR code for check-in
const checkInUrl = `${Astro.url.origin}/checkin/${event.checkInCode}`;
const qrCodeDataUrl = await QRCode.toDataURL(checkInUrl, {
  width: 300,
  margin: 2,
});

const scheduledDate = new Date(event.scheduledAt);
const endTime = new Date(scheduledDate.getTime() + (event.durationMinutes * 60 * 1000));
const isPast = endTime < new Date();
const isUserCheckedIn = attendedUserIds.has(user.id);

// Prepare date/time for form inputs
const dateValue = scheduledDate.toISOString().split('T')[0];
const timeValue = scheduledDate.toTimeString().slice(0, 5);

// For performances: fetch program and available season songs
type ProgramSong = { entryId: string; id: string; name: string; composer: string | null; sortOrder: number };
type AvailableSong = { id: string; name: string; composer: string | null };

let programSongs: ProgramSong[] = [];
let availableSeasonSongs: AvailableSong[] = [];

if (event.category === 'performance') {
  programSongs = await db
    .select({
      entryId: EventProgram.id,
      id: Song.id,
      name: Song.name,
      composer: Song.composer,
      sortOrder: EventProgram.sortOrder,
    })
    .from(EventProgram)
    .innerJoin(Song, eq(EventProgram.songId, Song.id))
    .where(eq(EventProgram.eventId, eventId))
    .orderBy(EventProgram.sortOrder);

  const allSeasonSongs = await db
    .select({ id: Song.id, name: Song.name, composer: Song.composer })
    .from(SeasonSong)
    .innerJoin(Song, eq(SeasonSong.songId, Song.id))
    .where(eq(SeasonSong.seasonId, event.seasonId))
    .orderBy(Song.name);

  const programSongIds = new Set(programSongs.map(s => s.id));
  availableSeasonSongs = allSeasonSongs.filter(s => !programSongIds.has(s.id));
}

const isPerformance = event.category === 'performance';
---

<Layout title={`${event.title} - ${ensemble.name}`}>
  {isAdmin && (
    <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
      <a class="navbar-link">{ensemble.name}</a>
      <div class="navbar-dropdown">
        <a class={`navbar-item${Astro.url.pathname === `/ensembles/${canonicalId}` ? ' is-active' : ''}`} href={`/ensembles/${canonicalId}`}>
          <span class="icon is-small mr-1"><i class="fas fa-home"></i></span>
          Dashboard
        </a>
        <hr class="navbar-divider" />
        {ensembleAdminTools.map((tool) => {
          const href = tool.href(canonicalId);
          return (
            <a class={`navbar-item${Astro.url.pathname.startsWith(href) ? ' is-active' : ''}`} href={href}>
              <span class="icon is-small mr-1"><i class={`fas ${tool.icon}`}></i></span>
              {tool.label}
            </a>
          );
        })}
      </div>
    </div>
  )}

  <div class="level mb-5">
    <div class="level-left">
      <div class="level-item">
        <div>
          <h1 class="title">
            {event.title}
            <span class={`tag ml-2 ${isPerformance ? 'is-warning' : 'is-primary'}`}>
              {isPerformance ? 'Performance' : 'Rehearsal'}
            </span>
          </h1>
          <p class="subtitle">
            <span class="icon-text">
              <span class="icon">
                <i class="fas fa-calendar"></i>
              </span>
              <span>{scheduledDate.toLocaleDateString()}</span>
            </span>
            <span class="ml-3 icon-text">
              <span class="icon">
                <i class="fas fa-clock"></i>
              </span>
              <span>{scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
            </span>
            <span class="ml-3 icon-text">
              <span class="icon">
                <i class="fas fa-hourglass-half"></i>
              </span>
              <span>{event.durationMinutes} min</span>
            </span>
            {event.location && (
              <span class="ml-3 icon-text">
                <span class="icon">
                  <i class="fas fa-map-marker-alt"></i>
                </span>
                <span>{event.location}</span>
              </span>
            )}
          </p>
        </div>
      </div>
    </div>
    <div class="level-right">
      <div class="level-item">
        <div class="buttons">
          {isAdmin && (
            <Button color="warning" id="edit-event-btn">
              <span class="icon">
                <i class="fas fa-edit"></i>
              </span>
              <span>Edit Event</span>
            </Button>
          )}
          <Button href={`/ensembles/${canonicalId}/events`}>
            <span class="icon">
              <i class="fas fa-arrow-left"></i>
            </span>
            <span>Back to Events</span>
          </Button>
        </div>
      </div>
    </div>
  </div>

  {message && (
    <div class="notification is-success is-light">
      {message}
    </div>
  )}

  {event.description && (
    <div class="box">
      <p class="content">{event.description}</p>
    </div>
  )}

  <div class="columns">
    <div class="column">
      <div class="box">
        <h2 class="title is-4">Check-In</h2>

        {!isPast && (
          <div class="notification is-info is-light mb-4">
            <p class="has-text-weight-semibold">Check-in Window:</p>
            <p>Opens {ensemble.checkInStartMinutes} minutes before event</p>
            <p>Closes {ensemble.checkInEndMinutes} minutes after event start</p>
          </div>
        )}

        {!isPast && !isUserCheckedIn && canCheckIn && (
          <form method="POST" action={actions.events.checkIn}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="eventId" value={event.id} />
            <Button type="submit" color="primary" size="large" fullwidth>
              <span class="icon">
                <i class="fas fa-check"></i>
              </span>
              <span>Check In Now</span>
            </Button>
          </form>
        )}

        {!isPast && !isUserCheckedIn && !canCheckIn && !isAdmin && (
          <div>
            <Button type="button" size="large" fullwidth disabled>
              <span class="icon">
                <i class="fas fa-lock"></i>
              </span>
              <span>Check-in {isTooEarly ? 'Not Yet Available' : 'Closed'}</span>
            </Button>
            <p class="help mt-2 has-text-centered">
              {isTooEarly && `Check-in opens ${ensemble.checkInStartMinutes} minutes before event`}
              {isTooLate && `Check-in closed ${ensemble.checkInEndMinutes} minutes after event start`}
            </p>
          </div>
        )}

        {!isPast && !isUserCheckedIn && !canCheckIn && isAdmin && (
          <form method="POST" action={actions.events.checkIn}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="eventId" value={event.id} />
            <Button type="submit" color="warning" size="large" fullwidth>
              <span class="icon">
                <i class="fas fa-user-shield"></i>
              </span>
              <span>Admin Check-In (Bypasses Time Window)</span>
            </Button>
          </form>
        )}

        {!isPast && isUserCheckedIn && (
          <div class="notification is-success">
            <p class="has-text-centered">
              <span class="icon is-large">
                <i class="fas fa-check-circle fa-2x"></i>
              </span>
            </p>
            <p class="has-text-centered has-text-weight-bold">You're checked in!</p>
          </div>
        )}

        {isPast && !isUserCheckedIn && (
          <div class="notification is-warning">
            This event has passed and you did not check in.
          </div>
        )}
      </div>

      {isAdmin && (
        <div class="box">
          <h2 class="title is-4">QR Code Check-In</h2>
          <p class="mb-4">Display this QR code for members to scan and check in</p>

          <div class="has-text-centered">
            <img src={qrCodeDataUrl} alt="QR Code for check-in" class="image is-inline-block" />
          </div>

          <div class="field mt-4">
            <label class="label">Check-in URL</label>
            <div class="control">
              <input
                class="input is-family-monospace"
                type="text"
                value={checkInUrl}
                readonly
                onclick="this.select()"
              />
            </div>
            <p class="help">Members can scan the QR code or visit this URL to check in</p>
          </div>
        </div>
      )}
    </div>

    {isAdmin && (
      <div class="column">
        <div class="box">
          <h2 class="title is-4">Attendance ({attendanceRecords.length} / {allMembers.length})</h2>

          {attendanceRecords.length > 0 ? (
            <table class="table is-fullwidth is-striped">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Checked In</th>
                  <th>Method</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {attendanceRecords.map((record) => (
                  <tr>
                    <td>{record.userName}</td>
                    <td>{new Date(record.checkedInAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</td>
                    <td>
                      <span class={`tag is-small ${
                        record.checkedInMethod === 'qr' ? 'is-success' :
                        record.checkedInMethod === 'manual' ? 'is-info' :
                        'is-warning'
                      }`}>
                        {record.checkedInMethod === 'qr' ? 'QR Scan' :
                         record.checkedInMethod === 'manual' ? 'Manual' :
                         'Admin'}
                      </span>
                    </td>
                    <td>
                      <form method="POST" action={actions.events.removeAttendance} style="display: inline;">
                        <input type="hidden" name="ensembleId" value={ensemble.id} />
                        <input type="hidden" name="attendanceId" value={record.id} />
                        <Button type="submit" color="danger" size="small">
                          Remove
                        </Button>
                      </form>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <div class="notification is-info is-light">
              No one has checked in yet.
            </div>
          )}

          {absentMembers.length > 0 && (
            <>
              <hr />
              <h3 class="title is-5 mt-4">Mark Attendance</h3>
              <p class="mb-3">Members who haven't checked in:</p>
              {absentMembers.map((member) => (
                <div class="field is-grouped mb-2">
                  <div class="control is-expanded">
                    <input class="input is-static" type="text" value={member.name} readonly />
                  </div>
                  <div class="control">
                    <form method="POST" action={actions.events.addAttendance} style="display: inline;">
                      <input type="hidden" name="ensembleId" value={ensemble.id} />
                      <input type="hidden" name="eventId" value={event.id} />
                      <input type="hidden" name="userId" value={member.id} />
                      <Button type="submit" color="success">
                        Mark Present
                      </Button>
                    </form>
                  </div>
                </div>
              ))}
            </>
          )}
        </div>
      </div>
    )}
  </div>

  {isPerformance && (
    <div class="box mt-2">
      <h2 class="title is-4">
        <span class="icon-text">
          <span class={`icon ${isPerformance ? 'has-text-warning' : 'has-text-primary'}`}>
            <i class="fas fa-music"></i>
          </span>
          <span>Program</span>
        </span>
      </h2>

      {programSongs.length === 0 ? (
        <div class="notification is-info is-light">No songs on the program yet.</div>
      ) : (
        <table class="table is-fullwidth is-striped">
          <thead>
            <tr>
              <th style="width: 40px;">#</th>
              <th>Song</th>
              <th>Composer</th>
              {isAdmin && <th style="width: 80px;"></th>}
            </tr>
          </thead>
          <tbody>
            {programSongs.map((song, i) => (
              <tr>
                <td class="has-text-grey">{i + 1}</td>
                <td><strong>{song.name}</strong></td>
                <td class="has-text-grey">{song.composer ?? '—'}</td>
                {isAdmin && (
                  <td>
                    <form method="POST" action={actions.events.removeProgramSong} style="display: inline;">
                      <input type="hidden" name="ensembleId" value={ensemble.id} />
                      <input type="hidden" name="programEntryId" value={song.entryId} />
                      <Button type="submit" color="danger" size="small">
                        <span class="icon is-small"><i class="fas fa-times"></i></span>
                      </Button>
                    </form>
                  </td>
                )}
              </tr>
            ))}
          </tbody>
        </table>
      )}

      {isAdmin && availableSeasonSongs.length > 0 && (
        <form method="POST" action={actions.events.addProgramSong} class="mt-4">
          <input type="hidden" name="ensembleId" value={ensemble.id} />
          <input type="hidden" name="eventId" value={event.id} />
          <div class="field has-addons">
            <div class="control is-expanded">
              <div class="select is-fullwidth">
                <select name="songId">
                  {availableSeasonSongs.map(s => (
                    <option value={s.id}>
                      {s.name}{s.composer ? ` — ${s.composer}` : ''}
                    </option>
                  ))}
                </select>
              </div>
            </div>
            <div class="control">
              <Button type="submit" color="primary">
                <span class="icon"><i class="fas fa-plus"></i></span>
                <span>Add to Program</span>
              </Button>
            </div>
          </div>
          <p class="help">Only songs from the current season's repertoire can be added.</p>
        </form>
      )}

      {isAdmin && availableSeasonSongs.length === 0 && programSongs.length > 0 && (
        <p class="is-size-7 has-text-grey mt-3">All season songs are on the program.</p>
      )}

      {isAdmin && availableSeasonSongs.length === 0 && programSongs.length === 0 && (
        <p class="is-size-7 has-text-grey mt-3">
          No songs in the current season's repertoire.
          <a href={`/ensembles/${canonicalId}/songs`}> Add songs to the season</a> first.
        </p>
      )}
    </div>
  )}

  <!-- Edit Event Modal -->
  {isAdmin && (
    <div class="modal" id="edit-modal">
      <div class="modal-background"></div>
      <div class="modal-card">
        <header class="modal-card-head">
          <p class="modal-card-title">Edit Event</p>
          <button class="delete" aria-label="close" id="close-edit-modal"></button>
        </header>
        <form method="POST" action={actions.events.edit}>
          <section class="modal-card-body">
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="eventId" value={event.id} />

            <div class="field">
              <label class="label" for="edit-title">Title</label>
              <div class="control">
                <input
                  class="input"
                  type="text"
                  id="edit-title"
                  name="title"
                  value={event.title}
                  required
                />
              </div>
            </div>

            <div class="field">
              <label class="label" for="edit-description">Description</label>
              <div class="control">
                <textarea
                  class="textarea"
                  id="edit-description"
                  name="description"
                  rows="3"
                >{event.description || ''}</textarea>
              </div>
            </div>

            <div class="columns">
              <div class="column is-4">
                <div class="field">
                  <label class="label" for="edit-date">Date</label>
                  <div class="control">
                    <input
                      class="input"
                      type="date"
                      id="edit-date"
                      name="date"
                      value={dateValue}
                      required
                    />
                  </div>
                </div>
              </div>
              <div class="column is-4">
                <div class="field">
                  <label class="label" for="edit-time">Time</label>
                  <div class="control">
                    <input
                      class="input"
                      type="time"
                      id="edit-time"
                      name="time"
                      value={timeValue}
                      required
                    />
                  </div>
                </div>
              </div>
              <div class="column is-4">
                <div class="field">
                  <label class="label" for="edit-duration">Duration (min)</label>
                  <div class="control">
                    <input
                      class="input"
                      type="number"
                      id="edit-duration"
                      name="durationMinutes"
                      value={event.durationMinutes}
                      min="15"
                      max="480"
                      required
                    />
                  </div>
                </div>
              </div>
            </div>

            <div class="field">
              <label class="label" for="edit-location">Location</label>
              <div class="control">
                <input
                  class="input"
                  type="text"
                  id="edit-location"
                  name="location"
                  value={event.location || ''}
                />
              </div>
            </div>
          </section>
          <footer class="modal-card-foot">
            <Button color="primary" type="submit">Save Changes</Button>
            <Button type="button" id="cancel-edit">Cancel</Button>
          </footer>
        </form>
      </div>
    </div>
  )}

  <script>
    const editModal = document.getElementById('edit-modal');
    const editBtn = document.getElementById('edit-event-btn');
    const closeEditModal = document.getElementById('close-edit-modal');
    const cancelEdit = document.getElementById('cancel-edit');

    const openEditModal = () => editModal?.classList.add('is-active');
    const closeModal = () => editModal?.classList.remove('is-active');

    editBtn?.addEventListener('click', openEditModal);
    closeEditModal?.addEventListener('click', closeModal);
    cancelEdit?.addEventListener('click', closeModal);
    editModal?.querySelector('.modal-background')?.addEventListener('click', closeModal);
  </script>
</Layout>
