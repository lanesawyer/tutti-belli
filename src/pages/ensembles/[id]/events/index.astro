---
import EnsemblePageLayout from "@layouts/EnsemblePageLayout.astro";
import Table from "@components/elements/Table.astro";
import Modal from "@components/Modal.astro";
import Button from "@components/elements/Button.astro";
import Icon from "@components/elements/Icon.astro";
import TextInput from "@components/forms/TextInput.astro";
import Select from "@components/forms/Select.astro";
import Tag from "@components/elements/Tag.astro";
import Notification from "@components/elements/Notification.astro";
import { actions } from "astro:actions";
import { getEnsembleBySlugOrId, getEnsembleAccess } from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import { formatDuration } from "@lib/format";
import { getEventsPageData, isRsvpEnabled } from "@lib/events";

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);
if (!ensemble) {
  return Astro.redirect("/ensembles");
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(
    Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`),
    301,
  );
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect("/ensembles");
const { isAdmin } = access;

const createResult = Astro.getActionResult(actions.events.create);
const deleteResult = Astro.getActionResult(actions.events.delete);
const rsvpResult = Astro.getActionResult(actions.events.rsvp);
const removeRsvpResult = Astro.getActionResult(actions.events.removeRsvp);

let message = "";
let messageType: "success" | "danger" | undefined;

if (createResult) {
  if (createResult.error) {
    message = createResult.error.message || "Failed to create event.";
    messageType = "danger";
  } else {
    message = "Event created successfully!";
    messageType = "success";
  }
} else if (deleteResult) {
  if (deleteResult.error) {
    message = deleteResult.error.message || "Failed to delete event.";
    messageType = "danger";
  } else {
    message = "Event deleted successfully!";
    messageType = "success";
  }
} else if (rsvpResult) {
  if (rsvpResult.error) {
    message = rsvpResult.error.message || "Failed to save RSVP.";
    messageType = "danger";
  } else {
    message = "RSVP saved!";
    messageType = "success";
  }
} else if (removeRsvpResult) {
  if (removeRsvpResult.error) {
    message = removeRsvpResult.error.message || "Failed to remove RSVP.";
    messageType = "danger";
  } else {
    message = "RSVP removed.";
    messageType = "success";
  }
}

const {
  activeSeason,
  events: allEvents,
  groups,
  userRsvpMap,
} = await getEventsPageData(ensemble.id, user.id);

function categoryTag(category: string) {
  switch (category) {
    case "performance":
      return { label: "Performance", color: "is-warning" };
    case "social":
      return { label: "Social", color: "is-success" };
    case "sectional":
      return { label: "Sectional", color: "is-info" };
    default:
      return { label: "Rehearsal", color: "is-primary" };
  }
}

const now = new Date();
const upcomingEvents = allEvents.filter((e) => {
  const endTime = new Date(
    new Date(e.scheduledAt).getTime() + e.durationMinutes * 60 * 1000,
  );
  return endTime > now;
});
const pastEvents = allEvents.filter((e) => {
  const endTime = new Date(
    new Date(e.scheduledAt).getTime() + e.durationMinutes * 60 * 1000,
  );
  return endTime <= now;
});
---

<EnsemblePageLayout
  title={`Events - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Events"
  message={message}
  messageType={messageType}
  isAdmin={isAdmin}
>
  {
    isAdmin && (
      <Button slot="action" color="primary" id="create-event-btn">
        <Icon icon="fa-plus" />
        <span>Schedule Event</span>
      </Button>
    )
  }

  {
    allEvents.length === 0 ? (
      <Notification color="info" light>
        No events scheduled yet.
        {!activeSeason && isAdmin && (
          <span>
            {" "}
            You need an{" "}
            <a href={`/ensembles/${canonicalId}/seasons`}>active season</a>{" "}
            before scheduling events.
          </span>
        )}
      </Notification>
    ) : (
      <>
        {upcomingEvents.length > 0 && (
          <div class="mb-5">
            <h2 class="title is-5 mb-3">Upcoming</h2>
            <Table
              columns={[
                "Title",
                "Type",
                "Group",
                "Date",
                "Time",
                "Location",
                "Duration",
                "RSVP",
                { label: "Actions", style: "width: 160px;" },
              ]}
            >
              <tbody>
                {upcomingEvents.map((event) => {
                  const scheduledDate = new Date(event.scheduledAt);
                  const rsvpOn = isRsvpEnabled(event);
                  const userRsvp = rsvpOn
                    ? (userRsvpMap.get(event.id) ?? null)
                    : null;
                  return (
                    <tr>
                      <td>
                        <strong>{event.title}</strong>
                      </td>
                      <td>
                        {(() => {
                          const ct = categoryTag(event.category);
                          return (
                            <span class={`tag ${ct.color}`}>{ct.label}</span>
                          );
                        })()}
                      </td>
                      <td>
                        {event.groupName ? (
                          <Tag color={event.groupColor as any} size="small">
                            {event.groupName}
                          </Tag>
                        ) : (
                          <span class="has-text-grey-light">—</span>
                        )}
                      </td>
                      <td>{scheduledDate.toLocaleDateString()}</td>
                      <td>
                        {scheduledDate.toLocaleTimeString([], {
                          hour: "2-digit",
                          minute: "2-digit",
                        })}
                      </td>
                      <td>{event.location || "-"}</td>
                      <td>{formatDuration(event.durationMinutes)}</td>
                      <td>
                        {rsvpOn ? (
                          <div class="buttons are-small">
                            {userRsvp === "yes" ? (
                              <>
                                <span class="tag is-success is-small">
                                  Attending
                                </span>
                                <form
                                  method="POST"
                                  action={actions.events.rsvp}
                                  style="display:inline"
                                >
                                  <input
                                    type="hidden"
                                    name="ensembleId"
                                    value={ensemble.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="eventId"
                                    value={event.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="response"
                                    value="no"
                                  />
                                  <Button
                                    type="submit"
                                    size="small"
                                    color="danger"
                                  >
                                    No
                                  </Button>
                                </form>
                              </>
                            ) : userRsvp === "no" ? (
                              <>
                                <span class="tag is-danger is-small">
                                  Not Attending
                                </span>
                                <form
                                  method="POST"
                                  action={actions.events.rsvp}
                                  style="display:inline"
                                >
                                  <input
                                    type="hidden"
                                    name="ensembleId"
                                    value={ensemble.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="eventId"
                                    value={event.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="response"
                                    value="yes"
                                  />
                                  <Button
                                    type="submit"
                                    size="small"
                                    color="success"
                                  >
                                    Yes
                                  </Button>
                                </form>
                              </>
                            ) : (
                              <>
                                <form
                                  method="POST"
                                  action={actions.events.rsvp}
                                  style="display:inline"
                                >
                                  <input
                                    type="hidden"
                                    name="ensembleId"
                                    value={ensemble.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="eventId"
                                    value={event.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="response"
                                    value="yes"
                                  />
                                  <Button
                                    type="submit"
                                    size="small"
                                    color="success"
                                  >
                                    Yes
                                  </Button>
                                </form>
                                <form
                                  method="POST"
                                  action={actions.events.rsvp}
                                  style="display:inline"
                                >
                                  <input
                                    type="hidden"
                                    name="ensembleId"
                                    value={ensemble.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="eventId"
                                    value={event.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="response"
                                    value="no"
                                  />
                                  <Button
                                    type="submit"
                                    size="small"
                                    color="danger"
                                  >
                                    No
                                  </Button>
                                </form>
                              </>
                            )}
                          </div>
                        ) : (
                          <span class="has-text-grey-light">—</span>
                        )}
                      </td>
                      <td>
                        <div class="buttons are-small">
                          <Button
                            href={`/ensembles/${canonicalId}/events/${event.id}`}
                            color="info"
                          >
                            View
                          </Button>
                          {isAdmin && (
                            <Button
                              color="danger"
                              class="delete-event-btn"
                              data-event-id={event.id}
                            >
                              <Icon icon="fa-trash" />
                            </Button>
                          )}
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </Table>
          </div>
        )}

        {pastEvents.length > 0 && (
          <div>
            <h2 class="title is-5 mb-3">Past</h2>
            <Table
              columns={[
                "Title",
                "Type",
                "Group",
                "Date",
                "Time",
                "Location",
                { label: "Actions", style: "width: 100px;" },
              ]}
            >
              <tbody>
                {pastEvents.map((event) => {
                  const scheduledDate = new Date(event.scheduledAt);
                  return (
                    <tr>
                      <td>{event.title}</td>
                      <td>
                        {(() => {
                          const ct = categoryTag(event.category);
                          return (
                            <span class={`tag is-light ${ct.color}`}>
                              {ct.label}
                            </span>
                          );
                        })()}
                      </td>
                      <td>
                        {event.groupName ? (
                          <Tag
                            color={event.groupColor as any}
                            size="small"
                            light
                          >
                            {event.groupName}
                          </Tag>
                        ) : (
                          <span class="has-text-grey-light">—</span>
                        )}
                      </td>
                      <td>{scheduledDate.toLocaleDateString()}</td>
                      <td>
                        {scheduledDate.toLocaleTimeString([], {
                          hour: "2-digit",
                          minute: "2-digit",
                        })}
                      </td>
                      <td>{event.location || "-"}</td>
                      <td>
                        <Button
                          href={`/ensembles/${canonicalId}/events/${event.id}`}
                          size="small"
                        >
                          {isAdmin ? "Attendance" : "Details"}
                        </Button>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </Table>
          </div>
        )}
      </>
    )
  }

  <Fragment slot="modals">
    <!-- Create Event Modal -->
    {
      isAdmin && (
        <Modal id="create-modal" title="Schedule Event">
          <form id="createForm" method="POST" action={actions.events.create}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />

            <div class="columns">
              <div class="column">
                <TextInput
                  name="title"
                  label="Title *"
                  placeholder="Weekly Rehearsal"
                  required
                />
              </div>
              <div class="column is-narrow">
                <Select id="category" name="category" label="Type *">
                  <option value="rehearsal">Rehearsal</option>
                  <option value="performance">Performance</option>
                  <option value="social">Social</option>
                  <option value="sectional">Sectional</option>
                </Select>
              </div>
              {groups.length > 0 && (
                <div class="column is-narrow">
                  <Select id="groupId" name="groupId" label="Group">
                    <option value="">— All Members —</option>
                    {groups.map((g) => (
                      <option value={g.id}>{g.name}</option>
                    ))}
                  </Select>
                </div>
              )}
            </div>

            <Select
              name="rsvpEnabled"
              label="RSVP"
              help="Whether members can RSVP for this event."
            >
              <option value="">Default (based on type)</option>
              <option value="1">Enabled</option>
              <option value="0">Disabled</option>
            </Select>

            <TextInput
              name="location"
              label="Location"
              placeholder="Music Hall, Room 101"
            />

            <div class="columns">
              <div class="column">
                <TextInput name="date" label="Date *" type="date" required />
              </div>
              <div class="column">
                <TextInput name="time" label="Time *" type="time" required />
              </div>
              <div class="column">
                <TextInput
                  name="durationMinutes"
                  label="Duration (min)"
                  type="number"
                  value="90"
                  min="15"
                  max="480"
                />
              </div>
            </div>

            <div class="field">
              <label class="label" for="description">
                Description
              </label>
              <div class="control">
                <textarea
                  class="textarea"
                  id="description"
                  name="description"
                  placeholder="Optional notes about this event"
                  rows="3"
                />
              </div>
            </div>
          </form>

          <div slot="footer">
            <Button type="submit" form="createForm" color="primary">
              Schedule
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Delete Confirmation Modal -->
    {
      isAdmin && (
        <Modal id="delete-modal" title="Delete Event">
          <p>
            Are you sure you want to delete this event? This action cannot be
            undone.
          </p>
          <form id="deleteForm" method="POST" action={actions.events.delete}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="eventId" id="deleteEventId" />
          </form>

          <div slot="footer">
            <Button type="submit" form="deleteForm" color="danger">
              Delete
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <script is:inline>
      document.addEventListener("astro:page-load", () => {
        document
          .getElementById("create-event-btn")
          ?.addEventListener("click", () => {
            document.getElementById("create-modal")?.classList.add("is-active");
          });

        document.querySelectorAll(".delete-event-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("deleteEventId").value =
              btn.getAttribute("data-event-id");
            document.getElementById("delete-modal")?.classList.add("is-active");
          });
        });
      });
    </script>
  </Fragment>
</EnsemblePageLayout>
