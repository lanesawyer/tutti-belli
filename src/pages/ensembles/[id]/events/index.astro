---
import EnsemblePageLayout from '../../../../layouts/EnsemblePageLayout.astro';
import Table from '../../../../components/Table.astro';
import Modal from '../../../../components/Modal.astro';
import Button from '../../../../components/Button.astro';
import Notification from '../../../../components/Notification.astro';
import { db, eq, and, desc, Event, Season } from 'astro:db';
import { actions } from 'astro:actions';
import { getEnsembleBySlugOrId, getEnsembleAccess } from '../../../../lib/ensemble';
import { getEnsembleUrlId } from '../../../../lib/slug';
import { formatDuration } from '../../../../lib/format';

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);
if (!ensemble) {
  return Astro.redirect('/ensembles');
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === 'GET' && id !== canonicalId) {
  return Astro.redirect(Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`), 301);
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect('/ensembles');
const { isAdmin } = access;

// Get the active season for this ensemble
const [activeSeason] = await db
  .select()
  .from(Season)
  .where(and(eq(Season.ensembleId, ensemble.id), eq(Season.isActive, 1)))
  .limit(1);

const createResult = Astro.getActionResult(actions.events.create);
const deleteResult = Astro.getActionResult(actions.events.delete);

let message = '';
let messageType: 'success' | 'danger' | undefined;

if (createResult) {
  if (createResult.error) {
    message = createResult.error.message || 'Failed to create event.';
    messageType = 'danger';
  } else {
    message = 'Event created successfully!';
    messageType = 'success';
  }
} else if (deleteResult) {
  if (deleteResult.error) {
    message = deleteResult.error.message || 'Failed to delete event.';
    messageType = 'danger';
  } else {
    message = 'Event deleted successfully!';
    messageType = 'success';
  }
}

// Get all events
const events = await db
  .select()
  .from(Event)
  .where(eq(Event.ensembleId, ensemble.id))
  .orderBy(desc(Event.scheduledAt));

const now = new Date();
const upcomingEvents = events.filter(e => {
  const endTime = new Date(new Date(e.scheduledAt).getTime() + e.durationMinutes * 60 * 1000);
  return endTime > now;
});
const pastEvents = events.filter(e => {
  const endTime = new Date(new Date(e.scheduledAt).getTime() + e.durationMinutes * 60 * 1000);
  return endTime <= now;
});
---

<EnsemblePageLayout
  title={`Events - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Events"
  message={message}
  messageType={messageType}
  isAdmin={isAdmin}
>
  {isAdmin && (
    <Button slot="action" color="primary" id="create-event-btn">
      <span class="icon"><i class="fas fa-plus"></i></span>
      <span>Schedule Event</span>
    </Button>
  )}

  {events.length === 0 ? (
    <Notification color="info" light>
      No events scheduled yet.
      {!activeSeason && isAdmin && (
        <span> You need an <a href={`/ensembles/${canonicalId}/seasons`}>active season</a> before scheduling events.</span>
      )}
    </Notification>
  ) : (
    <>
      {upcomingEvents.length > 0 && (
        <div class="mb-5">
          <h2 class="title is-5 mb-3">Upcoming</h2>
          <Table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Date</th>
                <th>Time</th>
                <th>Location</th>
                <th>Duration</th>
                <th style="width: 160px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              {upcomingEvents.map((event) => {
                const scheduledDate = new Date(event.scheduledAt);
                return (
                  <tr>
                    <td><strong>{event.title}</strong></td>
                    <td>
                      <span class={`tag ${event.category === 'performance' ? 'is-warning' : 'is-primary'}`}>
                        {event.category === 'performance' ? 'Performance' : 'Rehearsal'}
                      </span>
                    </td>
                    <td>{scheduledDate.toLocaleDateString()}</td>
                    <td>{scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</td>
                    <td>{event.location || '-'}</td>
                    <td>{formatDuration(event.durationMinutes)}</td>
                    <td>
                      <div class="buttons are-small">
                        <Button href={`/ensembles/${canonicalId}/events/${event.id}`} color="info">
                          View
                        </Button>
                        {isAdmin && (
                          <Button
                            color="danger"
                            class="delete-event-btn"
                            data-event-id={event.id}
                          >
                            <span class="icon"><i class="fas fa-trash"></i></span>
                          </Button>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </Table>
        </div>
      )}

      {pastEvents.length > 0 && (
        <div>
          <h2 class="title is-5 mb-3">Past</h2>
          <Table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Date</th>
                <th>Time</th>
                <th>Location</th>
                <th style="width: 100px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              {pastEvents.map((event) => {
                const scheduledDate = new Date(event.scheduledAt);
                return (
                  <tr>
                    <td>{event.title}</td>
                    <td>
                      <span class={`tag is-light ${event.category === 'performance' ? 'is-warning' : 'is-primary'}`}>
                        {event.category === 'performance' ? 'Performance' : 'Rehearsal'}
                      </span>
                    </td>
                    <td>{scheduledDate.toLocaleDateString()}</td>
                    <td>{scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</td>
                    <td>{event.location || '-'}</td>
                    <td>
                      <Button href={`/ensembles/${canonicalId}/events/${event.id}`} size="small">
                        {isAdmin ? 'Attendance' : 'Details'}
                      </Button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </Table>
        </div>
      )}
    </>
  )}

  <Fragment slot="modals">
<!-- Create Event Modal -->
{isAdmin && (
  <Modal id="create-modal" title="Schedule Event">
    <form id="createForm" method="POST" action={actions.events.create}>
      <input type="hidden" name="ensembleId" value={ensemble.id} />

      <div class="columns">
        <div class="column">
          <div class="field">
            <label class="label" for="title">Title *</label>
            <div class="control">
              <input class="input" type="text" id="title" name="title" placeholder="Weekly Rehearsal" required />
            </div>
          </div>
        </div>
        <div class="column is-narrow">
          <div class="field">
            <label class="label" for="category">Type *</label>
            <div class="control">
              <div class="select">
                <select id="category" name="category">
                  <option value="rehearsal">Rehearsal</option>
                  <option value="performance">Performance</option>
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="field">
        <label class="label" for="location">Location</label>
        <div class="control">
          <input class="input" type="text" id="location" name="location" placeholder="Music Hall, Room 101" />
        </div>
      </div>

      <div class="columns">
        <div class="column">
          <div class="field">
            <label class="label" for="date">Date *</label>
            <div class="control">
              <input class="input" type="date" id="date" name="date" required />
            </div>
          </div>
        </div>
        <div class="column">
          <div class="field">
            <label class="label" for="time">Time *</label>
            <div class="control">
              <input class="input" type="time" id="time" name="time" required />
            </div>
          </div>
        </div>
        <div class="column">
          <div class="field">
            <label class="label" for="durationMinutes">Duration (min)</label>
            <div class="control">
              <input class="input" type="number" id="durationMinutes" name="durationMinutes" value="90" min="15" max="480" />
            </div>
          </div>
        </div>
      </div>

      <div class="field">
        <label class="label" for="description">Description</label>
        <div class="control">
          <textarea class="textarea" id="description" name="description" placeholder="Optional notes about this event" rows="3"></textarea>
        </div>
      </div>
    </form>

    <div slot="footer">
      <Button type="submit" form="createForm" color="primary">Schedule</Button>
      <Button type="button" data-modal-close>Cancel</Button>
    </div>
  </Modal>
)}

<!-- Delete Confirmation Modal -->
{isAdmin && (
  <Modal id="delete-modal" title="Delete Event">
    <p>Are you sure you want to delete this event? This action cannot be undone.</p>
    <form id="deleteForm" method="POST" action={actions.events.delete}>
      <input type="hidden" name="ensembleId" value={ensemble.id} />
      <input type="hidden" name="eventId" id="deleteEventId" />
    </form>

    <div slot="footer">
      <Button type="submit" form="deleteForm" color="danger">Delete</Button>
      <Button type="button" data-modal-close>Cancel</Button>
    </div>
  </Modal>
)}

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('create-event-btn')?.addEventListener('click', () => {
      document.getElementById('create-modal')?.classList.add('is-active');
    });

    document.querySelectorAll('.delete-event-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('deleteEventId').value = btn.getAttribute('data-event-id');
        document.getElementById('delete-modal')?.classList.add('is-active');
      });
    });
  });
</script>
  </Fragment>
</EnsemblePageLayout>
