---
import Layout from '../../../../layouts/Layout.astro';
import { db, eq, and, desc, Ensemble, EnsembleMember, Rehearsal, Season } from 'astro:db';
import { canManageEnsemble } from '../../../../lib/permissions';
const user = Astro.locals.user!;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/ensembles');
}

// Get ensemble details
const [ensemble] = await db.select().from(Ensemble).where(eq(Ensemble.id, id));
if (!ensemble) {
  return Astro.redirect('/ensembles');
}

// Check if user is a member
const [membership] = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id), eq(EnsembleMember.userId, user.id)));

if (!membership) {
  return Astro.redirect('/ensembles');
}

const isAdmin = canManageEnsemble(user, membership);

// Get the active season for this ensemble
const [activeSeason] = await db
  .select()
  .from(Season)
  .where(and(eq(Season.ensembleId, id), eq(Season.isActive, 1)))
  .limit(1);

if (!activeSeason) {
  return new Response('No active season found. Please create a season first.', { status: 400 });
}

let message = '';

// Handle creating new rehearsal
if (Astro.request.method === 'POST' && isAdmin) {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create') {
    const title = formData.get('title')?.toString();
    const description = formData.get('description')?.toString();
    const date = formData.get('date')?.toString();
    const time = formData.get('time')?.toString();
    const location = formData.get('location')?.toString();
    const durationMinutes = parseInt(formData.get('durationMinutes')?.toString() || '90');

    if (title && date && time) {
      const scheduledAt = new Date(`${date}T${time}`);
      const checkInCode = Math.random().toString(36).substring(2, 10).toUpperCase();

      await db.insert(Rehearsal).values({
        id: crypto.randomUUID(),
        ensembleId: id,
        seasonId: activeSeason.id,
        title,
        description: description || '',
        scheduledAt,
        durationMinutes,
        location: location || '',
        checkInCode,
      });

      message = 'Rehearsal created successfully!';
    }
  } else if (action === 'delete') {
    const rehearsalId = formData.get('rehearsalId')?.toString();
    if (rehearsalId) {
      await db.delete(Rehearsal).where(eq(Rehearsal.id, rehearsalId));
      message = 'Rehearsal deleted successfully!';
    }
  }
}

// Get all rehearsals
const rehearsals = await db
  .select()
  .from(Rehearsal)
  .where(eq(Rehearsal.ensembleId, id))
  .orderBy(desc(Rehearsal.scheduledAt));

const now = new Date();
// A rehearsal is considered past if it has ended (scheduled time + duration)
const upcomingRehearsals = rehearsals.filter(r => {
  const scheduledTime = new Date(r.scheduledAt);
  const endTime = new Date(scheduledTime.getTime() + (r.durationMinutes * 60 * 1000));
  return endTime > now;
});
const pastRehearsals = rehearsals.filter(r => {
  const scheduledTime = new Date(r.scheduledAt);
  const endTime = new Date(scheduledTime.getTime() + (r.durationMinutes * 60 * 1000));
  return endTime <= now;
});
---

<Layout title={`${ensemble.name} - Rehearsals`}>
  <div class="level mb-5">
    <div class="level-left">
      <div class="level-item">
        <div>
          <h1 class="title">{ensemble.name}</h1>
          <p class="subtitle">Rehearsals</p>
        </div>
      </div>
    </div>
    <div class="level-right">
      <div class="level-item">
        <a href={`/ensembles/${id}`} class="button">
          <span class="icon">
            <i class="fas fa-arrow-left"></i>
          </span>
          <span>Back to Ensemble</span>
        </a>
      </div>
    </div>
  </div>

  {message && (
    <div class="notification is-success is-light">
      {message}
    </div>
  )}

  {isAdmin && (
    <div class="box mb-5">
      <h2 class="title is-4">Schedule New Rehearsal</h2>
      <form method="POST">
        <input type="hidden" name="action" value="create" />
        
        <div class="columns">
          <div class="column is-6">
            <div class="field">
              <label class="label" for="title">Title</label>
              <div class="control">
                <input
                  class="input"
                  type="text"
                  id="title"
                  name="title"
                  placeholder="Weekly Rehearsal"
                  required
                />
              </div>
            </div>
          </div>
          <div class="column is-6">
            <div class="field">
              <label class="label" for="location">Location</label>
              <div class="control">
                <input
                  class="input"
                  type="text"
                  id="location"
                  name="location"
                  placeholder="Music Hall, Room 101"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="field">
          <label class="label" for="description">Description</label>
          <div class="control">
            <textarea
              class="textarea"
              id="description"
              name="description"
              placeholder="Optional notes about this rehearsal"
            ></textarea>
          </div>
        </div>

        <div class="columns">
          <div class="column is-4">
            <div class="field">
              <label class="label" for="date">Date</label>
              <div class="control">
                <input
                  class="input"
                  type="date"
                  id="date"
                  name="date"
                  required
                />
              </div>
            </div>
          </div>
          <div class="column is-4">
            <div class="field">
              <label class="label" for="time">Time</label>
              <div class="control">
                <input
                  class="input"
                  type="time"
                  id="time"
                  name="time"
                  required
                />
              </div>
            </div>
          </div>
          <div class="column is-4">
            <div class="field">
              <label class="label" for="durationMinutes">Duration (minutes)</label>
              <div class="control">
                <input
                  class="input"
                  type="number"
                  id="durationMinutes"
                  name="durationMinutes"
                  value="90"
                  min="15"
                  max="480"
                  required
                />
              </div>
              <p class="help">Default: 90 minutes (1.5 hours)</p>
            </div>
          </div>
        </div>

        <div class="field">
          <div class="control">
            <button type="submit" class="button is-primary">
              <span class="icon">
                <i class="fas fa-plus"></i>
              </span>
              <span>Create Rehearsal</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  )}

  {upcomingRehearsals.length > 0 && (
    <div class="box mb-5">
      <h2 class="title is-4">Upcoming Rehearsals</h2>
      {upcomingRehearsals.map((rehearsal) => {
        const scheduledDate = new Date(rehearsal.scheduledAt);
        return (
          <div class="box">
            <div class="level">
              <div class="level-left">
                <div class="level-item">
                  <div>
                    <p class="title is-5">{rehearsal.title}</p>
                    <p class="subtitle is-6">
                      <span class="icon-text">
                        <span class="icon">
                          <i class="fas fa-calendar"></i>
                        </span>
                        <span>{scheduledDate.toLocaleDateString()}</span>
                      </span>
                      <span class="ml-3 icon-text">
                        <span class="icon">
                          <i class="fas fa-clock"></i>
                        </span>
                        <span>{scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                      </span>
                      {rehearsal.location && (
                        <span class="ml-3 icon-text">
                          <span class="icon">
                            <i class="fas fa-map-marker-alt"></i>
                          </span>
                          <span>{rehearsal.location}</span>
                        </span>
                      )}
                    </p>
                  </div>
                </div>
              </div>
              <div class="level-right">
                <div class="level-item">
                  <div class="buttons">
                    <a href={`/ensembles/${id}/rehearsals/${rehearsal.id}`} class="button is-info">
                      View Details
                    </a>
                    {isAdmin && (
                      <form method="POST" style="display: inline;">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="rehearsalId" value={rehearsal.id} />
                        <button
                          type="submit"
                          class="button is-danger"
                          onclick="return confirm('Are you sure you want to delete this rehearsal?')"
                        >
                          Delete
                        </button>
                      </form>
                    )}
                  </div>
                </div>
              </div>
            </div>
            {rehearsal.description && (
              <p class="content">{rehearsal.description}</p>
            )}
          </div>
        );
      })}
    </div>
  )}

  {pastRehearsals.length > 0 && (
    <div class="box">
      <h2 class="title is-4">Past Rehearsals</h2>
      {pastRehearsals.map((rehearsal) => {
        const scheduledDate = new Date(rehearsal.scheduledAt);
        return (
          <div class="box">
            <div class="level">
              <div class="level-left">
                <div class="level-item">
                  <div>
                    <p class="title is-6">{rehearsal.title}</p>
                    <p class="subtitle is-7">
                      {scheduledDate.toLocaleDateString()} at {scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </p>
                  </div>
                </div>
              </div>
              <div class="level-right">
                <div class="level-item">
                  <a href={`/ensembles/${id}/rehearsals/${rehearsal.id}`} class="button is-small">
                    {isAdmin ? 'View Attendance' : 'View Details'}
                  </a>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  )}

  {rehearsals.length === 0 && (
    <div class="notification is-info is-light">
      No rehearsals scheduled yet.
    </div>
  )}
</Layout>
