---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Box, Table, Button, Image, Icon, Breadcrumb } from "astro-bulma";
import { ensembleAdminTools } from "@lib/config";
import { getInitials, getColorFromInitials } from "@lib/avatar";
import { getEnsembleBySlugOrId, getEnsembleAccess } from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import { getMemberAttendanceStats } from "@lib/member-attendance";
import { getEnsembleSeasons } from "@lib/seasons";

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);
if (!ensemble) return Astro.redirect("/ensembles");

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(
    Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`),
    301,
  );
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect("/ensembles");
const { isAdmin } = access;

if (!isAdmin) return new Response("Unauthorized", { status: 403 });

const seasonId = Astro.url.searchParams.get("seasonId") ?? undefined;
const [seasons, stats] = await Promise.all([
  getEnsembleSeasons(ensemble.id),
  getMemberAttendanceStats(ensemble.id, seasonId),
]);

const selectedSeason = seasons.find((s) => s.id === seasonId);
---

<BaseLayout title={`Member Attendance - ${ensemble.name}`}>
  <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
    <a class="navbar-link">{ensemble.name}</a>
    <div class="navbar-dropdown">
      <a
        class={`navbar-item${Astro.url.pathname === `/ensembles/${canonicalId}` ? " is-active" : ""}`}
        href={`/ensembles/${canonicalId}`}
      >
        <Icon icon="fa-home" size="small" class="mr-1" />
        Dashboard
      </a>
      <hr class="navbar-divider" />
      {
        ensembleAdminTools.map((tool) => {
          const href = tool.href(canonicalId);
          return (
            <a
              class={`navbar-item${Astro.url.pathname.startsWith(href) ? " is-active" : ""}`}
              href={href}
            >
              <Icon icon={tool.icon} size="small" class="mr-1" />
              {tool.label}
            </a>
          );
        })
      }
    </div>
  </div>

  <section class="section">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Ensembles", href: "/ensembles" },
          { label: ensemble.name, href: `/ensembles/${canonicalId}` },
          { label: "Members", href: `/ensembles/${canonicalId}/members` },
          { label: "Attendance" },
        ]}
      />

      <div class="level mb-5">
        <div class="level-left">
          <div class="level-item">
            <div>
              <h1 class="title">Member Attendance</h1>
              <p class="subtitle">
                {selectedSeason ? `Season: ${selectedSeason.name}` : "All time"}
              </p>
            </div>
          </div>
        </div>
        <div class="level-right">
          {
            seasons.length > 0 && (
              <div class="level-item">
                <div class="field has-addons">
                  <div class="control">
                    <div class="select">
                      <select
                        id="season-filter"
                        onchange="window.location.href = this.value ? `?seasonId=${this.value}` : '?'"
                      >
                        <option value="">All seasons</option>
                        {seasons.map((s) => (
                          <option value={s.id} selected={s.id === seasonId}>
                            {s.name}
                            {s.isActive ? " (active)" : ""}
                          </option>
                        ))}
                      </select>
                    </div>
                  </div>
                </div>
              </div>
            )
          }
          <div class="level-item">
            <Button href={`/ensembles/${canonicalId}/export/attendance${seasonId ? `?seasonId=${seasonId}` : ""}`}>
              <Icon icon="fa-download" />
              <span>Export CSV</span>
            </Button>
          </div>
        </div>
      </div>

      <Box>
        {
          stats.length === 0 ? (
            <p class="has-text-grey">No active members found.</p>
          ) : (
            <Table>
              <thead>
                <tr>
                  <th style="width: 60px;" />
                  <th>Name</th>
                  <th>Role</th>
                  <th>Attended</th>
                  <th>Total Events</th>
                  <th>Attendance %</th>
                </tr>
              </thead>
              <tbody>
                {stats.map((member) => (
                  <tr>
                    <td>
                      {member.avatarUrl ? (
                        <Image
                          src={member.avatarUrl}
                          alt={member.name}
                          size="48x48"
                          rounded
                          imgStyle="object-fit: cover;"
                        />
                      ) : (
                        <figure class="image is-48x48">
                          <div
                            style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}
                          >
                            {getInitials(member.name)}
                          </div>
                        </figure>
                      )}
                    </td>
                    <td>
                      <div>{member.name}</div>
                      <div class="is-size-7 has-text-grey">{member.email}</div>
                    </td>
                    <td>
                      <span
                        class={`tag ${member.role === "admin" ? "is-warning" : "is-info"}`}
                      >
                        {member.role === "admin" ? "Admin" : "Member"}
                      </span>
                    </td>
                    <td>{member.attended}</td>
                    <td>{member.total}</td>
                    <td>
                      <div
                        class="is-flex is-align-items-center"
                        style="gap: 0.5rem;"
                      >
                        <progress
                          class={`progress is-small mb-0 ${member.pct >= 75 ? "is-success" : member.pct >= 50 ? "is-warning" : "is-danger"}`}
                          value={member.pct}
                          max="100"
                          style="width: 80px;"
                        />
                        <span
                          class={`has-text-weight-semibold ${member.pct >= 75 ? "has-text-success" : member.pct >= 50 ? "has-text-warning" : "has-text-danger"}`}
                        >
                          {member.pct}%
                        </span>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </Table>
          )
        }
      </Box>
    </div>
  </section>
</BaseLayout>
