---
import BaseLayout from "@layouts/BaseLayout.astro";
import Box from "@components/elements/Box.astro";
import Table from "@components/elements/Table.astro";
import { actions } from "astro:actions";
import { ensembleAdminTools } from "@lib/config";
import { getInitials, getColorFromInitials } from "@lib/avatar";
import {
  getEnsembleBySlugOrId,
  getEnsembleAccess,
  getEnsembleMembersWithUsers,
  getEnsembleParts,
  getMemberPartAssignments,
} from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import Button from "@components/elements/Button.astro";
import Image from "@components/elements/Image.astro";
import Icon from "@components/elements/Icon.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);
if (!ensemble) {
  return Astro.redirect("/ensembles");
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(
    Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`),
    301,
  );
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect("/ensembles");
const { isAdmin } = access;

if (!isAdmin) {
  return new Response("Unauthorized", { status: 403 });
}

const removeResult = Astro.getActionResult(actions.members.remove);
const promoteResult = Astro.getActionResult(actions.members.promote);
const demoteResult = Astro.getActionResult(actions.members.demote);

if ((removeResult || promoteResult || demoteResult) && !removeResult?.error && !promoteResult?.error && !demoteResult?.error) {
  return Astro.redirect(`/ensembles/${canonicalId}/members`);
}

const membersData = await getEnsembleMembersWithUsers(ensemble.id);
const allParts = await getEnsembleParts(ensemble.id);
const membershipIds = membersData.map((m) => m.membershipId);
const memberPartRows = await getMemberPartAssignments(membershipIds);

const membersByPart = new Map<string, typeof membersData>();
const membersWithPartIds = new Set<string>();

for (const mp of memberPartRows) {
  const member = membersData.find((m) => m.membershipId === mp.membershipId);
  if (!member) continue;
  membersWithPartIds.add(mp.membershipId);
  if (!membersByPart.has(mp.partId)) {
    membersByPart.set(mp.partId, []);
  }
  membersByPart.get(mp.partId)!.push(member);
}

const membersWithoutPart = membersData.filter(
  (m) => !membersWithPartIds.has(m.membershipId),
);

const members = membersData;
---

<BaseLayout title={`Manage Members - ${ensemble.name}`} backgroundIcon="fa-users">
  <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
    <a class="navbar-link">{ensemble.name}</a>
    <div class="navbar-dropdown">
      <a
        class={`navbar-item${Astro.url.pathname === `/ensembles/${canonicalId}` ? " is-active" : ""}`}
        href={`/ensembles/${canonicalId}`}
      >
        <Icon icon="fa-home" size="small" class="mr-1" />
        Dashboard
      </a>
      <hr class="navbar-divider" />
      {
        ensembleAdminTools.map((tool) => {
          const href = tool.href(canonicalId);
          return (
            <a
              class={`navbar-item${Astro.url.pathname.startsWith(href) ? " is-active" : ""}`}
              href={href}
            >
              <Icon icon={tool.icon} size="small" class="mr-1" />
              {tool.label}
            </a>
          );
        })
      }
    </div>
  </div>
  <section class="section">
    <div class="container">
      <Breadcrumb
        items={[
          { label: "Ensembles", href: "/ensembles" },
          { label: ensemble.name, href: `/ensembles/${canonicalId}` },
          { label: "Manage Members" },
        ]}
      />

      <div class="level mb-5">
        <div class="level-left">
          <div class="level-item">
            <div>
              <h1 class="title">Manage Members</h1>
              <p class="subtitle">Total Members: {members.length}</p>
            </div>
          </div>
        </div>
        <div class="level-right">
          <div class="level-item">
            <Button href={`/ensembles/${canonicalId}`}>
              <Icon icon="fa-arrow-left" />
              <span>Back to Ensemble</span>
            </Button>
          </div>
        </div>
      </div>

      <Box>
        {
          allParts.length > 0 ? (
            <>
              {allParts.map((part) => {
                const partMembers = membersByPart.get(part.id) || [];
                if (partMembers.length === 0) return null;

                return (
                  <div class="mb-5">
                    <Table
                      title={`${part.name} (${partMembers.length})`}
                      className="has-text-primary"
                    >
                      <thead>
                        <tr>
                          <th style="width: 60px;" />
                          <th>Name</th>
                          <th>Email</th>
                          <th>Role</th>
                          <th>Joined</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {partMembers.map((member: any) => (
                          <tr>
                            <td>
                              {member.avatarUrl ? (
                                <Image
                                  src={member.avatarUrl}
                                  alt={member.name}
                                  size="48x48"
                                  rounded
                                  imgStyle="object-fit: cover;"
                                />
                              ) : (
                                <figure class="image is-48x48">
                                  <div
                                    style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}
                                  >
                                    {getInitials(member.name)}
                                  </div>
                                </figure>
                              )}
                            </td>
                            <td>{member.name}</td>
                            <td>{member.email}</td>
                            <td>
                              <span
                                class={`tag ${member.role === "admin" ? "is-warning" : "is-info"}`}
                              >
                                {member.role === "admin" ? "Admin" : "Member"}
                              </span>
                            </td>
                            <td>
                              {new Date(member.joinedAt).toLocaleDateString()}
                            </td>
                            {member.id !== user.id && (
                              <td>
                                <div class="buttons are-small">
                                  {member.role === "member" ? (
                                    <form
                                      method="POST"
                                      action={actions.members.promote}
                                      style="display: inline;"
                                    >
                                      <input
                                        type="hidden"
                                        name="ensembleId"
                                        value={ensemble.id}
                                      />
                                      <input
                                        type="hidden"
                                        name="membershipId"
                                        value={member.membershipId}
                                      />
                                      <Button
                                        type="submit"
                                        color="warning"
                                        size="small"
                                      >
                                        Make Admin
                                      </Button>
                                    </form>
                                  ) : (
                                    <form
                                      method="POST"
                                      action={actions.members.demote}
                                      style="display: inline;"
                                    >
                                      <input
                                        type="hidden"
                                        name="ensembleId"
                                        value={ensemble.id}
                                      />
                                      <input
                                        type="hidden"
                                        name="membershipId"
                                        value={member.membershipId}
                                      />
                                      <Button
                                        type="submit"
                                        color="info"
                                        size="small"
                                      >
                                        Remove Admin
                                      </Button>
                                    </form>
                                  )}
                                  <form method="POST" action={actions.members.remove} style="display: inline;">
                                    <input
                                      type="hidden"
                                      name="ensembleId"
                                      value={ensemble.id}
                                    />
                                    <input
                                      type="hidden"
                                      name="membershipId"
                                      value={member.membershipId}
                                    />
                                    <Button
                                      type="submit"
                                      color="danger"
                                      size="small"
                                    >
                                      Remove
                                    </Button>
                                  </form>
                                </div>
                              </td>
                            )}
                          </tr>
                        ))}
                      </tbody>
                    </Table>
                  </div>
                );
              })}

              {membersWithoutPart.length > 0 && (
                <div class="mb-5">
                  <Table
                    title={`No Part Assigned (${membersWithoutPart.length})`}
                  >
                    <thead>
                      <tr>
                        <th style="width: 60px;" />
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {membersWithoutPart.map((member) => (
                        <tr>
                          <td>
                            {member.avatarUrl ? (
                              <Image
                                src={member.avatarUrl}
                                alt={member.name}
                                size="48x48"
                                rounded
                                imgStyle="object-fit: cover;"
                              />
                            ) : (
                              <figure class="image is-48x48">
                                <div
                                  style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}
                                >
                                  {getInitials(member.name)}
                                </div>
                              </figure>
                            )}
                          </td>
                          <td>{member.name}</td>
                          <td>{member.email}</td>
                          <td>
                            <span
                              class={`tag ${member.role === "admin" ? "is-warning" : "is-info"}`}
                            >
                              {member.role === "admin" ? "Admin" : "Member"}
                            </span>
                          </td>
                          <td>
                            {new Date(member.joinedAt).toLocaleDateString()}
                          </td>
                          {member.id !== user.id && (
                            <td>
                              <div class="buttons are-small">
                                {member.role === "member" ? (
                                  <form method="POST" action={actions.members.promote} style="display: inline;">
                                    <input
                                      type="hidden"
                                      name="ensembleId"
                                      value={ensemble.id}
                                    />
                                    <input
                                      type="hidden"
                                      name="membershipId"
                                      value={member.membershipId}
                                    />
                                    <Button
                                      type="submit"
                                      color="warning"
                                      size="small"
                                    >
                                      Make Admin
                                    </Button>
                                  </form>
                                ) : (
                                  <form method="POST" action={actions.members.demote} style="display: inline;">
                                    <input
                                      type="hidden"
                                      name="ensembleId"
                                      value={ensemble.id}
                                    />
                                    <input
                                      type="hidden"
                                      name="membershipId"
                                      value={member.membershipId}
                                    />
                                    <Button
                                      type="submit"
                                      color="info"
                                      size="small"
                                    >
                                      Remove Admin
                                    </Button>
                                  </form>
                                )}
                                <form method="POST" action={actions.members.remove} style="display: inline;">
                                  <input
                                    type="hidden"
                                    name="ensembleId"
                                    value={ensemble.id}
                                  />
                                  <input
                                    type="hidden"
                                    name="membershipId"
                                    value={member.membershipId}
                                  />
                                  <Button
                                    type="submit"
                                    color="danger"
                                    size="small"
                                  >
                                    Remove
                                  </Button>
                                </form>
                              </div>
                            </td>
                          )}
                        </tr>
                      ))}
                    </tbody>
                  </Table>
                </div>
              )}
            </>
          ) : (
            <Table>
              <thead>
                <tr>
                  <th style="width: 60px;" />
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Joined</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {members.map((member) => (
                  <tr>
                    <td>
                      {member.avatarUrl ? (
                        <Image
                          src={member.avatarUrl}
                          alt={member.name}
                          size="48x48"
                          rounded
                          imgStyle="object-fit: cover;"
                        />
                      ) : (
                        <figure class="image is-48x48">
                          <div
                            style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}
                          >
                            {getInitials(member.name)}
                          </div>
                        </figure>
                      )}
                    </td>
                    <td>{member.name}</td>
                    <td>{member.email}</td>
                    <td>
                      <span
                        class={`tag ${member.role === "admin" ? "is-warning" : "is-info"}`}
                      >
                        {member.role === "admin" ? "Admin" : "Member"}
                      </span>
                    </td>
                    <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
                    {member.id !== user.id && (
                      <td>
                        <div class="buttons are-small">
                          {member.role === "member" ? (
                            <form method="POST" action={actions.members.promote} style="display: inline;">
                              <input
                                type="hidden"
                                name="ensembleId"
                                value={ensemble.id}
                              />
                              <input
                                type="hidden"
                                name="membershipId"
                                value={member.membershipId}
                              />
                              <Button
                                type="submit"
                                color="warning"
                                size="small"
                              >
                                Make Admin
                              </Button>
                            </form>
                          ) : (
                            <form method="POST" action={actions.members.demote} style="display: inline;">
                              <input
                                type="hidden"
                                name="ensembleId"
                                value={ensemble.id}
                              />
                              <input
                                type="hidden"
                                name="membershipId"
                                value={member.membershipId}
                              />
                              <Button type="submit" color="info" size="small">
                                Remove Admin
                              </Button>
                            </form>
                          )}
                          <form method="POST" action={actions.members.remove} style="display: inline;">
                            <input
                              type="hidden"
                              name="ensembleId"
                              value={ensemble.id}
                            />
                            <input
                              type="hidden"
                              name="membershipId"
                              value={member.membershipId}
                            />
                            <Button type="submit" color="danger" size="small">
                              Remove
                            </Button>
                          </form>
                        </div>
                      </td>
                    )}
                  </tr>
                ))}
              </tbody>
            </Table>
          )
        }
      </Box>
    </div>
  </section>
</BaseLayout>
