---
import Layout from '../../../layouts/Layout.astro';
import Table from '../../../components/elements/Table.astro';
import { db, eq, and, EnsembleMember, User, Part } from 'astro:db';
import { ensembleAdminTools } from '../../../lib/config';
import { getInitials, getColorFromInitials } from '../../../lib/avatar';
import { getEnsembleBySlugOrId, getEnsembleAccess } from '../../../lib/ensemble';
import { getEnsembleUrlId } from '../../../lib/slug';
import Button from '../../../components/elements/Button.astro';
import Icon from '../../../components/elements/Icon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);
if (!ensemble) {
  return Astro.redirect('/ensembles');
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === 'GET' && id !== canonicalId) {
  return Astro.redirect(Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`), 301);
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect('/ensembles');
const { isAdmin } = access;

if (!isAdmin) {
  return new Response('Unauthorized', { status: 403 });
}

// Get all active members with their parts
const membersData = await db
  .select({
    id: User.id,
    name: User.name,
    email: User.email,
    avatarUrl: User.avatarUrl,
    role: EnsembleMember.role,
    status: EnsembleMember.status,
    joinedAt: EnsembleMember.joinedAt,
    membershipId: EnsembleMember.id,
    partId: EnsembleMember.partId,
  })
  .from(EnsembleMember)
  .innerJoin(User, eq(EnsembleMember.userId, User.id))
  .where(and(eq(EnsembleMember.ensembleId, ensemble.id), eq(EnsembleMember.status, 'active')));

// Get all parts for this ensemble
const allParts = await db
  .select()
  .from(Part)
  .where(eq(Part.ensembleId, ensemble.id))
  .all();

// Sort parts by sortOrder
allParts.sort((a, b) => a.sortOrder - b.sortOrder);

// Group members by part
const membersByPart = new Map();
const membersWithoutPart = [];

for (const member of membersData) {
  if (member.partId) {
    if (!membersByPart.has(member.partId)) {
      membersByPart.set(member.partId, []);
    }
    membersByPart.get(member.partId).push(member);
  } else {
    membersWithoutPart.push(member);
  }
}

const members = membersData;

// Handle member actions
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();
  const membershipId = formData.get('membershipId')?.toString();

  if (action === 'remove' && membershipId) {
    await db.delete(EnsembleMember).where(eq(EnsembleMember.id, membershipId));
    return Astro.redirect(`/ensembles/${canonicalId}/members`);
  } else if (action === 'promote' && membershipId) {
    await db
      .update(EnsembleMember)
      .set({ role: 'admin' })
      .where(eq(EnsembleMember.id, membershipId));
    return Astro.redirect(`/ensembles/${canonicalId}/members`);
  } else if (action === 'demote' && membershipId) {
    await db
      .update(EnsembleMember)
      .set({ role: 'member' })
      .where(eq(EnsembleMember.id, membershipId));
    return Astro.redirect(`/ensembles/${canonicalId}/members`);
  }
}
---

<Layout title={`Manage Members - ${ensemble.name}`}>
  <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
    <a class="navbar-link">{ensemble.name}</a>
    <div class="navbar-dropdown">
      <a class={`navbar-item${Astro.url.pathname === `/ensembles/${canonicalId}` ? ' is-active' : ''}`} href={`/ensembles/${canonicalId}`}>
        <Icon icon="fa-home" size="small" class="mr-1" />
        Dashboard
      </a>
      <hr class="navbar-divider" />
      {ensembleAdminTools.map((tool) => {
        const href = tool.href(canonicalId);
        return (
          <a class={`navbar-item${Astro.url.pathname.startsWith(href) ? ' is-active' : ''}`} href={href}>
            <Icon icon={tool.icon} size="small" class="mr-1" />
            {tool.label}
          </a>
        );
      })}
    </div>
  </div>
  <section class="section">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Ensembles', href: '/ensembles' },
        { label: ensemble.name, href: `/ensembles/${canonicalId}` },
        { label: 'Manage Members' },
      ]} />

      <div class="level mb-5">
        <div class="level-left">
          <div class="level-item">
            <div>
              <h1 class="title">Manage Members</h1>
              <p class="subtitle">Total Members: {members.length}</p>
            </div>
          </div>
        </div>
        <div class="level-right">
          <div class="level-item">
            <Button href={`/ensembles/${canonicalId}`}>
              <Icon icon="fa-arrow-left" />
              <span>Back to Ensemble</span>
            </Button>
          </div>
        </div>
      </div>

      <div class="box">
        {allParts.length > 0 ? (
          <>
            {allParts.map((part) => {
              const partMembers = membersByPart.get(part.id) || [];
              if (partMembers.length === 0) return null;
              
              return (
                <div class="mb-5">
                  <Table title={`${part.name} (${partMembers.length})`} className="has-text-primary">
                    <thead>
                      <tr>
                        <th style="width: 60px;"></th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {partMembers.map((member: any) => (
                        <tr>
                          <td>
                            <figure class="image is-48x48">
                              {member.avatarUrl ? (
                                <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                              ) : (
                                <div style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}>
                                  {getInitials(member.name)}
                                </div>
                              )}
                            </figure>
                          </td>
                          <td>{member.name}</td>
                          <td>{member.email}</td>
                          <td>
                            <span class={`tag ${member.role === 'admin' ? 'is-warning' : 'is-info'}`}>
                              {member.role === 'admin' ? 'Admin' : 'Member'}
                            </span>
                          </td>
                          <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
                          {member.id !== user.id && (
                            <td>
                              <div class="buttons are-small">
                                {member.role === 'member' ? (
                                  <form method="POST" style="display: inline;">
                                    <input type="hidden" name="action" value="promote" />
                                    <input type="hidden" name="membershipId" value={member.membershipId} />
                                    <Button type="submit" color="warning" size="small">
                                      Make Admin
                                    </Button>
                                  </form>
                                ) : (
                                  <form method="POST" style="display: inline;">
                                    <input type="hidden" name="action" value="demote" />
                                    <input type="hidden" name="membershipId" value={member.membershipId} />
                                    <Button type="submit" color="info" size="small">
                                      Remove Admin
                                    </Button>
                                  </form>
                                )}
                                <form method="POST" style="display: inline;">
                                  <input type="hidden" name="action" value="remove" />
                                  <input type="hidden" name="membershipId" value={member.membershipId} />
                                  <Button type="submit" color="danger" size="small">
                                    Remove
                                  </Button>
                                </form>
                              </div>
                            </td>
                          )}
                        </tr>
                      ))}
                    </tbody>
                  </Table>
                </div>
              );
            })}

            {membersWithoutPart.length > 0 && (
              <div class="mb-5">
                <Table title={`No Part Assigned (${membersWithoutPart.length})`}>
                  <thead>
                    <tr>
                      <th style="width: 60px;"></th>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Role</th>
                      <th>Joined</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {membersWithoutPart.map((member) => (
                      <tr>
                        <td>
                          <figure class="image is-48x48">
                            {member.avatarUrl ? (
                              <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                            ) : (
                              <div style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}>
                                {getInitials(member.name)}
                              </div>
                            )}
                          </figure>
                        </td>
                        <td>{member.name}</td>
                        <td>{member.email}</td>
                        <td>
                          <span class={`tag ${member.role === 'admin' ? 'is-warning' : 'is-info'}`}>
                            {member.role === 'admin' ? 'Admin' : 'Member'}
                          </span>
                        </td>
                        <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
                        {member.id !== user.id && (
                          <td>
                            <div class="buttons are-small">
                              {member.role === 'member' ? (
                                <form method="POST" style="display: inline;">
                                  <input type="hidden" name="action" value="promote" />
                                  <input type="hidden" name="membershipId" value={member.membershipId} />
                                  <Button type="submit" color="warning" size="small">
                                    Make Admin
                                  </Button>
                                </form>
                              ) : (
                                <form method="POST" style="display: inline;">
                                  <input type="hidden" name="action" value="demote" />
                                  <input type="hidden" name="membershipId" value={member.membershipId} />
                                  <Button type="submit" color="info" size="small">
                                    Remove Admin
                                  </Button>
                                </form>
                              )}
                              <form method="POST" style="display: inline;">
                                <input type="hidden" name="action" value="remove" />
                                <input type="hidden" name="membershipId" value={member.membershipId} />
                                <Button type="submit" color="danger" size="small">
                                  Remove
                                </Button>
                              </form>
                            </div>
                          </td>
                        )}
                      </tr>
                    ))}
                  </tbody>
                </Table>
              </div>
            )}
          </>
        ) : (
          <Table>
            <thead>
              <tr>
                <th style="width: 60px;"></th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {members.map((member) => (
                <tr>
                  <td>
                    <figure class="image is-48x48">
                      {member.avatarUrl ? (
                        <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                      ) : (
                        <div style={`width: 48px; height: 48px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem; font-weight: bold;`}>
                          {getInitials(member.name)}
                        </div>
                      )}
                    </figure>
                  </td>
                  <td>{member.name}</td>
                  <td>{member.email}</td>
                  <td>
                    <span class={`tag ${member.role === 'admin' ? 'is-warning' : 'is-info'}`}>
                      {member.role === 'admin' ? 'Admin' : 'Member'}
                    </span>
                  </td>
                  <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
                  {member.id !== user.id && (
                    <td>
                      <div class="buttons are-small">
                        {member.role === 'member' ? (
                          <form method="POST" style="display: inline;">
                            <input type="hidden" name="action" value="promote" />
                            <input type="hidden" name="membershipId" value={member.membershipId} />
                            <Button type="submit" color="warning" size="small">
                              Make Admin
                            </Button>
                          </form>
                        ) : (
                          <form method="POST" style="display: inline;">
                            <input type="hidden" name="action" value="demote" />
                            <input type="hidden" name="membershipId" value={member.membershipId} />
                            <Button type="submit" color="info" size="small">
                              Remove Admin
                            </Button>
                          </form>
                        )}
                        <form method="POST" style="display: inline;">
                          <input type="hidden" name="action" value="remove" />
                          <input type="hidden" name="membershipId" value={member.membershipId} />
                          <Button type="submit" color="danger" size="small">
                            Remove
                          </Button>
                        </form>
                      </div>
                    </td>
                  )}
                </tr>
              ))}
            </tbody>
          </Table>
        )}
      </div>
    </div>
  </section>
</Layout>
