---
import Layout from '../../../layouts/Layout.astro';
import { db, eq, and, Ensemble, EnsembleMember, Part } from 'astro:db';
import { canManageEnsemble } from '../../../lib/permissions';
const user = Astro.locals.user!;

const { id } = Astro.params;

// Get the ensemble
const ensemble = await db
  .select()
  .from(Ensemble)
  .where(eq(Ensemble.id, id!))
  .get();

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

// Check if user is an admin of this ensemble
const membership = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.userId, user.id)))
  .get();

const isAdmin = canManageEnsemble(user, membership);

if (!isAdmin) {
  return new Response('Unauthorized', { status: 403 });
}

// Get all parts for this ensemble
const parts = await db
  .select()
  .from(Part)
  .where(eq(Part.ensembleId, id!))
  .all();

// Sort parts by sortOrder
parts.sort((a, b) => a.sortOrder - b.sortOrder);

// Handle form submissions
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'add') {
    const name = formData.get('name') as string;
    const sortOrder = parseInt(formData.get('sortOrder') as string) || 0;

    if (name) {
      await db.insert(Part).values({
        id: crypto.randomUUID(),
        ensembleId: id!,
        name: name.trim(),
        sortOrder,
      });
    }
  } else if (action === 'edit') {
    const partId = formData.get('partId') as string;
    const name = formData.get('name') as string;
    const sortOrder = parseInt(formData.get('sortOrder') as string) || 0;

    if (partId && name) {
      await db
        .update(Part)
        .set({ name: name.trim(), sortOrder })
        .where(eq(Part.id, partId));
    }
  } else if (action === 'delete') {
    const partId = formData.get('partId') as string;

    if (partId) {
      // Check if any members are assigned to this part
      const membersCount = await db
        .select()
        .from(EnsembleMember)
        .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.partId, partId)))
        .all();

      if (membersCount.length === 0) {
        await db.delete(Part).where(eq(Part.id, partId));
      }
    }
  }

  return Astro.redirect(`/ensembles/${id}/parts`);
}
---

<Layout title={`Manage Parts - ${ensemble.name}`}>
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumbs">
        <ul>
          <li><a href="/ensembles">Ensembles</a></li>
          <li><a href={`/ensembles/${id}`}>{ensemble.name}</a></li>
          <li class="is-active"><a href="#" aria-current="page">Manage Parts</a></li>
        </ul>
      </nav>

      <h1 class="title">Manage Parts</h1>
      <p class="subtitle">Configure voice parts for {ensemble.name}</p>

      <div class="columns">
        <div class="column is-two-thirds">
          <div class="box">
            <h2 class="title is-4">Current Parts</h2>
            {parts.length === 0 ? (
              <div class="notification is-info is-light">
                <p>No parts defined yet. Add your first part below.</p>
              </div>
            ) : (
              <table class="table is-fullwidth is-hoverable">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Sort Order</th>
                    <th style="width: 200px;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {parts.map((part) => (
                    <tr id={`part-${part.id}`}>
                      <td>
                        <span class="part-name">{part.name}</span>
                        <input
                          type="text"
                          class="input is-small part-name-edit"
                          style="display: none;"
                          value={part.name}
                          data-part-id={part.id}
                        />
                      </td>
                      <td>
                        <span class="part-order">{part.sortOrder}</span>
                        <input
                          type="number"
                          class="input is-small part-order-edit"
                          style="display: none; width: 100px;"
                          value={part.sortOrder}
                          data-part-id={part.id}
                        />
                      </td>
                      <td>
                        <div class="buttons are-small part-actions">
                          <button class="button is-info edit-btn" data-part-id={part.id}>
                            <span class="icon">
                              <i class="fas fa-edit"></i>
                            </span>
                            <span>Edit</span>
                          </button>
                          <form method="POST" style="display: inline;" class="delete-form">
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="partId" value={part.id} />
                            <button type="submit" class="button is-danger delete-btn">
                              <span class="icon">
                                <i class="fas fa-trash"></i>
                              </span>
                              <span>Delete</span>
                            </button>
                          </form>
                        </div>
                        <div class="buttons are-small part-edit-actions" style="display: none;">
                          <button class="button is-success save-btn" data-part-id={part.id}>
                            <span class="icon">
                              <i class="fas fa-check"></i>
                            </span>
                            <span>Save</span>
                          </button>
                          <button class="button cancel-btn" data-part-id={part.id}>
                            <span class="icon">
                              <i class="fas fa-times"></i>
                            </span>
                            <span>Cancel</span>
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>
        </div>

        <div class="column">
          <div class="box">
            <h2 class="title is-4">Add New Part</h2>
            <form method="POST">
              <input type="hidden" name="action" value="add" />
              
              <div class="field">
                <label class="label" for="name">Part Name</label>
                <div class="control">
                  <input
                    class="input"
                    type="text"
                    id="name"
                    name="name"
                    placeholder="e.g., Soprano, Alto"
                    required
                  />
                </div>
              </div>

              <div class="field">
                <label class="label" for="sortOrder">Sort Order</label>
                <div class="control">
                  <input
                    class="input"
                    type="number"
                    id="sortOrder"
                    name="sortOrder"
                    value={parts.length > 0 ? Math.max(...parts.map(p => p.sortOrder)) + 1 : 1}
                    min="0"
                  />
                </div>
                <p class="help">Lower numbers appear first in lists</p>
              </div>

              <div class="field">
                <div class="control">
                  <button type="submit" class="button is-primary">
                    <span class="icon">
                      <i class="fas fa-plus"></i>
                    </span>
                    <span>Add Part</span>
                  </button>
                </div>
              </div>
            </form>
          </div>

          <div class="box">
            <h2 class="title is-5">About Parts</h2>
            <div class="content">
              <p><strong>Sort Order</strong> determines how parts are displayed in member lists.</p>
              <p><strong>Deleting</strong> a part is only allowed if no members are assigned to it.</p>
              <p>Members can select their part from their profile page.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Handle inline editing
    document.querySelectorAll('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const partId = (e.currentTarget as HTMLElement).dataset.partId;
        const row = document.querySelector(`#part-${partId}`);
        if (!row) return;

        // Hide display elements and show edit elements
        row.querySelector('.part-name')?.setAttribute('style', 'display: none;');
        row.querySelector('.part-order')?.setAttribute('style', 'display: none;');
        row.querySelector('.part-name-edit')?.removeAttribute('style');
        row.querySelector('.part-order-edit')?.removeAttribute('style');
        row.querySelector('.part-actions')?.setAttribute('style', 'display: none;');
        row.querySelector('.part-edit-actions')?.removeAttribute('style');
      });
    });

    document.querySelectorAll('.cancel-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const partId = (e.currentTarget as HTMLElement).dataset.partId;
        const row = document.querySelector(`#part-${partId}`);
        if (!row) return;

        // Show display elements and hide edit elements
        row.querySelector('.part-name')?.removeAttribute('style');
        row.querySelector('.part-order')?.removeAttribute('style');
        row.querySelector('.part-name-edit')?.setAttribute('style', 'display: none;');
        row.querySelector('.part-order-edit')?.setAttribute('style', 'display: none;');
        row.querySelector('.part-actions')?.removeAttribute('style');
        row.querySelector('.part-edit-actions')?.setAttribute('style', 'display: none;');

        // Reset input values
        const nameEdit = row.querySelector('.part-name-edit') as HTMLInputElement;
        const nameDisplay = row.querySelector('.part-name');
        if (nameEdit && nameDisplay) {
          nameEdit.value = nameDisplay.textContent?.trim() || '';
        }

        const orderEdit = row.querySelector('.part-order-edit') as HTMLInputElement;
        const orderDisplay = row.querySelector('.part-order');
        if (orderEdit && orderDisplay) {
          orderEdit.value = orderDisplay.textContent?.trim() || '';
        }
      });
    });

    document.querySelectorAll('.save-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const partId = (e.currentTarget as HTMLElement).dataset.partId;
        const row = document.querySelector(`#part-${partId}`);
        if (!row) return;

        const nameInput = row.querySelector('.part-name-edit') as HTMLInputElement;
        const orderInput = row.querySelector('.part-order-edit') as HTMLInputElement;

        if (!nameInput || !orderInput) return;

        // Submit the form
        const form = document.createElement('form');
        form.method = 'POST';
        form.innerHTML = `
          <input type="hidden" name="action" value="edit" />
          <input type="hidden" name="partId" value="${partId}" />
          <input type="hidden" name="name" value="${nameInput.value}" />
          <input type="hidden" name="sortOrder" value="${orderInput.value}" />
        `;
        document.body.appendChild(form);
        form.submit();
      });
    });

    // Confirm before deleting
    document.querySelectorAll('.delete-form').forEach((form) => {
      form.addEventListener('submit', (e) => {
        if (!confirm('Are you sure you want to delete this part? This can only be done if no members are assigned to it.')) {
          e.preventDefault();
        }
      });
    });
  </script>
</Layout>
