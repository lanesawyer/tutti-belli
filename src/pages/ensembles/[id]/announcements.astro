---
import EnsemblePageLayout from "@layouts/EnsemblePageLayout.astro";
import Table from "@components/elements/Table.astro";
import Modal from "@components/Modal.astro";
import Button from "@components/elements/Button.astro";
import Icon from "@components/elements/Icon.astro";
import TextInput from "@components/forms/TextInput.astro";
import Notification from "@components/elements/Notification.astro";
import Tag from "@components/elements/Tag.astro";
import { actions } from "astro:actions";
import Checkbox from "@components/forms/Checkbox.astro";
import { getEnsembleBySlugOrId, getEnsembleAccess } from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import { getEnsembleAnnouncements } from "@lib/announcements";

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);

if (!ensemble) {
  return new Response("Ensemble not found", { status: 404 });
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(
    Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`),
    301,
  );
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access)
  return new Response("Unauthorized - Not a member", { status: 403 });
const { isAdmin } = access;

const createResult = Astro.getActionResult(actions.announcements.create);
const updateResult = Astro.getActionResult(actions.announcements.update);
const deleteResult = Astro.getActionResult(actions.announcements.delete);

let message = "";
let messageType: "success" | "danger" | undefined;

if (createResult?.error) {
  message = createResult.error.message ?? "Failed to create announcement.";
  messageType = "danger";
} else if (createResult) {
  message = "Announcement created successfully!";
  messageType = "success";
} else if (updateResult?.error) {
  message = updateResult.error.message ?? "Failed to update announcement.";
  messageType = "danger";
} else if (updateResult) {
  message = "Announcement updated successfully!";
  messageType = "success";
} else if (deleteResult?.error) {
  message = deleteResult.error.message ?? "Failed to delete announcement.";
  messageType = "danger";
} else if (deleteResult) {
  message = "Announcement deleted successfully!";
  messageType = "success";
}

const announcements = await getEnsembleAnnouncements(ensemble.id);
---

<EnsemblePageLayout
  title={`Announcements - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Announcements"
  message={message}
  messageType={messageType}
  isAdmin={isAdmin}
>
  {
    isAdmin && (
      <Button slot="action" color="primary" id="create-announcement-btn">
        <Icon icon="fa-plus" />
        <span>New Announcement</span>
      </Button>
    )
  }

  {
    announcements.length === 0 ? (
      <Notification color="info" light>
        No announcements yet.
        {isAdmin && ' Click "New Announcement" to post one.'}
      </Notification>
    ) : (
      <Table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Posted By</th>
            <th>Date</th>
            {isAdmin && <th style="width: 110px;">Actions</th>}
          </tr>
        </thead>
        <tbody>
          {announcements.map((announcement) => (
            <tr>
              <td>
                <strong>{announcement.title}</strong>
                <p
                  class="has-text-grey is-size-7 mt-1"
                  style="white-space: pre-wrap; max-width: 500px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;"
                >
                  {announcement.content}
                </p>
              </td>
              <td>{announcement.creatorName}</td>
              <td>
                {new Date(announcement.createdAt).toLocaleDateString()}
                {announcement.updatedAt.getTime() !==
                  announcement.createdAt.getTime() && (
                  <Tag size="small" class="ml-1">
                    edited
                  </Tag>
                )}
              </td>
              {isAdmin && (
                <td>
                  <div class="buttons are-small">
                    <Button
                      color="warning"
                      class="edit-announcement-btn"
                      data-announcement-id={announcement.id}
                      data-announcement-title={announcement.title}
                      data-announcement-content={announcement.content}
                    >
                      <Icon icon="fa-edit" />
                    </Button>
                    <Button
                      color="danger"
                      class="delete-announcement-btn"
                      data-announcement-id={announcement.id}
                    >
                      <Icon icon="fa-trash" />
                    </Button>
                  </div>
                </td>
              )}
            </tr>
          ))}
        </tbody>
      </Table>
    )
  }

  <Fragment slot="modals">
    <!-- Create Announcement Modal -->
    {
      isAdmin && (
        <Modal id="create-modal" title="New Announcement">
          <form id="createForm" method="POST" action={actions.announcements.create}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="ensembleName" value={ensemble.name} />
            <input type="hidden" name="canonicalId" value={canonicalId} />
            {ensemble.discordWebhookUrl && (
              <input type="hidden" name="discordWebhookUrl" value={ensemble.discordWebhookUrl} />
            )}

            <TextInput
              name="title"
              id="create-title"
              label="Title *"
              required
            />

            <div class="field">
              <label class="label" for="create-content">
                Content *
              </label>
              <div class="control">
                <textarea
                  class="textarea"
                  id="create-content"
                  name="content"
                  rows="6"
                  required
                />
              </div>
            </div>

            {ensemble.discordWebhookUrl && (
              <Checkbox name="postToDiscord" label="Post to Discord" />
            )}
          </form>

          <div slot="footer">
            <Button type="submit" form="createForm" color="primary">
              <Icon icon="fa-bullhorn" />
              <span>Post Announcement</span>
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Edit Announcement Modal -->
    {
      isAdmin && (
        <Modal id="edit-modal" title="Edit Announcement">
          <form id="editForm" method="POST" action={actions.announcements.update}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="ensembleName" value={ensemble.name} />
            <input type="hidden" name="canonicalId" value={canonicalId} />
            {ensemble.discordWebhookUrl && (
              <input type="hidden" name="discordWebhookUrl" value={ensemble.discordWebhookUrl} />
            )}
            <input
              type="hidden"
              name="announcementId"
              id="edit-announcement-id"
            />

            <TextInput name="title" id="edit-title" label="Title *" required />

            <div class="field">
              <label class="label" for="edit-content">
                Content *
              </label>
              <div class="control">
                <textarea
                  class="textarea"
                  id="edit-content"
                  name="content"
                  rows="6"
                  required
                />
              </div>
            </div>

            {ensemble.discordWebhookUrl && (
              <Checkbox name="postToDiscord" label="Post to Discord" />
            )}
          </form>

          <div slot="footer">
            <Button type="submit" form="editForm" color="primary">
              Save Changes
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Delete Confirmation Modal -->
    {
      isAdmin && (
        <Modal id="delete-modal" title="Delete Announcement">
          <p>
            Are you sure you want to delete this announcement? This action
            cannot be undone.
          </p>
          <form id="deleteForm" method="POST" action={actions.announcements.delete}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input
              type="hidden"
              name="announcementId"
              id="delete-announcement-id"
            />
          </form>

          <div slot="footer">
            <Button type="submit" form="deleteForm" color="danger">
              Delete
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <script is:inline>
      document.addEventListener("astro:page-load", () => {
        document
          .getElementById("create-announcement-btn")
          ?.addEventListener("click", () => {
            document.getElementById("create-modal")?.classList.add("is-active");
          });

        document.querySelectorAll(".edit-announcement-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("edit-announcement-id").value =
              btn.getAttribute("data-announcement-id");
            document.getElementById("edit-title").value = btn.getAttribute(
              "data-announcement-title",
            );
            document.getElementById("edit-content").value = btn.getAttribute(
              "data-announcement-content",
            );
            document.getElementById("edit-modal")?.classList.add("is-active");
          });
        });

        document.querySelectorAll(".delete-announcement-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("delete-announcement-id").value =
              btn.getAttribute("data-announcement-id");
            document.getElementById("delete-modal")?.classList.add("is-active");
          });
        });
      });
    </script>
  </Fragment>
</EnsemblePageLayout>
