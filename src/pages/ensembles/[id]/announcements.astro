---
import Layout from '../../../layouts/Layout.astro';
import { db, eq, and, desc, Ensemble, EnsembleMember, Announcement, User } from 'astro:db';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

// Get the ensemble
const ensemble = await db
  .select()
  .from(Ensemble)
  .where(eq(Ensemble.id, id!))
  .get();

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

// Check if user is a member of this ensemble
const membership = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.userId, user.id)))
  .get();

if (!membership) {
  return new Response('Unauthorized - Not a member', { status: 403 });
}

const isAdmin = membership.role === 'admin' || user.role === 'admin';

let message = '';
let messageType = '';

// Handle form submission
if (Astro.request.method === 'POST') {
  if (!isAdmin) {
    return new Response('Unauthorized', { status: 403 });
  }

  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create') {
    const title = formData.get('title')?.toString();
    const content = formData.get('content')?.toString();

    if (!title || !title.trim() || !content || !content.trim()) {
      message = 'Title and content are required';
      messageType = 'danger';
    } else {
      const announcementId = crypto.randomUUID();
      await db.insert(Announcement).values({
        id: announcementId,
        ensembleId: id!,
        title: title.trim(),
        content: content.trim(),
        createdBy: user.id,
        createdAt: new Date(),
        updatedAt: new Date(),
      });
      message = 'Announcement created successfully!';
      messageType = 'success';
    }
  } else if (action === 'delete') {
    const announcementId = formData.get('announcementId')?.toString();
    if (announcementId) {
      await db.delete(Announcement).where(eq(Announcement.id, announcementId));
      message = 'Announcement deleted successfully!';
      messageType = 'success';
    }
  } else if (action === 'edit') {
    const announcementId = formData.get('announcementId')?.toString();
    const title = formData.get('title')?.toString();
    const content = formData.get('content')?.toString();

    if (!announcementId || !title || !title.trim() || !content || !content.trim()) {
      message = 'Title and content are required';
      messageType = 'danger';
    } else {
      await db.update(Announcement)
        .set({
          title: title.trim(),
          content: content.trim(),
          updatedAt: new Date(),
        })
        .where(eq(Announcement.id, announcementId));
      message = 'Announcement updated successfully!';
      messageType = 'success';
    }
  }
}

// Get all announcements for this ensemble
const announcements = await db
  .select({
    id: Announcement.id,
    title: Announcement.title,
    content: Announcement.content,
    createdAt: Announcement.createdAt,
    updatedAt: Announcement.updatedAt,
    creatorName: User.name,
  })
  .from(Announcement)
  .innerJoin(User, eq(Announcement.createdBy, User.id))
  .where(eq(Announcement.ensembleId, id!))
  .orderBy(desc(Announcement.createdAt));
---

<Layout title={`${ensemble.name} - Announcements`}>
  <div class="columns">
    <div class="column">
      <nav class="breadcrumb" aria-label="breadcrumbs">
        <ul>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a href={`/ensembles/${id}`}>{ensemble.name}</a></li>
          <li class="is-active"><a href="#" aria-current="page">Announcements</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <h1 class="title">{ensemble.name} - Announcements</h1>
    </div>
  </div>

  {message && (
    <div class={`notification is-${messageType}`}>
      <button class="delete"></button>
      {message}
    </div>
  )}

  {isAdmin && (
    <div class="box">
      <h2 class="title is-4">Create New Announcement</h2>
      <form method="POST">
        <input type="hidden" name="action" value="create" />
        
        <div class="field">
          <label class="label" for="title">Title</label>
          <div class="control">
            <input class="input" type="text" id="title" name="title" required />
          </div>
        </div>

        <div class="field">
          <label class="label" for="content">Content</label>
          <div class="control">
            <textarea class="textarea" id="content" name="content" rows="5" required></textarea>
          </div>
        </div>

        <div class="field">
          <div class="control">
            <button class="button is-primary" type="submit">
              <span class="icon">
                <i class="fas fa-bullhorn"></i>
              </span>
              <span>Create Announcement</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  )}

  <div class="columns is-multiline">
    {announcements.length === 0 && (
      <div class="column is-12">
        <div class="notification is-info is-light">
          <p class="has-text-centered">
            <span class="icon is-large">
              <i class="fas fa-info-circle fa-2x"></i>
            </span>
          </p>
          <p class="has-text-centered">No announcements yet.</p>
        </div>
      </div>
    )}

    {announcements.map((announcement) => (
      <div class="column is-12">
        <div class="box">
          <article class="media">
            <div class="media-content">
              <div class="content">
                <div class="level">
                  <div class="level-left">
                    <div class="level-item">
                      <h3 class="title is-4">{announcement.title}</h3>
                    </div>
                  </div>
                  {isAdmin && (
                    <div class="level-right">
                      <div class="level-item">
                        <button 
                          class="button is-small is-warning edit-btn"
                          data-announcement-id={announcement.id}
                          data-announcement-title={announcement.title}
                          data-announcement-content={announcement.content}
                        >
                          <span class="icon is-small">
                            <i class="fas fa-edit"></i>
                          </span>
                          <span>Edit</span>
                        </button>
                      </div>
                      <div class="level-item">
                        <form method="POST" style="display: inline;">
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="announcementId" value={announcement.id} />
                          <button 
                            class="button is-small is-danger"
                            type="submit"
                            onclick="return confirm('Are you sure you want to delete this announcement?')"
                          >
                            <span class="icon is-small">
                              <i class="fas fa-trash"></i>
                            </span>
                            <span>Delete</span>
                          </button>
                        </form>
                      </div>
                    </div>
                  )}
                </div>
                <p style="white-space: pre-wrap;">{announcement.content}</p>
                <small>
                  Posted by {announcement.creatorName} on {new Date(announcement.createdAt).toLocaleDateString()}
                  {announcement.updatedAt.getTime() !== announcement.createdAt.getTime() && 
                    ` (edited ${new Date(announcement.updatedAt).toLocaleDateString()})`
                  }
                </small>
              </div>
            </div>
          </article>
        </div>
      </div>
    ))}
  </div>

  <!-- Edit Modal -->
  <div class="modal" id="edit-modal">
    <div class="modal-background"></div>
    <div class="modal-card">
      <header class="modal-card-head">
        <p class="modal-card-title">Edit Announcement</p>
        <button class="delete" aria-label="close" id="close-modal"></button>
      </header>
      <form method="POST">
        <section class="modal-card-body">
          <input type="hidden" name="action" value="edit" />
          <input type="hidden" name="announcementId" id="edit-announcement-id" />
          
          <div class="field">
            <label class="label" for="edit-title">Title</label>
            <div class="control">
              <input class="input" type="text" id="edit-title" name="title" required />
            </div>
          </div>

          <div class="field">
            <label class="label" for="edit-content">Content</label>
            <div class="control">
              <textarea class="textarea" id="edit-content" name="content" rows="5" required></textarea>
            </div>
          </div>
        </section>
        <footer class="modal-card-foot">
          <button class="button is-primary" type="submit">Save Changes</button>
          <button class="button" type="button" id="cancel-edit">Cancel</button>
        </footer>
      </form>
    </div>
  </div>

  <script>
    // Delete notification close button
    document.querySelectorAll('.notification .delete').forEach(($delete) => {
      const $notification = $delete.parentNode as HTMLElement;
      $delete.addEventListener('click', () => {
        $notification.remove();
      });
    });

    // Edit modal functionality
    const modal = document.getElementById('edit-modal') as HTMLElement;
    const closeModalBtn = document.getElementById('close-modal') as HTMLButtonElement;
    const cancelEditBtn = document.getElementById('cancel-edit') as HTMLButtonElement;
    const editBtns = document.querySelectorAll('.edit-btn');

    editBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const announcementId = btn.getAttribute('data-announcement-id');
        const title = btn.getAttribute('data-announcement-title');
        const content = btn.getAttribute('data-announcement-content');

        (document.getElementById('edit-announcement-id') as HTMLInputElement).value = announcementId || '';
        (document.getElementById('edit-title') as HTMLInputElement).value = title || '';
        (document.getElementById('edit-content') as HTMLTextAreaElement).value = content || '';

        modal.classList.add('is-active');
      });
    });

    const closeModal = () => {
      modal.classList.remove('is-active');
    };

    closeModalBtn?.addEventListener('click', closeModal);
    cancelEditBtn?.addEventListener('click', closeModal);
    modal.querySelector('.modal-background')?.addEventListener('click', closeModal);
  </script>
</Layout>
