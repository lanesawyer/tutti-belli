---
import EnsemblePageLayout from '../../../layouts/EnsemblePageLayout.astro';
import Table from '../../../components/Table.astro';
import Modal from '../../../components/Modal.astro';
import { db, eq, and, desc, Ensemble, EnsembleMember, Announcement, User } from 'astro:db';
import { canManageEnsemble } from '../../../lib/permissions';
import { sendAnnouncementEmail } from '../../../lib/email';
const user = Astro.locals.user!;

const { id } = Astro.params;

// Get the ensemble
const ensemble = await db
  .select()
  .from(Ensemble)
  .where(eq(Ensemble.id, id!))
  .get();

if (!ensemble) {
  return new Response('Ensemble not found', { status: 404 });
}

// Check if user is a member of this ensemble
const membership = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.userId, user.id)))
  .get();

if (!membership) {
  return new Response('Unauthorized - Not a member', { status: 403 });
}

const isAdmin = canManageEnsemble(user, membership);

let message = '';
let messageType = '';

// Handle form submission
if (Astro.request.method === 'POST') {
  if (!isAdmin) {
    return new Response('Unauthorized', { status: 403 });
  }

  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create') {
    const title = formData.get('title')?.toString();
    const content = formData.get('content')?.toString();

    if (!title || !title.trim() || !content || !content.trim()) {
      message = 'Title and content are required';
      messageType = 'danger';
    } else {
      await db.insert(Announcement).values({
        id: crypto.randomUUID(),
        ensembleId: id!,
        title: title.trim(),
        content: content.trim(),
        createdBy: user.id,
        createdAt: new Date(),
        updatedAt: new Date(),
      });

      const members = await db
        .select({ email: User.email, name: User.name })
        .from(EnsembleMember)
        .innerJoin(User, eq(EnsembleMember.userId, User.id))
        .where(and(eq(EnsembleMember.ensembleId, id!), eq(EnsembleMember.status, 'active')));

      sendAnnouncementEmail(
        members,
        ensemble.name,
        id!,
        title.trim(),
        content.trim(),
        user.name,
      ).catch(() => {});

      message = 'Announcement created successfully!';
      messageType = 'success';
    }
  } else if (action === 'edit') {
    const announcementId = formData.get('announcementId')?.toString();
    const title = formData.get('title')?.toString();
    const content = formData.get('content')?.toString();

    if (!announcementId || !title || !title.trim() || !content || !content.trim()) {
      message = 'Title and content are required';
      messageType = 'danger';
    } else {
      await db.update(Announcement)
        .set({ title: title.trim(), content: content.trim(), updatedAt: new Date() })
        .where(eq(Announcement.id, announcementId));
      message = 'Announcement updated successfully!';
      messageType = 'success';
    }
  } else if (action === 'delete') {
    const announcementId = formData.get('announcementId')?.toString();
    if (announcementId) {
      await db.delete(Announcement).where(eq(Announcement.id, announcementId));
      message = 'Announcement deleted successfully!';
      messageType = 'success';
    }
  }
}

// Get all announcements for this ensemble
const announcements = await db
  .select({
    id: Announcement.id,
    title: Announcement.title,
    content: Announcement.content,
    createdAt: Announcement.createdAt,
    updatedAt: Announcement.updatedAt,
    creatorName: User.name,
  })
  .from(Announcement)
  .innerJoin(User, eq(Announcement.createdBy, User.id))
  .where(eq(Announcement.ensembleId, id!))
  .orderBy(desc(Announcement.createdAt));
---

<EnsemblePageLayout
  title={`Announcements - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={id!}
  pageTitle="Announcements"
  message={message}
  messageType={messageType}
>
  {isAdmin && (
    <button slot="action" class="button is-primary" id="create-announcement-btn">
      <span class="icon"><i class="fas fa-plus"></i></span>
      <span>New Announcement</span>
    </button>
  )}

  {announcements.length === 0 ? (
    <div class="notification is-info is-light">
      No announcements yet.
      {isAdmin && ' Click "New Announcement" to post one.'}
    </div>
  ) : (
    <Table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Posted By</th>
          <th>Date</th>
          {isAdmin && <th style="width: 110px;">Actions</th>}
        </tr>
      </thead>
      <tbody>
        {announcements.map((announcement) => (
          <tr>
            <td>
              <strong>{announcement.title}</strong>
              <p class="has-text-grey is-size-7 mt-1" style="white-space: pre-wrap; max-width: 500px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                {announcement.content}
              </p>
            </td>
            <td>{announcement.creatorName}</td>
            <td>
              {new Date(announcement.createdAt).toLocaleDateString()}
              {announcement.updatedAt.getTime() !== announcement.createdAt.getTime() && (
                <span class="tag is-light is-small ml-1">edited</span>
              )}
            </td>
            {isAdmin && (
              <td>
                <div class="buttons are-small">
                  <button
                    class="button is-warning edit-announcement-btn"
                    data-announcement-id={announcement.id}
                    data-announcement-title={announcement.title}
                    data-announcement-content={announcement.content}
                  >
                    <span class="icon"><i class="fas fa-edit"></i></span>
                  </button>
                  <button
                    class="button is-danger delete-announcement-btn"
                    data-announcement-id={announcement.id}
                  >
                    <span class="icon"><i class="fas fa-trash"></i></span>
                  </button>
                </div>
              </td>
            )}
          </tr>
        ))}
      </tbody>
    </Table>
  )}

  <Fragment slot="modals">
<!-- Create Announcement Modal -->
{isAdmin && (
  <Modal id="create-modal" title="New Announcement">
    <form id="createForm" method="POST">
      <input type="hidden" name="action" value="create" />

      <div class="field">
        <label class="label" for="create-title">Title *</label>
        <div class="control">
          <input class="input" type="text" id="create-title" name="title" required />
        </div>
      </div>

      <div class="field">
        <label class="label" for="create-content">Content *</label>
        <div class="control">
          <textarea class="textarea" id="create-content" name="content" rows="6" required></textarea>
        </div>
      </div>
    </form>

    <div slot="footer">
      <button type="submit" form="createForm" class="button is-primary">
        <span class="icon"><i class="fas fa-bullhorn"></i></span>
        <span>Post Announcement</span>
      </button>
      <button class="button" type="button" data-modal-close>Cancel</button>
    </div>
  </Modal>
)}

<!-- Edit Announcement Modal -->
{isAdmin && (
  <Modal id="edit-modal" title="Edit Announcement">
    <form id="editForm" method="POST">
      <input type="hidden" name="action" value="edit" />
      <input type="hidden" name="announcementId" id="edit-announcement-id" />

      <div class="field">
        <label class="label" for="edit-title">Title *</label>
        <div class="control">
          <input class="input" type="text" id="edit-title" name="title" required />
        </div>
      </div>

      <div class="field">
        <label class="label" for="edit-content">Content *</label>
        <div class="control">
          <textarea class="textarea" id="edit-content" name="content" rows="6" required></textarea>
        </div>
      </div>
    </form>

    <div slot="footer">
      <button type="submit" form="editForm" class="button is-primary">Save Changes</button>
      <button class="button" type="button" data-modal-close>Cancel</button>
    </div>
  </Modal>
)}

<!-- Delete Confirmation Modal -->
{isAdmin && (
  <Modal id="delete-modal" title="Delete Announcement">
    <p>Are you sure you want to delete this announcement? This action cannot be undone.</p>
    <form id="deleteForm" method="POST">
      <input type="hidden" name="action" value="delete" />
      <input type="hidden" name="announcementId" id="delete-announcement-id" />
    </form>

    <div slot="footer">
      <button type="submit" form="deleteForm" class="button is-danger">Delete</button>
      <button class="button" type="button" data-modal-close>Cancel</button>
    </div>
  </Modal>
)}

<script is:inline>
  document.getElementById('create-announcement-btn')?.addEventListener('click', () => {
    document.getElementById('create-modal')?.classList.add('is-active');
  });

  document.querySelectorAll('.edit-announcement-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('edit-announcement-id').value = btn.getAttribute('data-announcement-id');
      document.getElementById('edit-title').value = btn.getAttribute('data-announcement-title');
      document.getElementById('edit-content').value = btn.getAttribute('data-announcement-content');
      document.getElementById('edit-modal')?.classList.add('is-active');
    });
  });

  document.querySelectorAll('.delete-announcement-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('delete-announcement-id').value = btn.getAttribute('data-announcement-id');
      document.getElementById('delete-modal')?.classList.add('is-active');
    });
  });
</script>
  </Fragment>
</EnsemblePageLayout>
