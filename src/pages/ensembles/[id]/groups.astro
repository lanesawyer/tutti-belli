---
import EnsemblePageLayout from "@layouts/EnsemblePageLayout.astro";
import Table from "@components/elements/Table.astro";
import Modal from "@components/Modal.astro";
import Button from "@components/elements/Button.astro";
import Icon from "@components/elements/Icon.astro";
import TextInput from "@components/forms/TextInput.astro";
import Select from "@components/forms/Select.astro";
import Checkbox from "@components/forms/Checkbox.astro";
import Notification from "@components/elements/Notification.astro";
import Tag from "@components/elements/Tag.astro";
import type { Color } from "@lib/bulma";
import { actions } from "astro:actions";
import { getEnsembleBySlugOrId, getEnsembleAccess } from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";
import {
  getEnsembleGroups,
  getGroupMembershipsWithUsers,
  getEnsembleMembersBasic,
} from "@lib/groups";

const user = Astro.locals.user!;

const { id } = Astro.params;
const ensemble = await getEnsembleBySlugOrId(id!);

if (!ensemble) {
  return new Response("Ensemble not found", { status: 404 });
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(
    Astro.url.pathname.replace(`/ensembles/${id}`, `/ensembles/${canonicalId}`),
    301,
  );
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access)
  return new Response("Unauthorized - Not a member", { status: 403 });
const { isAdmin } = access;

const createResult = Astro.getActionResult(actions.groups.create);
const updateResult = Astro.getActionResult(actions.groups.update);
const deleteResult = Astro.getActionResult(actions.groups.delete);

let message = "";
let messageType: "success" | "danger" | undefined;

if (createResult?.error) {
  message = createResult.error.message ?? "Failed to create group.";
  messageType = "danger";
} else if (createResult) {
  message = "Group created successfully!";
  messageType = "success";
} else if (updateResult?.error) {
  message = updateResult.error.message ?? "Failed to update group.";
  messageType = "danger";
} else if (updateResult) {
  message = "Group updated successfully!";
  messageType = "success";
} else if (deleteResult?.error) {
  message = deleteResult.error.message ?? "Failed to delete group.";
  messageType = "danger";
} else if (deleteResult) {
  message = "Group deleted successfully!";
  messageType = "success";
}

const groups = await getEnsembleGroups(ensemble.id);
const allMembers = await getEnsembleMembersBasic(ensemble.id);
const groupMemberships = await getGroupMembershipsWithUsers(ensemble.id);

const membershipsByGroupId = groupMemberships.reduce(
  (acc, m) => {
    if (!acc[m.groupId]) acc[m.groupId] = [];
    acc[m.groupId].push(m);
    return acc;
  },
  {} as Record<string, typeof groupMemberships>,
);

const colorOptions = [
  { value: "primary", label: "Primary (Turquoise)" },
  { value: "link", label: "Link (Blue)" },
  { value: "info", label: "Info (Cyan)" },
  { value: "success", label: "Success (Green)" },
  { value: "warning", label: "Warning (Yellow)" },
  { value: "danger", label: "Danger (Red)" },
];
---

<EnsemblePageLayout
  title={`Groups - ${ensemble.name}`}
  ensembleName={ensemble.name}
  ensembleId={canonicalId}
  pageTitle="Groups"
  pageSubtitle="Organize members into groups for better management"
  message={message}
  messageType={messageType}
  isAdmin={isAdmin}
>
  {
    isAdmin && (
      <Button slot="action" color="primary" id="create-group-btn">
        <Icon icon="fa-plus" />
        <span>Create Group</span>
      </Button>
    )
  }

  {
    groups.length === 0 ? (
      <Notification color="info" light>
        No groups yet. {isAdmin && "Create one to organize your members!"}
      </Notification>
    ) : (
      <Table
        columns={[
          "Name",
          "Description",
          "Members",
          isAdmin && { label: "Actions", style: "width: 160px;" },
        ]}
      >
        <tbody>
          {groups.map((group) => {
            const members = membershipsByGroupId[group.id] || [];
            const leads = members.filter((m) => m.role === "lead");
            const regulars = members.filter((m) => m.role !== "lead");
            return (
              <tr>
                <td>
                  <Tag color={group.color as Color} class="mr-2">
                    {group.name}
                  </Tag>
                </td>
                <td>{group.description || "-"}</td>
                <td>
                  {members.length > 0 ? (
                    <div>
                      {leads.length > 0 && (
                        <div class="tags are-small mb-1">
                          {leads.map((m) => (
                            <Tag color="warning">
                              <Icon icon="fa-star is-size-7 mr-1" />
                              {m.userName}
                            </Tag>
                          ))}
                        </div>
                      )}
                      {regulars.length > 0 && (
                        <div class="tags are-small">
                          {regulars.map((m) => (
                            <Tag>{m.userName}</Tag>
                          ))}
                        </div>
                      )}
                    </div>
                  ) : (
                    <span class="has-text-grey-light is-italic">None</span>
                  )}
                </td>
                {isAdmin && (
                  <td>
                    <div class="buttons are-small">
                      <Button
                        color="info"
                        class="manage-members-btn"
                        data-group-id={group.id}
                      >
                        <Icon icon="fa-users" />
                      </Button>
                      <Button
                        color="warning"
                        class="edit-group-btn"
                        data-group-id={group.id}
                        data-group-name={group.name}
                        data-group-description={group.description || ""}
                        data-group-color={group.color}
                      >
                        <Icon icon="fa-edit" />
                      </Button>
                      <Button
                        color="danger"
                        class="delete-group-btn"
                        data-group-id={group.id}
                      >
                        <Icon icon="fa-trash" />
                      </Button>
                    </div>
                  </td>
                )}
              </tr>
            );
          })}
        </tbody>
      </Table>
    )
  }

  <Fragment slot="modals">
    <!-- Create Group Modal -->
    {
      isAdmin && (
        <Modal id="create-modal" title="Create Group">
          <form id="createForm" method="POST" action={actions.groups.create}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />

            <TextInput
              name="name"
              id="create-name"
              label="Group Name *"
              placeholder="e.g., Section Leaders, Board Members"
              required
            />

            <div class="field">
              <label class="label" for="create-description">
                Description
              </label>
              <div class="control">
                <textarea
                  class="textarea"
                  id="create-description"
                  name="description"
                  placeholder="Optional description of the group's purpose"
                  rows="3"
                />
              </div>
            </div>

            <Select
              id="create-color"
              name="color"
              label="Badge Color"
              fullwidth
            >
              {colorOptions.map((option) => (
                <option value={option.value} selected={option.value === "info"}>
                  {option.label}
                </option>
              ))}
            </Select>
          </form>

          <div slot="footer">
            <Button type="submit" form="createForm" color="primary">
              Create Group
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Edit Group Modal -->
    {
      isAdmin && (
        <Modal id="edit-modal" title="Edit Group">
          <form id="editForm" method="POST" action={actions.groups.update}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="groupId" id="edit-groupId" />

            <TextInput
              name="name"
              id="edit-name"
              label="Group Name *"
              required
            />

            <div class="field">
              <label class="label" for="edit-description">
                Description
              </label>
              <div class="control">
                <textarea
                  class="textarea"
                  id="edit-description"
                  name="description"
                  rows="3"
                />
              </div>
            </div>

            <Select id="edit-color" name="color" label="Badge Color" fullwidth>
              {colorOptions.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </Select>
          </form>

          <div slot="footer">
            <Button type="submit" form="editForm" color="primary">
              Save Changes
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Manage Members Modal -->
    {
      isAdmin && (
        <Modal id="members-modal" title="Manage Group Members">
          <input type="hidden" id="members-groupId" />
          <p class="mb-3">
            Select which members belong to this group and assign roles:
          </p>
          {allMembers.map((member) => (
            <div class="field">
              <div class="is-flex is-align-items-center" style="gap: 0.75rem;">
                <Checkbox
                  name="member"
                  class="member-checkbox"
                  data-user-id={member.id}
                  label={member.name}
                  standalone
                />
                <span class="member-role-select" style="display: none;">
                  <Select name="role" standalone size="small">
                    <option value="">Member</option>
                    <option value="lead">Lead</option>
                  </Select>
                </span>
              </div>
            </div>
          ))}

          <div slot="footer">
            <Button type="button" id="close-members-btn">
              Done
            </Button>
          </div>
        </Modal>
      )
    }

    <!-- Delete Confirmation Modal -->
    {
      isAdmin && (
        <Modal id="delete-modal" title="Delete Group">
          <p>
            Are you sure you want to delete this group? This action cannot be
            undone.
          </p>
          <form id="deleteForm" method="POST" action={actions.groups.delete}>
            <input type="hidden" name="ensembleId" value={ensemble.id} />
            <input type="hidden" name="groupId" id="delete-groupId" />
          </form>

          <div slot="footer">
            <Button type="submit" form="deleteForm" color="danger">
              Delete Group
            </Button>
            <Button type="button" data-modal-close>
              Cancel
            </Button>
          </div>
        </Modal>
      )
    }

    <script is:inline define:vars={{ membershipsByGroupId, ensembleId: ensemble.id }}>
      document.addEventListener("astro:page-load", () => {
        document
          .getElementById("create-group-btn")
          ?.addEventListener("click", () => {
            document.getElementById("create-modal")?.classList.add("is-active");
          });

        document.querySelectorAll(".edit-group-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("edit-groupId").value =
              btn.getAttribute("data-group-id");
            document.getElementById("edit-name").value =
              btn.getAttribute("data-group-name");
            document.getElementById("edit-description").value =
              btn.getAttribute("data-group-description");
            document.getElementById("edit-color").value =
              btn.getAttribute("data-group-color");
            document.getElementById("edit-modal")?.classList.add("is-active");
          });
        });

        document.querySelectorAll(".manage-members-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            const groupId = btn.getAttribute("data-group-id");
            document.getElementById("members-groupId").value = groupId;

            const groupMembers = membershipsByGroupId[groupId] || [];
            const memberMap = new Map(groupMembers.map((m) => [m.userId, m]));

            document
              .querySelectorAll(".member-checkbox")
              .forEach((checkbox) => {
                const userId = checkbox.getAttribute("data-user-id");
                const membership = memberMap.get(userId);
                checkbox.querySelector("input").checked = !!membership;

                const roleSelect = checkbox
                  .closest(".is-flex")
                  ?.querySelector(".member-role-select");
                if (roleSelect) {
                  if (membership) {
                    roleSelect.style.display = "";
                    roleSelect.querySelector("select").value =
                      membership.role || "";
                  } else {
                    roleSelect.style.display = "none";
                    roleSelect.querySelector("select").value = "";
                  }
                }
              });

            document
              .getElementById("members-modal")
              ?.classList.add("is-active");
          });
        });

        document.querySelectorAll(".member-checkbox").forEach((checkbox) => {
          checkbox.addEventListener("change", async () => {
            const groupId = document.getElementById("members-groupId").value;
            const userId = checkbox.getAttribute("data-user-id");
            const roleSelect = checkbox
              .closest(".is-flex")
              ?.querySelector(".member-role-select");

            const formData = new FormData();
            formData.append("ensembleId", ensembleId);
            formData.append("groupId", groupId);
            formData.append("userId", userId);

            await fetch("/_actions/groups.toggleMember", { method: "POST", body: formData });

            if (roleSelect) {
              if (checkbox.querySelector("input").checked) {
                roleSelect.style.display = "";
                roleSelect.querySelector("select").value = "";
              } else {
                roleSelect.style.display = "none";
                roleSelect.querySelector("select").value = "";
              }
            }
          });
        });

        document.querySelectorAll(".member-role-select").forEach((wrapper) => {
          wrapper
            .querySelector("select")
            .addEventListener("change", async (e) => {
              const groupId = document.getElementById("members-groupId").value;
              const userId = wrapper
                .closest(".is-flex")
                ?.querySelector(".member-checkbox")
                ?.getAttribute("data-user-id");
              const role = e.target.value;

              const formData = new FormData();
              formData.append("ensembleId", ensembleId);
              formData.append("groupId", groupId);
              formData.append("userId", userId);
              formData.append("role", role);

              await fetch("/_actions/groups.setMemberRole", { method: "POST", body: formData });
            });
        });

        document
          .getElementById("close-members-btn")
          ?.addEventListener("click", () => {
            document
              .getElementById("members-modal")
              ?.classList.remove("is-active");
            window.location.reload();
          });

        document.querySelectorAll(".delete-group-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.getElementById("delete-groupId").value =
              btn.getAttribute("data-group-id");
            document.getElementById("delete-modal")?.classList.add("is-active");
          });
        });
      });
    </script>
  </Fragment>
</EnsemblePageLayout>
