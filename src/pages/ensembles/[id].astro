---
import Layout from '../../layouts/Layout.astro';
import InviteCodeWidget from '../../components/InviteCodeWidget.astro';
import DashboardSection from '../../components/DashboardSection.astro';
import { db, eq, and, desc, EnsembleMember, User, EnsembleInvite, Part, Announcement, Group, GroupMembership, Event, Season, SeasonMembership, SeasonSong, Song, EnsembleLink } from 'astro:db';
import { canManageEnsemble } from '../../lib/permissions';
import { getInitials, getColorFromInitials } from '../../lib/avatar';
import { ensembleAdminTools } from '../../lib/config';
import { getEnsembleBySlugOrId } from '../../lib/ensemble';
import { getEnsembleUrlId } from '../../lib/slug';

const user = Astro.locals.user!;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/ensembles');
}

const ensemble = await getEnsembleBySlugOrId(id);
if (!ensemble) {
  return Astro.redirect('/ensembles');
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === 'GET' && id !== canonicalId) {
  return Astro.redirect(`/ensembles/${canonicalId}`, 301);
}

// Check if user is a member
const [membership] = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, ensemble.id), eq(EnsembleMember.userId, user.id)));

if (!membership) {
  return Astro.redirect('/ensembles');
}

const isAdmin = canManageEnsemble(user, membership);
const isPending = membership.status === 'pending';

// Get the current active season
const [currentSeason] = await db
  .select()
  .from(Season)
  .where(and(
    eq(Season.ensembleId, ensemble.id),
    eq(Season.isActive, 1)
  ));

// Get all active members with their parts
const membersData = await db
  .select({
    id: User.id,
    name: User.name,
    email: User.email,
    avatarUrl: User.avatarUrl,
    role: EnsembleMember.role,
    status: EnsembleMember.status,
    joinedAt: EnsembleMember.joinedAt,
    membershipId: EnsembleMember.id,
    partId: EnsembleMember.partId,
  })
  .from(EnsembleMember)
  .innerJoin(User, eq(EnsembleMember.userId, User.id))
  .where(and(eq(EnsembleMember.ensembleId, ensemble.id), eq(EnsembleMember.status, 'active')));

// Get pending members (for admins)
const pendingMembers = isAdmin ? await db
  .select({
    id: User.id,
    name: User.name,
    email: User.email,
    avatarUrl: User.avatarUrl,
    joinedAt: EnsembleMember.joinedAt,
    membershipId: EnsembleMember.id,
  })
  .from(EnsembleMember)
  .innerJoin(User, eq(EnsembleMember.userId, User.id))
  .where(and(eq(EnsembleMember.ensembleId, ensemble.id), eq(EnsembleMember.status, 'pending')))
  : [];

// Get all parts for this ensemble
const allParts = await db
  .select()
  .from(Part)
  .where(eq(Part.ensembleId, ensemble.id))
  .all();

// Sort parts by sortOrder
allParts.sort((a, b) => a.sortOrder - b.sortOrder);

// Group members by part
const membersByPart = new Map();
const membersWithoutPart = [];

for (const member of membersData) {
  if (member.partId) {
    if (!membersByPart.has(member.partId)) {
      membersByPart.set(member.partId, []);
    }
    membersByPart.get(member.partId).push(member);
  } else {
    membersWithoutPart.push(member);
  }
}

// For backwards compatibility, keep members array
const members = membersData;

// Get all groups for this ensemble
const groups = await db
  .select()
  .from(Group)
  .where(eq(Group.ensembleId, ensemble.id))
  .all();

// Get all group memberships
const groupMemberships = await db
  .select({
    groupId: GroupMembership.groupId,
    userId: GroupMembership.userId,
  })
  .from(GroupMembership);

// Create a map of user groups for easy lookup
const userGroups = new Map();
for (const gm of groupMemberships) {
  if (!userGroups.has(gm.userId)) {
    userGroups.set(gm.userId, []);
  }
  const group = groups.find(g => g.id === gm.groupId);
  if (group) {
    userGroups.get(gm.userId).push(group);
  }
}

// Get latest announcements (limit to 3 most recent)
const latestAnnouncements = await db
  .select({
    id: Announcement.id,
    title: Announcement.title,
    content: Announcement.content,
    createdAt: Announcement.createdAt,
    creatorName: User.name,
  })
  .from(Announcement)
  .innerJoin(User, eq(Announcement.createdBy, User.id))
  .where(eq(Announcement.ensembleId, ensemble.id))
  .orderBy(desc(Announcement.createdAt))
  .limit(3);

// Get upcoming events
const allEvents = await db
  .select()
  .from(Event)
  .where(eq(Event.ensembleId, ensemble.id))
  .orderBy(Event.scheduledAt);

const now = new Date();
const upcomingRehearsals = allEvents
  .filter(e => {
    const endTime = new Date(new Date(e.scheduledAt).getTime() + (e.durationMinutes * 60 * 1000));
    return endTime > now && e.category === 'rehearsal';
  })
  .slice(0, 5);

const upcomingPerformances = allEvents
  .filter(e => {
    const endTime = new Date(new Date(e.scheduledAt).getTime() + (e.durationMinutes * 60 * 1000));
    return endTime > now && e.category === 'performance';
  })
  .slice(0, 5);

// Get songs for the active season
const seasonSongs = currentSeason ? await db
  .select({
    id: Song.id,
    name: Song.name,
    composer: Song.composer,
    arranger: Song.arranger,
    runTime: Song.runTime,
  })
  .from(SeasonSong)
  .innerJoin(Song, eq(SeasonSong.songId, Song.id))
  .where(eq(SeasonSong.seasonId, currentSeason.id))
  .orderBy(Song.name)
  : [];

// Get invite codes (if admin)
const invites = isAdmin
  ? await db
      .select()
      .from(EnsembleInvite)
      .where(eq(EnsembleInvite.ensembleId, ensemble.id))
  : [];

// Get ensemble links
const ensembleLinks = await db
  .select()
  .from(EnsembleLink)
  .where(eq(EnsembleLink.ensembleId, ensemble.id))
  .orderBy(EnsembleLink.sortOrder, EnsembleLink.createdAt);

// Handle member actions
if (Astro.request.method === 'POST') {
  if (!isAdmin) {
    return new Response('Unauthorized', { status: 403 });
  }

  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create-invite') {
    // Generate random 8-character code
    const code = Math.random().toString(36).substring(2, 10).toUpperCase();
    await db.insert(EnsembleInvite).values({
      id: crypto.randomUUID(),
      ensembleId: ensemble.id,
      code,
      createdBy: user.id,
    });
    return Astro.redirect(`/ensembles/${canonicalId}`);
  } else if (action === 'approve-member') {
    const membershipId = formData.get('membershipId')?.toString();
    if (membershipId) {
      // Get the membership to find the userId
      const [membership] = await db
        .select()
        .from(EnsembleMember)
        .where(eq(EnsembleMember.id, membershipId));

      if (membership) {
        // Update member status to active
        await db
          .update(EnsembleMember)
          .set({ status: 'active' })
          .where(eq(EnsembleMember.id, membershipId));

        // Check if there's an active season and add the member to it
        const [activeSeason] = await db
          .select()
          .from(Season)
          .where(and(
            eq(Season.ensembleId, ensemble.id),
            eq(Season.isActive, 1)
          ));
        
        if (activeSeason) {
          // Check if they're not already in the season
          const [existingMembership] = await db
            .select()
            .from(SeasonMembership)
            .where(and(
              eq(SeasonMembership.seasonId, activeSeason.id),
              eq(SeasonMembership.userId, membership.userId)
            ));
          
          if (!existingMembership) {
            await db.insert(SeasonMembership).values({
              id: crypto.randomUUID(),
              seasonId: activeSeason.id,
              userId: membership.userId,
            });
          }
        }
      }
      
      return Astro.redirect(`/ensembles/${canonicalId}`);
    }
  } else if (action === 'reject-member') {
    const membershipId = formData.get('membershipId')?.toString();
    if (membershipId) {
      await db.delete(EnsembleMember).where(eq(EnsembleMember.id, membershipId));
      return Astro.redirect(`/ensembles/${canonicalId}`);
    }
  } else if (action === 'delete-invite') {
    const inviteId = formData.get('inviteId')?.toString();
    if (inviteId) {
      await db.delete(EnsembleInvite).where(eq(EnsembleInvite.id, inviteId));
      return Astro.redirect(`/ensembles/${canonicalId}`);
    }
  }
}
---

<Layout title={ensemble.name}>
  {isAdmin && (
    <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
      <a class="navbar-link">{ensemble.name}</a>
      <div class="navbar-dropdown">
        {ensembleAdminTools.map((tool) => {
          const href = tool.href(canonicalId);
          return (
            <a class={`navbar-item${Astro.url.pathname.startsWith(href) ? ' is-active' : ''}`} href={href}>
              <span class="icon is-small mr-1"><i class={`fas ${tool.icon}`}></i></span>
              {tool.label}
            </a>
          );
        })}
      </div>
    </div>
  )}
  <!-- Header Section - Full Width -->
  <div class="mb-5">
    <div class="level">
      <div class="level-left">
        <div class="level-item" style="align-items: flex-start;">
          {ensemble.imageUrl && (
            <figure class="image is-96x96 mr-4" style="flex-shrink: 0;">
              <img src={ensemble.imageUrl} alt={ensemble.name} style="object-fit: cover; border-radius: 8px; width: 96px; height: 96px;" />
            </figure>
          )}
          <div>
            <h1 class="title">{ensemble.name}</h1>
            {ensemble.description && (
              <p class="subtitle">{ensemble.description}</p>
            )}
            {currentSeason && (
              <p class="subtitle is-6 mt-2">
                <span class="icon-text">
                  <span class="icon has-text-info">
                    <i class="fas fa-calendar-alt"></i>
                  </span>
                  <span><strong>Current Season:</strong> {currentSeason.name}</span>
                </span>
              </p>
            )}
          </div>
        </div>
      </div>
      {!isPending && (ensemble.discordLink || ensembleLinks.length > 0) && (
        <div class="level-right">
          {ensemble.discordLink && (
            <div class="level-item">
              <a href={ensemble.discordLink} target="_blank" rel="noopener noreferrer" class="button is-link" title="Join Discord Server">
                <span class="icon">
                  <i class="fab fa-discord"></i>
                </span>
                <span>Discord</span>
              </a>
            </div>
          )}
          {ensembleLinks.map((link) => (
            <div class="level-item">
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="button is-light">
                <span class="icon">
                  <i class="fas fa-link"></i>
                </span>
                <span>{link.label}</span>
              </a>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  {isPending && (
    <div class="notification is-warning">
      <h2 class="title is-5">
        <span class="icon-text">
          <span class="icon">
            <i class="fas fa-hourglass-half"></i>
          </span>
          <span>Membership Pending Approval</span>
        </span>
      </h2>
      <p>Your request to join <strong>{ensemble.name}</strong> is awaiting approval from an ensemble administrator. You'll receive full access once your membership is approved.</p>
      <p class="mt-3"><strong>Joined:</strong> {new Date(membership.joinedAt).toLocaleDateString()}</p>
    </div>
  )}

  {!isPending && (
  <div class="columns">
    <div class={`column ${isAdmin ? 'is-9-desktop' : ''}`}>
      <!-- Announcements Section -->
      <DashboardSection
        title="Recent Announcements"
        viewAllHref={`/ensembles/${canonicalId}/announcements`}
        viewAllColor="is-link"
      >
        {latestAnnouncements.length === 0 ? (
          <div class="notification is-info is-light">
            <p class="has-text-centered">No announcements yet.</p>
            {isAdmin && (
              <p class="has-text-centered mt-2">
                <a href={`/ensembles/${canonicalId}/announcements`} class="button is-small is-link">
                  Create First Announcement
                </a>
              </p>
            )}
          </div>
        ) : (
          <div class="ann-carousel">
            <div class="ann-slides" style="height: 16rem; overflow-y: auto;">
              {latestAnnouncements.map((announcement, i) => (
                <div class="ann-slide" data-index={i} style={i === 0 ? '' : 'display:none'}>
                  <article class="message is-link" style="margin-bottom: 0;">
                    <div class="message-header">
                      <p>{announcement.title}</p>
                      <small class="has-text-weight-normal">
                        {new Date(announcement.createdAt).toLocaleDateString()}
                      </small>
                    </div>
                    <div class="message-body">
                      <p style="white-space: pre-wrap;">{announcement.content}</p>
                      <p class="mt-2">
                        <small><em>— {announcement.creatorName}</em></small>
                      </p>
                    </div>
                  </article>
                </div>
              ))}
              <div class="ann-slide" data-index={latestAnnouncements.length} style="display:none">
                <div class="has-text-centered" style="padding: 2rem 1rem;">
                  <p class="mb-4 has-text-grey">See all announcements from this ensemble.</p>
                  <a href={`/ensembles/${canonicalId}/announcements`} class="button is-link is-medium">
                    <span class="icon"><i class="fas fa-bullhorn"></i></span>
                    <span>View All Announcements</span>
                  </a>
                </div>
              </div>
            </div>

            <div class="ann-nav">
              <button class="ann-arrow" id="ann-prev" aria-label="Previous announcement">
                <i class="fas fa-chevron-left"></i>
              </button>
              <div class="ann-dots">
                {latestAnnouncements.map((_, i) => (
                  <button class="ann-dot" class:list={[{ 'ann-dot-active': i === 0 }]} data-target={i} aria-label={`Announcement ${i + 1}`}></button>
                ))}
                <button class="ann-dot ann-dot-viewall" data-target={latestAnnouncements.length} aria-label="View all"></button>
              </div>
              <button class="ann-arrow" id="ann-next" aria-label="Next announcement">
                <i class="fas fa-chevron-right"></i>
              </button>
            </div>
          </div>
        )}
      </DashboardSection>

      <!-- Upcoming Rehearsals Section -->
      <DashboardSection
        title="Upcoming Rehearsals"
        viewAllHref={`/ensembles/${canonicalId}/events`}
        viewAllColor="is-primary"
      >
        {upcomingRehearsals.length === 0 ? (
          <div class="notification is-info is-light">
            <p class="has-text-centered">No upcoming rehearsals.</p>
            {isAdmin && (
              <p class="has-text-centered mt-2">
                <a href={`/ensembles/${canonicalId}/events`} class="button is-small is-primary">
                  Schedule Event
                </a>
              </p>
            )}
          </div>
        ) : (
          <div class="content">
            {upcomingRehearsals.map((event) => {
              const scheduledDate = new Date(event.scheduledAt);
              const isToday = scheduledDate.toDateString() === new Date().toDateString();

              return (
                <article class={`message ${isToday ? 'is-success' : 'is-primary'}`}>
                  <div class="message-header">
                    <a href={`/ensembles/${canonicalId}/events/${event.id}`} class="has-text-white">
                      {event.title}
                      {isToday && <span class="tag is-light ml-2">Today</span>}
                    </a>
                    <small class="has-text-weight-normal">
                      {scheduledDate.toLocaleDateString()} at {scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </small>
                  </div>
                  <div class="message-body">
                    {event.location && (
                      <p class="mb-2">
                        <span class="icon-text">
                          <span class="icon">
                            <i class="fas fa-map-marker-alt"></i>
                          </span>
                          <span>{event.location}</span>
                        </span>
                      </p>
                    )}
                    {event.description && (
                      <p style="white-space: pre-wrap;">{event.description}</p>
                    )}
                    <p class="mt-2">
                      <small>Duration: {event.durationMinutes} minutes</small>
                    </p>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </DashboardSection>

      <!-- Upcoming Performances Section -->
      <DashboardSection
        title="Upcoming Performances"
        viewAllHref={`/ensembles/${canonicalId}/events`}
        viewAllColor="is-warning"
      >
        {upcomingPerformances.length === 0 ? (
          <div class="notification is-info is-light">
            <p class="has-text-centered">No upcoming performances.</p>
            {isAdmin && (
              <p class="has-text-centered mt-2">
                <a href={`/ensembles/${canonicalId}/events`} class="button is-small is-warning">
                  Schedule Performance
                </a>
              </p>
            )}
          </div>
        ) : (
          <div class="content">
            {upcomingPerformances.map((event) => {
              const scheduledDate = new Date(event.scheduledAt);
              const isToday = scheduledDate.toDateString() === new Date().toDateString();

              return (
                <article class={`message ${isToday ? 'is-success' : 'is-warning'}`}>
                  <div class="message-header">
                    <a href={`/ensembles/${canonicalId}/events/${event.id}`} class="has-text-white">
                      {event.title}
                      {isToday && <span class="tag is-light ml-2">Today</span>}
                    </a>
                    <small class="has-text-weight-normal">
                      {scheduledDate.toLocaleDateString()} at {scheduledDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </small>
                  </div>
                  <div class="message-body">
                    {event.location && (
                      <p class="mb-2">
                        <span class="icon-text">
                          <span class="icon">
                            <i class="fas fa-map-marker-alt"></i>
                          </span>
                          <span>{event.location}</span>
                        </span>
                      </p>
                    )}
                    {event.description && (
                      <p style="white-space: pre-wrap;">{event.description}</p>
                    )}
                    <p class="mt-2">
                      <small>Duration: {event.durationMinutes} minutes</small>
                    </p>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </DashboardSection>

      <!-- Season Songs Section -->
      {currentSeason && (
        <DashboardSection
          title={`${currentSeason.name} Repertoire`}
          viewAllHref={`/ensembles/${canonicalId}/songs`}
          viewAllColor="is-info"
        >
          {seasonSongs.length === 0 ? (
            <div class="notification is-info is-light">
              <p class="has-text-centered">No songs added to this season yet.</p>
              {isAdmin && (
                <p class="has-text-centered mt-2">
                  <a href={`/ensembles/${canonicalId}/songs`} class="button is-small is-info">
                    Add Songs
                  </a>
                </p>
              )}
            </div>
          ) : (
            <table class="table is-fullwidth is-hoverable">
              <tbody>
                {seasonSongs.map((song) => {
                  const minutes = song.runTime ? Math.floor(song.runTime / 60) : null;
                  const seconds = song.runTime ? String(song.runTime % 60).padStart(2, '0') : null;
                  return (
                    <tr>
                      <td>
                        <a href={`/ensembles/${canonicalId}/songs/${song.id}`} class="has-text-weight-semibold">{song.name}</a>
                        <p class="is-size-7 has-text-grey">
                          {song.composer ?? 'Unknown'}
                          {song.arranger && ` — arr. ${song.arranger}`}
                        </p>
                      </td>
                      <td class="has-text-right has-text-grey is-size-7" style="vertical-align: middle; white-space: nowrap;">
                        {minutes !== null ? `${minutes}:${seconds}` : ''}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          )}
        </DashboardSection>
      )}

      <DashboardSection
        title={`Members (${members.length})`}
        viewAllHref={isAdmin ? `/ensembles/${canonicalId}/members` : undefined}
        viewAllLabel="View All"
        viewAllColor="is-warning"
        class="mb-0"
      >
        
        {allParts.length > 0 ? (
          <>
            {allParts.map((part) => {
              const partMembers = membersByPart.get(part.id) || [];
              if (partMembers.length === 0) return null;
              
              return (
                <div class="mb-5">
                  <h3 class="title is-5 has-text-primary mb-3">{part.name} ({partMembers.length})</h3>
                  <div class="columns is-multiline">
                    {partMembers.map((member: any) => (
                      <div class="column is-6-tablet is-4-desktop is-3-widescreen">
                        <div class="card">
                          <div class="card-content has-text-centered">
                            <figure class="image is-96x96 mx-auto mb-3">
                              {member.avatarUrl ? (
                                <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                              ) : (
                                <div style={`width: 96px; height: 96px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; font-weight: bold;`}>
                                  {getInitials(member.name)}
                                </div>
                              )}
                            </figure>
                            <p class="title is-6 mb-2">{member.name}</p>
                            <p class="subtitle is-7 has-text-grey mb-2">{part.name}</p>
                            {userGroups.has(member.id) && (
                              <div class="tags are-small is-justify-content-center mt-2">
                                {userGroups.get(member.id).map((group: any) => (
                                  <span class={`tag is-${group.color}`} title={group.description || group.name}>
                                    {group.name}
                                  </span>
                                ))}
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}

            {membersWithoutPart.length > 0 && (
              <div class="mb-5">
                <h3 class="title is-5 has-text-grey mb-3">No Part Assigned ({membersWithoutPart.length})</h3>
                <div class="columns is-multiline">
                  {membersWithoutPart.map((member) => (
                    <div class="column is-6-tablet is-4-desktop is-3-widescreen">
                      <div class="card">
                        <div class="card-content has-text-centered">
                          <figure class="image is-96x96 mx-auto mb-3">
                            {member.avatarUrl ? (
                              <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                            ) : (
                              <div style={`width: 96px; height: 96px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; font-weight: bold;`}>
                                {getInitials(member.name)}
                              </div>
                            )}
                          </figure>
                          <p class="title is-6 mb-2">{member.name}</p>
                          <p class="subtitle is-7 has-text-grey mb-2">No part assigned</p>
                          {userGroups.has(member.id) && (
                            <div class="tags are-small is-justify-content-center mt-2">
                              {userGroups.get(member.id).map((group: any) => (
                                <span class={`tag is-${group.color}`} title={group.description || group.name}>
                                  {group.name}
                                </span>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <div class="columns is-multiline">
            {members.map((member) => (
              <div class="column is-6-tablet is-4-desktop is-3-widescreen">
                <div class="card">
                  <div class="card-content has-text-centered">
                    <figure class="image is-96x96 mx-auto mb-3">
                      {member.avatarUrl ? (
                        <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                      ) : (
                        <div style={`width: 96px; height: 96px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; font-weight: bold;`}>
                          {getInitials(member.name)}
                        </div>
                      )}
                    </figure>
                    <p class="title is-6 mb-2">{member.name}</p>
                    {userGroups.has(member.id) && (
                      <div class="tags are-small is-justify-content-center mt-2">
                        {userGroups.get(member.id).map((group: any) => (
                          <span class={`tag is-${group.color}`} title={group.description || group.name}>
                            {group.name}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </DashboardSection>

      <a href="/ensembles" class="button">
        <span class="icon">
          <i class="fas fa-arrow-left"></i>
        </span>
        <span>Back to Ensembles</span>
      </a>
    </div>

    <!-- Admin Sidebar -->
    {isAdmin && (
      <div class="column is-3-desktop">
        <div class="box mb-5">
          <h2 class="title is-5 mb-4">
            <span class="icon-text">
              <span class="icon">
                <i class="fas fa-cog"></i>
              </span>
              <span>Admin Tools</span>
            </span>
          </h2>
          
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;">
            {ensembleAdminTools.map((tool) => (
              <a href={tool.href(id!)} class="button" style="height: auto; padding: 0.75rem 0.25rem; flex-direction: column; align-items: center; justify-content: center;">
                <i class={`fas ${tool.icon} fa-lg mb-1`}></i>
                <span class="is-size-7">{tool.label}</span>
              </a>
            ))}
          </div>
        </div>

        {pendingMembers.length > 0 && (
          <div class="box mb-5">
            <h2 class="title is-5 mb-4">
              <span class="icon-text">
                <span class="icon has-text-warning">
                  <i class="fas fa-user-clock"></i>
                </span>
                <span>Pending Members ({pendingMembers.length})</span>
              </span>
            </h2>
            <p class="mb-4 is-size-7">These members are awaiting approval to join the ensemble</p>
            
            <div class="content">
              {pendingMembers.map((member) => (
                <div class="box p-2 mb-2">
                  <div class="media">
                    <div class="media-left">
                      <figure class="image is-32x32">
                        {member.avatarUrl ? (
                          <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                        ) : (
                          <div style={`width: 32px; height: 32px; border-radius: 50%; background-color: ${getColorFromInitials(getInitials(member.name))}; display: flex; align-items: center; justify-content: center; color: white; font-size: 0.75rem; font-weight: bold;`}>
                            {getInitials(member.name)}
                          </div>
                        )}
                      </figure>
                    </div>
                    <div class="media-content">
                      <p class="is-size-7 has-text-weight-semibold">{member.name}</p>
                      <p class="is-size-7 has-text-grey">{member.email}</p>
                      <p class="is-size-7 has-text-grey-light">
                        <small>Applied {new Date(member.joinedAt).toLocaleDateString()}</small>
                      </p>
                    </div>
                  </div>
                  <div class="buttons are-small mt-2">
                    <form method="POST" style="display: inline; width: 48%;">
                      <input type="hidden" name="action" value="approve-member" />
                      <input type="hidden" name="membershipId" value={member.membershipId} />
                      <button type="submit" class="button is-success is-small is-fullwidth">
                        <span class="icon">
                          <i class="fas fa-check"></i>
                        </span>
                        <span>Approve</span>
                      </button>
                    </form>
                    <form method="POST" style="display: inline; width: 48%;">
                      <input type="hidden" name="action" value="reject-member" />
                      <input type="hidden" name="membershipId" value={member.membershipId} />
                      <button type="submit" class="button is-danger is-small is-fullwidth">
                        <span class="icon">
                          <i class="fas fa-times"></i>
                        </span>
                        <span>Reject</span>
                      </button>
                    </form>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <InviteCodeWidget invites={invites} />
      </div>
    )}
  </div>
  )}
</Layout>

<style>
  .ann-carousel { position: relative; }
  .ann-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 0.875rem;
  }
  .ann-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid #dbdbdb;
    background: transparent;
    cursor: pointer;
    color: inherit;
    transition: background 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .ann-arrow:hover { background: #f5f5f5; border-color: #b5b5b5; }
  .ann-arrow:disabled { opacity: 0.35; cursor: default; }
  .ann-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .ann-dot {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #dbdbdb;
    border: none;
    cursor: pointer;
    padding: 0;
    /* larger hit area without changing visual size */
    box-shadow: 0 0 0 6px transparent;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .ann-dot:hover { box-shadow: 0 0 0 6px #f0f0f0; }
  .ann-dot-viewall {
    border-radius: 50%;
    width: 14px;
  }
  .ann-dot-active { background: #3273dc; }
</style>

<script>
  document.querySelectorAll('.ann-carousel').forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.ann-slide'));
    const dots = Array.from(carousel.querySelectorAll<HTMLElement>('.ann-dot'));
    const prevBtn = carousel.querySelector<HTMLButtonElement>('#ann-prev');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('#ann-next');
    let current = 0;

    function goTo(index: number) {
      current = index;
      slides.forEach((slide, i) => { slide.style.display = i === current ? '' : 'none'; });
      dots.forEach((d) => d.classList.remove('ann-dot-active'));
      dots[current]?.classList.add('ann-dot-active');
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === slides.length - 1;
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    prevBtn?.addEventListener('click', () => goTo(Math.max(0, current - 1)));
    nextBtn?.addEventListener('click', () => goTo(Math.min(slides.length - 1, current + 1)));

    goTo(0);
  });
</script>
