---
import Layout from "@layouts/Layout.astro";
import InviteCodeWidget from "@containers/InviteCodeWidget.astro";
import PendingMembers from "@containers/PendingMembers.astro";
import Button from "@components/elements/Button.astro";
import Image from "@components/elements/Image.astro";
import Icon from "@components/elements/Icon.astro";
import Notification from "@components/elements/Notification.astro";
import RecentAnnouncements from "@containers/RecentAnnouncements.astro";
import UpcomingEvents from "@containers/UpcomingEvents.astro";
import EnsembleMembers from "@containers/EnsembleMembers.astro";
import SeasonRepertoire from "@containers/SeasonRepertoire.astro";
import EnsembleLinks from "@containers/EnsembleLinks.astro";
import MyTasks from "@containers/MyTasks.astro";
import AdminTools from "@containers/AdminTools.astro";
import { db, eq, and, Season } from "astro:db";
import { ensembleAdminTools } from "@lib/config";
import { getEnsembleBySlugOrId, getEnsembleAccess } from "@lib/ensemble";
import { getEnsembleUrlId } from "@lib/slug";

const user = Astro.locals.user!;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/ensembles");
}

const ensemble = await getEnsembleBySlugOrId(id);
if (!ensemble) {
  return Astro.redirect("/ensembles");
}

const canonicalId = getEnsembleUrlId(ensemble);
if (Astro.request.method === "GET" && id !== canonicalId) {
  return Astro.redirect(`/ensembles/${canonicalId}`, 301);
}

const access = await getEnsembleAccess(user, ensemble.id);
if (!access) return Astro.redirect("/ensembles");
const { membership, isAdmin } = access;
const isPending = !isAdmin && membership?.status === "pending";

// Get the current active season
const [currentSeason] = await db
  .select()
  .from(Season)
  .where(and(eq(Season.ensembleId, ensemble.id), eq(Season.isActive, 1)));
---

<Layout title={ensemble.name}>
  {
    isAdmin && (
      <div class="navbar-item has-dropdown is-hoverable" slot="navbar-start">
        <a class="navbar-link">{ensemble.name}</a>
        <div class="navbar-dropdown">
          {ensembleAdminTools.map((tool) => {
            const href = tool.href(canonicalId);
            return (
              <a
                class={`navbar-item${Astro.url.pathname.startsWith(href) ? " is-active" : ""}`}
                href={href}
              >
                <Icon icon={tool.icon} size="small" class="mr-1" />
                {tool.label}
              </a>
            );
          })}
        </div>
      </div>
    )
  }
  <!-- Header Section - Full Width -->
  <div class="is-flex is-align-items-flex-start mb-5" style="min-width: 0;">
    {
      ensemble.imageUrl && (
        <Image
          src={ensemble.imageUrl}
          alt={ensemble.name}
          size="96x96"
          class="mr-4"
          style="flex-shrink: 0;"
          imgStyle="object-fit: cover; border-radius: 8px;"
        />
      )
    }
    <div style="min-width: 0;">
      <h1 class="title">{ensemble.name}</h1>
      {
        ensemble.description && (
          <p class="subtitle" style="overflow-wrap: break-word;">
            {ensemble.description}
          </p>
        )
      }
      {
        currentSeason && (
          <p class="subtitle is-6 mt-2">
            <span class="icon-text">
              <Icon icon="fa-calendar-alt" color="info" />
              <span>
                <strong>Current Season:</strong> {currentSeason.name}
              </span>
            </span>
          </p>
        )
      }
    </div>
  </div>

  {
    isPending && (
      <Notification color="warning">
        <h2 class="title is-5">
          <span class="icon-text">
            <Icon icon="fa-hourglass-half" />
            <span>Membership Pending Approval</span>
          </span>
        </h2>
        <p>
          Your request to join <strong>{ensemble.name}</strong> is awaiting
          approval from an ensemble administrator. You'll receive full access
          once your membership is approved.
        </p>
        <p class="mt-3">
          <strong>Joined:</strong>{" "}
          {new Date(membership.joinedAt).toLocaleDateString()}
        </p>
      </Notification>
    )
  }

  {
    !isPending && (
      <div class="columns">
        <div
          class={`column ${isAdmin || ensemble.discordLink ? "is-9-desktop" : ""}`}
        >
          <RecentAnnouncements
            ensembleId={ensemble.id}
            canonicalId={canonicalId}
            isAdmin={isAdmin}
          />

          <UpcomingEvents
            ensembleId={ensemble.id}
            canonicalId={canonicalId}
            userId={user.id}
            isAdmin={isAdmin}
          />

          <SeasonRepertoire
            ensembleId={ensemble.id}
            canonicalId={canonicalId}
            isAdmin={isAdmin}
          />

          <EnsembleMembers
            ensembleId={ensemble.id}
            canonicalId={canonicalId}
            isAdmin={isAdmin}
          />

          <Button href="/ensembles">
            <Icon icon="fa-arrow-left" />
            <span>Back to Ensembles</span>
          </Button>
        </div>

        {(isAdmin || ensemble.discordLink) && (
          <div class="column is-3-desktop">
            <EnsembleLinks
              ensembleId={ensemble.id}
              discordLink={ensemble.discordLink}
            />

            {currentSeason && (
              <MyTasks
                ensembleId={ensemble.id}
                userId={user.id}
                seasonId={currentSeason.id}
                canonicalId={canonicalId}
                isAdmin={isAdmin}
              />
            )}

            {isAdmin && (
              <>
                <AdminTools canonicalId={canonicalId} />

                <PendingMembers ensembleId={ensemble.id} />

                <InviteCodeWidget ensembleId={ensemble.id} />
              </>
            )}
          </div>
        )}
      </div>
    )
  }
</Layout>
