---
import Layout from '../../layouts/Layout.astro';
import { db, eq, and, desc, Ensemble, EnsembleMember, User, EnsembleInvite, Part, Announcement } from 'astro:db';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/ensembles');
}

// Get ensemble details
const [ensemble] = await db.select().from(Ensemble).where(eq(Ensemble.id, id));
if (!ensemble) {
  return Astro.redirect('/ensembles');
}

// Check if user is a member
const [membership] = await db
  .select()
  .from(EnsembleMember)
  .where(and(eq(EnsembleMember.ensembleId, id), eq(EnsembleMember.userId, user.id)));

if (!membership) {
  return Astro.redirect('/ensembles');
}

const isAdmin = membership.role === 'admin';

// Get all members with their parts
const membersData = await db
  .select({
    id: User.id,
    name: User.name,
    email: User.email,
    avatarUrl: User.avatarUrl,
    role: EnsembleMember.role,
    joinedAt: EnsembleMember.joinedAt,
    membershipId: EnsembleMember.id,
    partId: EnsembleMember.partId,
  })
  .from(EnsembleMember)
  .innerJoin(User, eq(EnsembleMember.userId, User.id))
  .where(eq(EnsembleMember.ensembleId, id));

// Get all parts for this ensemble
const allParts = await db
  .select()
  .from(Part)
  .where(eq(Part.ensembleId, id))
  .all();

// Sort parts by sortOrder
allParts.sort((a, b) => a.sortOrder - b.sortOrder);

// Group members by part
const membersByPart = new Map();
const membersWithoutPart = [];

for (const member of membersData) {
  if (member.partId) {
    if (!membersByPart.has(member.partId)) {
      membersByPart.set(member.partId, []);
    }
    membersByPart.get(member.partId).push(member);
  } else {
    membersWithoutPart.push(member);
  }
}

// For backwards compatibility, keep members array
const members = membersData;

// Get latest announcements (limit to 3 most recent)
const latestAnnouncements = await db
  .select({
    id: Announcement.id,
    title: Announcement.title,
    content: Announcement.content,
    createdAt: Announcement.createdAt,
    creatorName: User.name,
  })
  .from(Announcement)
  .innerJoin(User, eq(Announcement.createdBy, User.id))
  .where(eq(Announcement.ensembleId, id))
  .orderBy(desc(Announcement.createdAt))
  .limit(3);

// Get invite codes (if admin)
const invites = isAdmin
  ? await db
      .select()
      .from(EnsembleInvite)
      .where(eq(EnsembleInvite.ensembleId, id))
  : [];

// Handle member actions
if (Astro.request.method === 'POST') {
  if (!isAdmin) {
    return new Response('Unauthorized', { status: 403 });
  }

  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'create-invite') {
    // Generate random 8-character code
    const code = Math.random().toString(36).substring(2, 10).toUpperCase();
    await db.insert(EnsembleInvite).values({
      id: crypto.randomUUID(),
      ensembleId: id,
      code,
      createdBy: user.id,
    });
    return Astro.redirect(`/ensembles/${id}`);
  } else if (action === 'delete-invite') {
    const inviteId = formData.get('inviteId')?.toString();
    if (inviteId) {
      await db.delete(EnsembleInvite).where(eq(EnsembleInvite.id, inviteId));
      return Astro.redirect(`/ensembles/${id}`);
    }
  } else {
    const membershipId = formData.get('membershipId')?.toString();

    if (action === 'remove' && membershipId) {
      await db.delete(EnsembleMember).where(eq(EnsembleMember.id, membershipId));
      return Astro.redirect(`/ensembles/${id}`);
    } else if (action === 'promote' && membershipId) {
      await db
        .update(EnsembleMember)
        .set({ role: 'admin' })
        .where(eq(EnsembleMember.id, membershipId));
      return Astro.redirect(`/ensembles/${id}`);
    } else if (action === 'demote' && membershipId) {
      await db
        .update(EnsembleMember)
        .set({ role: 'member' })
        .where(eq(EnsembleMember.id, membershipId));
      return Astro.redirect(`/ensembles/${id}`);
    }
  }
}
---

<Layout title={ensemble.name}>
  {ensemble.imageUrl && (
    <div class="columns">
      <div class="column">
        <figure class="image is-128x128 mb-4">
          <img src={ensemble.imageUrl} alt={ensemble.name} style="object-fit: cover; border-radius: 8px;" />
        </figure>
      </div>
    </div>
  )}

  <div class="level">
    <div class="level-left">
      <div class="level-item">
        <div>
          <h1 class="title">{ensemble.name}</h1>
          {ensemble.description && (
            <p class="subtitle">{ensemble.description}</p>
          )}
        </div>
      </div>
    </div>
    <div class="level-right">
      <div class="level-item">
        <div class="buttons">
          {isAdmin && (
            <a href={`/ensembles/${id}/edit`} class="button is-warning">
              <span class="icon">
                <i class="fas fa-edit"></i>
              </span>
              <span>Edit Ensemble</span>
            </a>
          )}
          <a href={`/ensembles/${id}/announcements`} class="button is-link">
            <span class="icon">
              <i class="fas fa-bullhorn"></i>
            </span>
            <span>Announcements</span>
          </a>
          <a href={`/ensembles/${id}/rehearsals`} class="button is-primary">
            <span class="icon">
              <i class="fas fa-music"></i>
            </span>
            <span>Rehearsals</span>
          </a>
          {isAdmin && (
            <a href={`/ensembles/${id}/parts`} class="button is-info">
              <span class="icon">
                <i class="fas fa-list"></i>
              </span>
              <span>Manage Parts</span>
            </a>
          )}
          <span class={`tag is-medium ${isAdmin ? 'is-warning' : 'is-info'}`}>
            {isAdmin ? 'Ensemble Admin' : 'Member'}
          </span>
        </div>
      </div>
    </div>
  </div>

  {isAdmin && (
    <div class="box mb-5">
      <h2 class="title is-4">Invite Codes</h2>
      <p class="mb-4">Share these codes with new members to join the ensemble</p>
      
      <div class="buttons mb-4">
        <form method="POST" style="display: inline;">
          <input type="hidden" name="action" value="create-invite" />
          <button type="submit" class="button is-success">
            <span class="icon">
              <i class="fas fa-plus"></i>
            </span>
            <span>Generate New Invite Code</span>
          </button>
        </form>
      </div>

      {invites.length > 0 ? (
        <table class="table is-fullwidth">
          <thead>
            <tr>
              <th>Code</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {invites.map((invite) => (
              <tr>
                <td>
                  <span class="tag is-large is-family-monospace">
                    {invite.code}
                  </span>
                </td>
                <td>{new Date(invite.createdAt).toLocaleDateString()}</td>
                <td>
                  <form method="POST" style="display: inline;">
                    <input type="hidden" name="action" value="delete-invite" />
                    <input type="hidden" name="inviteId" value={invite.id} />
                    <button type="submit" class="button is-danger is-small">
                      Delete
                    </button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <div class="notification is-info is-light">
          No invite codes created yet.
        </div>
      )}
    </div>
  )}

  <!-- Announcements Section -->
  <div class="box mb-5">
    <div class="level">
      <div class="level-left">
        <div class="level-item">
          <h2 class="title is-4">
            <span class="icon-text">
              <span class="icon">
                <i class="fas fa-bullhorn"></i>
              </span>
              <span>Recent Announcements</span>
            </span>
          </h2>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <a href={`/ensembles/${id}/announcements`} class="button is-small is-link">
            View All
          </a>
        </div>
      </div>
    </div>

    {latestAnnouncements.length === 0 ? (
      <div class="notification is-info is-light">
        <p class="has-text-centered">No announcements yet.</p>
        {isAdmin && (
          <p class="has-text-centered mt-2">
            <a href={`/ensembles/${id}/announcements`} class="button is-small is-link">
              Create First Announcement
            </a>
          </p>
        )}
      </div>
    ) : (
      latestAnnouncements.map((announcement) => (
        <article class="message is-link">
          <div class="message-header">
            <p>{announcement.title}</p>
            <small class="has-text-weight-normal">
              {new Date(announcement.createdAt).toLocaleDateString()}
            </small>
          </div>
          <div class="message-body">
            <p style="white-space: pre-wrap;">{announcement.content}</p>
            <p class="mt-2">
              <small><em>— {announcement.creatorName}</em></small>
            </p>
          </div>
        </article>
      ))
    )}
  </div>

  <div class="box">
    <h2 class="title is-4">Members ({members.length})</h2>
    
    {allParts.length > 0 ? (
      <>
        {allParts.map((part) => {
          const partMembers = membersByPart.get(part.id) || [];
          if (partMembers.length === 0) return null;
          
          return (
            <div class="mb-5">
              <h3 class="title is-5 has-text-primary">{part.name} ({partMembers.length})</h3>
              <table class="table is-fullwidth is-striped">
                <thead>
                  <tr>
                    <th style="width: 60px;"></th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    {isAdmin && <th>Actions</th>}
                  </tr>
                </thead>
                <tbody>
                  {partMembers.map((member: any) => (
                    <tr>
                      <td>
                        <figure class="image is-48x48">
                          {member.avatarUrl ? (
                            <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                          ) : (
                            <img src="https://bulma.io/assets/images/placeholders/128x128.png" alt="No avatar" style="border-radius: 50%;" />
                          )}
                        </figure>
                      </td>
                      <td>{member.name}</td>
                      <td>{member.email}</td>
                      <td>
                        <span class={`tag ${member.role === 'admin' ? 'is-warning' : 'is-info'}`}>
                          {member.role === 'admin' ? 'Admin' : 'Member'}
                        </span>
                      </td>
                      <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
                      {isAdmin && member.id !== user.id && (
                        <td>
                          <div class="buttons are-small">
                            {member.role === 'member' ? (
                              <form method="POST" style="display: inline;">
                                <input type="hidden" name="action" value="promote" />
                                <input type="hidden" name="membershipId" value={member.membershipId} />
                                <button type="submit" class="button is-warning is-small">
                                  Make Admin
                                </button>
                              </form>
                            ) : (
                              <form method="POST" style="display: inline;">
                                <input type="hidden" name="action" value="demote" />
                                <input type="hidden" name="membershipId" value={member.membershipId} />
                                <button type="submit" class="button is-info is-small">
                                  Remove Admin
                                </button>
                              </form>
                            )}
                            <form method="POST" style="display: inline;">
                              <input type="hidden" name="action" value="remove" />
                              <input type="hidden" name="membershipId" value={member.membershipId} />
                              <button type="submit" class="button is-danger is-small">
                                Remove
                              </button>
                            </form>
                          </div>
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          );
        })}

        {membersWithoutPart.length > 0 && (
          <div class="mb-5">
            <h3 class="title is-5 has-text-grey">No Part Assigned ({membersWithoutPart.length})</h3>
            <table class="table is-fullwidth is-striped">
              <thead>
                <tr>
                  <th style="width: 60px;"></th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Joined</th>
                  {isAdmin && <th>Actions</th>}
                </tr>
              </thead>
              <tbody>
                {membersWithoutPart.map((member) => (
                  <tr>
                    <td>
                      <figure class="image is-48x48">
                        {member.avatarUrl ? (
                          <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                        ) : (
                          <img src="https://bulma.io/assets/images/placeholders/128x128.png" alt="No avatar" style="border-radius: 50%;" />
                        )}
                      </figure>
                    </td>
                    <td>{member.name}</td>
                    <td>{member.email}</td>
                    <td>
                      <span class={`tag ${member.role === 'admin' ? 'is-warning' : 'is-info'}`}>
                        {member.role === 'admin' ? 'Admin' : 'Member'}
                      </span>
                    </td>
                    <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
                    {isAdmin && member.id !== user.id && (
                      <td>
                        <div class="buttons are-small">
                          {member.role === 'member' ? (
                            <form method="POST" style="display: inline;">
                              <input type="hidden" name="action" value="promote" />
                              <input type="hidden" name="membershipId" value={member.membershipId} />
                              <button type="submit" class="button is-warning is-small">
                                Make Admin
                              </button>
                            </form>
                          ) : (
                            <form method="POST" style="display: inline;">
                              <input type="hidden" name="action" value="demote" />
                              <input type="hidden" name="membershipId" value={member.membershipId} />
                              <button type="submit" class="button is-info is-small">
                                Remove Admin
                              </button>
                            </form>
                          )}
                          <form method="POST" style="display: inline;">
                            <input type="hidden" name="action" value="remove" />
                            <input type="hidden" name="membershipId" value={member.membershipId} />
                            <button type="submit" class="button is-danger is-small">
                              Remove
                            </button>
                          </form>
                        </div>
                      </td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </>
    ) : (
      <table class="table is-fullwidth is-striped">
        <thead>
          <tr>
            <th style="width: 60px;"></th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Joined</th>
            {isAdmin && <th>Actions</th>}
          </tr>
        </thead>
        <tbody>
          {members.map((member) => (
            <tr>
              <td>
                <figure class="image is-48x48">
                  {member.avatarUrl ? (
                    <img src={member.avatarUrl} alt={member.name} style="object-fit: cover; border-radius: 50%;" />
                  ) : (
                    <img src="https://bulma.io/assets/images/placeholders/128x128.png" alt="No avatar" style="border-radius: 50%;" />
                  )}
                </figure>
              </td>
              <td>{member.name}</td>
              <td>{member.email}</td>
              <td>
                <span class={`tag ${member.role === 'admin' ? 'is-warning' : 'is-info'}`}>
                  {member.role === 'admin' ? 'Admin' : 'Member'}
                </span>
              </td>
              <td>{new Date(member.joinedAt).toLocaleDateString()}</td>
              {isAdmin && member.id !== user.id && (
                <td>
                  <div class="buttons are-small">
                    {member.role === 'member' ? (
                      <form method="POST" style="display: inline;">
                        <input type="hidden" name="action" value="promote" />
                        <input type="hidden" name="membershipId" value={member.membershipId} />
                        <button type="submit" class="button is-warning is-small">
                          Make Admin
                        </button>
                      </form>
                    ) : (
                      <form method="POST" style="display: inline;">
                        <input type="hidden" name="action" value="demote" />
                        <input type="hidden" name="membershipId" value={member.membershipId} />
                        <button type="submit" class="button is-info is-small">
                          Remove Admin
                        </button>
                      </form>
                    )}
                    <form method="POST" style="display: inline;">
                      <input type="hidden" name="action" value="remove" />
                      <input type="hidden" name="membershipId" value={member.membershipId} />
                      <button type="submit" class="button is-danger is-small">
                        Remove
                      </button>
                    </form>
                  </div>
                </td>
              )}
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <a href="/ensembles" class="button">
    <span class="icon">
      <i class="fas fa-arrow-left"></i>
    </span>
    <span>Back to Ensembles</span>
  </a>
</Layout>
