---
import BaseLayout from "@layouts/BaseLayout.astro";
import Box from "@components/elements/Box.astro";
import Button from "@components/elements/Button.astro";
import Icon from "@components/elements/Icon.astro";
import { APP_NAME, APP_SLOGAN } from "@lib/config";

const user = Astro.locals.user;
---

<BaseLayout title="Home">
  <section class="hero is-medium is-primary">
    <div class="hero-body">
      <p class="title">
        Welcome to {APP_NAME}
      </p>
      <p class="subtitle">
        {APP_SLOGAN}
      </p>
      {
        !user && (
          <div class="buttons mt-4">
            <Button href="/register" color="light" size="large">
              <Icon icon="fa-user-plus" />
              <span>Sign Up Free</span>
            </Button>
            <Button href="/login" color="primary" size="large" style="outlined">
              <Icon icon="fa-sign-in-alt" />
              <span>Log In</span>
            </Button>
          </div>
        )
      }
      {
        user && (
          <div class="buttons mt-4">
            <Button href="/ensembles" color="light" size="large">
              <Icon icon="fa-users" />
              <span>My Ensembles</span>
            </Button>
          </div>
        )
      }
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="title is-3 has-text-centered mb-6">
        Everything your ensemble needs
      </h2>
      <div class="columns is-multiline">
        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon icon="fa-2x fa-users" size="large" color="primary" />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Member Management</h3>
                <p>
                  Invite members via unique codes, assign roles, and manage
                  membership status. Track who's active across seasons.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon
                  icon="fa-2x fa-calendar-check"
                  size="large"
                  color="primary"
                />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Rehearsal Scheduling</h3>
                <p>
                  Schedule rehearsals and events, track attendance for each
                  session, and keep your ensemble on track.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon icon="fa-2x fa-music" size="large" color="primary" />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Repertoire Library</h3>
                <p>
                  Build a library of songs and assign them to voice parts.
                  Organize repertoire by season so your music is always at hand.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon
                  icon="fa-2x fa-calendar-alt"
                  size="large"
                  color="primary"
                />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Seasons</h3>
                <p>
                  Organize your ensemble's activities into seasons. Manage
                  seasonal memberships and tie repertoire to each season.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon icon="fa-2x fa-bullhorn" size="large" color="primary" />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Announcements</h3>
                <p>
                  Post announcements to keep all your members informed about
                  upcoming events, changes, and important news.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon icon="fa-2x fa-users-cog" size="large" color="primary" />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Groups &amp; Sections</h3>
                <p>
                  Create custom sub-groups within your ensemble — sections,
                  committees, or any arbitrary grouping you need.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon icon="fa-2x fa-list" size="large" color="primary" />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Voice Parts</h3>
                <p>
                  Define custom voice parts or instrument sections for your
                  ensemble and assign members and songs accordingly.
                </p>
              </div>
            </div>
          </Box>
        </div>

        <div class="column is-half">
          <Box>
            <div class="media">
              <div class="media-left">
                <Icon icon="fa-2x fa-moon" size="large" color="primary" />
              </div>
              <div class="media-content">
                <h3 class="title is-5">Dark Mode</h3>
                <p>
                  A polished interface with full dark mode support — easy on the
                  eyes during late-night rehearsal prep.
                </p>
              </div>
            </div>
          </Box>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="columns is-vcentered">
        <div class="column is-narrow has-text-centered mr-5">
          <span class="icon has-text-primary" style="font-size: 4rem;">
            <i class="fab fa-github"></i>
          </span>
        </div>
        <div class="column">
          <h2 class="title is-3">Free &amp; open source</h2>
          <p class="subtitle is-5">
            Tutti Belli is open source software. You're welcome to run your
            ensemble on the hosted site — or self-host it on your own
            infrastructure if you prefer to keep full control.
          </p>
          <a
            href="https://github.com/lanesawyer/tutti-belli"
            target="_blank"
            rel="noopener noreferrer"
            class="button is-dark"
          >
            <Icon icon="fa-github" variant="fab" />
            <span>View on GitHub</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="columns is-vcentered">
        <div class="column is-narrow has-text-centered mr-5">
          <span class="icon has-text-primary" style="font-size: 4rem;">
            <i class="fas fa-envelope"></i>
          </span>
        </div>
        <div class="column">
          <h2 class="title is-3">Get in touch</h2>
          <p class="subtitle is-5">
            Have a feature request, found a bug, or want to get involved? Open
            an issue on GitHub.
          </p>
          <div class="buttons">
            <a
              href="https://github.com/lanesawyer/tutti-belli/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="button is-dark"
            >
              <Icon icon="fa-github" variant="fab" />
              <span>Open an Issue</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    !user && (
      <section class="section">
        <div class="content has-text-centered">
          <h2 class="title is-3">Ready to get organized?</h2>
          <p class="subtitle is-5">
            Create an account and start managing your ensemble today.
          </p>
          <div class="buttons is-centered">
            <Button href="/register" color="primary" size="large">
              <Icon icon="fa-user-plus" />
              <span>Sign Up Free</span>
            </Button>
            <Button href="/login" color="light" size="large">
              <Icon icon="fa-sign-in-alt" />
              <span>Log In</span>
            </Button>
          </div>
        </div>
      </section>
    )
  }

  {
    user && (
      <section class="section">
        <div class="content has-text-centered">
          <h2 class="title is-3">Welcome back, {user.name}!</h2>
          <div class="buttons is-centered">
            <Button href="/ensembles" color="primary" size="large">
              <Icon icon="fa-users" />
              <span>View My Ensembles</span>
            </Button>
            {user.role === "admin" && (
              <Button href="/admin" color="info" size="large">
                <Icon icon="fa-cog" />
                <span>Admin Panel</span>
              </Button>
            )}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
