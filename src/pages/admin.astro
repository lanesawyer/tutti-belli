---
import PageLayout from '../layouts/PageLayout.astro';
import Table from '../components/Table.astro';
import Button from '../components/Button.astro';
import Modal from '../components/Modal.astro';
import Notification from '../components/Notification.astro';
import { db, Ensemble, User } from 'astro:db';
import { actions } from 'astro:actions';

const user = Astro.locals.user;

if (!user || user.role !== 'admin') {
  return Astro.redirect('/');
}

const createResult = Astro.getActionResult(actions.admin.createEnsemble);
const deleteEnsembleResult = Astro.getActionResult(actions.admin.deleteEnsemble);
const toggleAdminResult = Astro.getActionResult(actions.admin.toggleAdmin);
const deleteUserResult = Astro.getActionResult(actions.admin.deleteUser);

let message = '';
let messageType: 'success' | 'danger' = 'success';

if (createResult?.data) {
  message = `Ensemble "${createResult.data.name}" created successfully!`;
} else if (createResult?.error) {
  message = createResult.error.message;
  messageType = 'danger';
} else if (deleteEnsembleResult && !deleteEnsembleResult.error) {
  message = 'Ensemble deleted successfully!';
} else if (deleteEnsembleResult?.error) {
  message = deleteEnsembleResult.error.message;
  messageType = 'danger';
} else if (toggleAdminResult?.data) {
  const { name, newRole } = toggleAdminResult.data;
  message = `User ${name} is now ${newRole === 'admin' ? 'a site admin' : 'a regular user'}`;
} else if (toggleAdminResult?.error) {
  message = toggleAdminResult.error.message;
  messageType = 'danger';
} else if (deleteUserResult?.data) {
  message = `User "${deleteUserResult.data.name}" has been deleted.`;
} else if (deleteUserResult?.error) {
  message = deleteUserResult.error.message;
  messageType = 'danger';
}

// Get all ensembles
const allEnsembles = await db.select().from(Ensemble);

// Get all users
const allUsers = await db.select().from(User);
---

<PageLayout
  title="Admin Panel"
  pageTitle="Site Administration"
  message={message}
  messageType={messageType}
>
  <Button slot="action" color="primary" id="create-ensemble-btn">
    <span class="icon"><i class="fas fa-plus"></i></span>
    <span>New Ensemble</span>
  </Button>

  <!-- Ensembles -->
  <h2 class="title is-4">Ensembles ({allEnsembles.length})</h2>

  {allEnsembles.length === 0 ? (
    <Notification color="info" light>
      No ensembles created yet.
    </Notification>
  ) : (
    <Table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {allEnsembles.map((ensemble) => (
          <tr>
            <td><strong>{ensemble.name}</strong></td>
            <td>{ensemble.description}</td>
            <td>{new Date(ensemble.createdAt).toLocaleDateString()}</td>
            <td>
              <div class="buttons are-small">
                <Button href={`/ensembles/${ensemble.id}`} color="info" size="small">
                  View
                </Button>
                <form method="POST" action={actions.admin.deleteEnsemble} style="display: inline;">
                  <input type="hidden" name="ensembleId" value={ensemble.id} />
                  <Button
                    type="submit"
                    color="danger"
                    size="small"
                    onclick="return confirm('Are you sure you want to delete this ensemble?')"
                  >
                    Delete
                  </Button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </Table>
  )}

  <!-- Users -->
  <h2 class="title is-4 mt-5">Users ({allUsers.length})</h2>

  <Table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Joined</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {allUsers.map((u) => (
        <tr>
          <td>{u.name}</td>
          <td>{u.email}</td>
          <td>
            <span class={`tag ${u.role === 'admin' ? 'is-danger' : 'is-info'}`}>
              {u.role === 'admin' ? 'Site Admin' : 'User'}
            </span>
          </td>
          <td>{new Date(u.createdAt).toLocaleDateString()}</td>
          <td>
            {u.id !== user.id && (
              <div class="buttons are-small">
                <form method="POST" action={actions.admin.toggleAdmin} style="display: inline;">
                  <input type="hidden" name="userId" value={u.id} />
                  <Button
                    type="submit"
                    color={u.role === 'admin' ? 'warning' : 'success'}
                    size="small"
                  >
                    {u.role === 'admin' ? 'Remove Admin' : 'Make Admin'}
                  </Button>
                </form>
                <form method="POST" action={actions.admin.deleteUser} style="display: inline;">
                  <input type="hidden" name="userId" value={u.id} />
                  <Button
                    type="submit"
                    color="danger"
                    size="small"
                    onclick={`return confirm('Delete user "${u.name}"? This cannot be undone.')`}
                  >
                    Delete
                  </Button>
                </form>
              </div>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </Table>

  <Fragment slot="modals">
    <Modal id="create-ensemble-modal" title="New Ensemble">
      <form method="POST" action={actions.admin.createEnsemble} id="create-ensemble-form">
        <div class="field">
          <label class="label" for="name">Ensemble Name</label>
          <div class="control">
            <input
              class="input"
              type="text"
              id="name"
              name="name"
              placeholder="e.g., Chamber Orchestra"
              required
            />
          </div>
        </div>

        <div class="field">
          <label class="label" for="description">Description</label>
          <div class="control">
            <textarea
              class="textarea"
              id="description"
              name="description"
              placeholder="Optional description"
            ></textarea>
          </div>
        </div>
      </form>

      <Fragment slot="footer">
        <Button type="submit" form="create-ensemble-form" color="primary">
          <span class="icon"><i class="fas fa-plus"></i></span>
          <span>Create Ensemble</span>
        </Button>
        <Button type="button" data-modal-close>Cancel</Button>
      </Fragment>
    </Modal>
  </Fragment>
</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('create-ensemble-btn')?.addEventListener('click', () => {
      document.getElementById('create-ensemble-modal')?.classList.add('is-active');
    });
  });
</script>
