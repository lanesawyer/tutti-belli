---
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import { Button, TextInput, Notification } from "astro-bulma";
import { actions } from "astro:actions";
import { getRedirectUrl } from "@lib/redirect";

const customRedirect = Astro.url.searchParams.get("redirect");

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect(
    await getRedirectUrl(Astro.locals.user.id, customRedirect),
  );
}

const result = Astro.getActionResult(actions.auth.login);

let error = "";
let unverifiedEmail = "";

if (result?.error) {
  const msg = result.error.message ?? "";
  if (msg.startsWith("unverified:")) {
    unverifiedEmail = msg.slice("unverified:".length);
  } else {
    error = msg || "An error occurred. Please try again.";
  }
} else if (result?.data) {
  return Astro.redirect(result.data.redirectUrl);
}
---

<SingleColumnLayout title="Log In">
  <h1 class="title">Log In</h1>

  {
    unverifiedEmail && (
      <Notification color="warning" light>
        <p>
          <strong>Email not verified.</strong> Please check your inbox for a
          verification link.
        </p>
        <p class="mt-2 is-size-7">
          <a
            href={`/resend-verification?email=${encodeURIComponent(unverifiedEmail)}`}
          >
            Resend verification email
          </a>
        </p>
      </Notification>
    )
  }

  {
    error && (
      <Notification color="danger" light>
        {error}
      </Notification>
    )
  }

  <form method="POST" action={actions.auth.login}>
    {
      customRedirect && (
        <input type="hidden" name="redirect" value={customRedirect} />
      )
    }
    <TextInput
      name="email"
      label="Email"
      type="email"
      placeholder="you@example.com"
      iconLeft="fa-envelope"
      required
    />
    <TextInput
      name="password"
      label="Password"
      type="password"
      placeholder="••••••••"
      iconLeft="fa-lock"
      required
    />

    <div class="field">
      <div class="control">
        <Button color="primary" fullwidth type="submit"> Log In </Button>
      </div>
    </div>
  </form>

  <div class="has-text-centered mt-4">
    <p><a href="/forgot-password">Forgot your password?</a></p>
    <p class="mt-2">
      Don't have an account? <a href="/register">Sign up</a>
    </p>
  </div>
</SingleColumnLayout>
