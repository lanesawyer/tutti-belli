---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Notification from '../components/Notification.astro';
import { db, eq, User } from 'astro:db';
import { verifyPassword } from '../lib/auth';
import { createSession } from '../lib/session';
import { getRedirectUrl } from '../lib/redirect';

const customRedirect = Astro.url.searchParams.get('redirect');
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString();
    const password = formData.get('password')?.toString();

    if (!email || !password) {
      error = 'Please provide both email and password';
    } else {
      const [user] = await db.select().from(User).where(eq(User.email, email));

      if (!user || !(await verifyPassword(password, user.passwordHash))) {
        error = 'Invalid email or password';
      } else {
        const sessionId = createSession(user.id);
        Astro.cookies.set('session', sessionId, {
          path: '/',
          httpOnly: true,
          secure: import.meta.env.PROD,
          sameSite: 'lax',
          maxAge: 60 * 60 * 24 * 30, // 30 days
        });

        return Astro.redirect(await getRedirectUrl(user.id, customRedirect));
      }
    }
  } catch (e) {
    error = 'An error occurred. Please try again.';
  }
}

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect(await getRedirectUrl(Astro.locals.user.id, customRedirect));
}
---

<Layout title="Log In">
  <div class="columns is-centered">
    <div class="column is-5-tablet is-4-desktop">
      <h1 class="title">Log In</h1>
      
      {error && (
        <Notification color="danger" light>
          {error}
        </Notification>
      )}

      <form method="POST">
        <div class="field">
          <label class="label" for="email">Email</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-envelope"></i>
            </span>
          </div>
        </div>

        <div class="field">
          <label class="label" for="password">Password</label>
          <div class="control has-icons-left">
            <input
              class="input"
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
            />
            <span class="icon is-small is-left">
              <i class="fas fa-lock"></i>
            </span>
          </div>
        </div>

        <div class="field">
          <div class="control">
            <Button color="primary" fullwidth type="submit">
              Log In
            </Button>
          </div>
        </div>
      </form>

      <div class="has-text-centered mt-4">
        <p><a href="/forgot-password">Forgot your password?</a></p>
        <p class="mt-2">Don't have an account? <a href="/register">Sign up</a></p>
      </div>
    </div>
  </div>
</Layout>
