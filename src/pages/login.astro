---
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import Button from "@components/elements/Button.astro";
import TextInput from "@components/forms/TextInput.astro";
import Notification from "@components/elements/Notification.astro";
import { db, eq, User } from "astro:db";
import { verifyPassword } from "@lib/auth";
import { createSession } from "@lib/session";
import { getRedirectUrl } from "@lib/redirect";

const customRedirect = Astro.url.searchParams.get("redirect");
let error = "";
let unverifiedEmail = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get("email")?.toString();
    const password = formData.get("password")?.toString();

    if (!email || !password) {
      error = "Please provide both email and password";
    } else {
      const [user] = await db.select().from(User).where(eq(User.email, email));

      if (!user || !(await verifyPassword(password, user.passwordHash))) {
        error = "Invalid email or password";
      } else if (!user.emailVerifiedAt) {
        unverifiedEmail = email;
      } else {
        const sessionId = createSession(user.id);
        Astro.cookies.set("session", sessionId, {
          path: "/",
          httpOnly: true,
          secure: import.meta.env.PROD,
          sameSite: "lax",
          maxAge: 60 * 60 * 24 * 30, // 30 days
        });

        return Astro.redirect(await getRedirectUrl(user.id, customRedirect));
      }
    }
  } catch (e) {
    error = "An error occurred. Please try again.";
  }
}

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect(
    await getRedirectUrl(Astro.locals.user.id, customRedirect),
  );
}
---

<SingleColumnLayout title="Log In">
  <h1 class="title">Log In</h1>

  {
    unverifiedEmail && (
      <Notification color="warning" light>
        <p>
          <strong>Email not verified.</strong> Please check your inbox for a
          verification link.
        </p>
        <p class="mt-2 is-size-7">
          <a
            href={`/resend-verification?email=${encodeURIComponent(unverifiedEmail)}`}
          >
            Resend verification email
          </a>
        </p>
      </Notification>
    )
  }

  {
    error && (
      <Notification color="danger" light>
        {error}
      </Notification>
    )
  }

  <form method="POST">
    <TextInput
      name="email"
      label="Email"
      type="email"
      placeholder="you@example.com"
      iconLeft="fa-envelope"
      required
    />
    <TextInput
      name="password"
      label="Password"
      type="password"
      placeholder="••••••••"
      iconLeft="fa-lock"
      required
    />

    <div class="field">
      <div class="control">
        <Button color="primary" fullwidth type="submit"> Log In </Button>
      </div>
    </div>
  </form>

  <div class="has-text-centered mt-4">
    <p><a href="/forgot-password">Forgot your password?</a></p>
    <p class="mt-2">
      Don't have an account? <a href="/register">Sign up</a>
    </p>
  </div>
</SingleColumnLayout>
