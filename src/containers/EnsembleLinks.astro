---
import { db, eq, EnsembleLink } from "astro:db";
import { Box } from "astro-bulma";
import { Button } from "astro-bulma";
import { Icon } from "astro-bulma";

interface Props {
  ensembleId: string;
  discordLink: string | null;
}

const { ensembleId, discordLink } = Astro.props;

const ensembleLinks = await db
  .select()
  .from(EnsembleLink)
  .where(eq(EnsembleLink.ensembleId, ensembleId))
  .orderBy(EnsembleLink.sortOrder, EnsembleLink.createdAt);
---

{
  (discordLink || ensembleLinks.length > 0) && (
    <Box class="mb-5">
      <h2 class="title is-5 mb-4">
        <span class="icon-text">
          <Icon icon="fa-link" />
          <span>Links</span>
        </span>
      </h2>
      <div class="buttons">
        {discordLink && (
          <Button
            href={discordLink}
            target="_blank"
            rel="noopener noreferrer"
            color="link"
            fullwidth
          >
            <Icon icon="fa-discord" variant="fab" />
            <span>Discord</span>
          </Button>
        )}
        {ensembleLinks.map((link) => (
          <Button
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            color="light"
            fullwidth
          >
            {link.label}
          </Button>
        ))}
      </div>
    </Box>
  )
}
