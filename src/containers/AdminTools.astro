---
import { ensembleAdminTools } from "@lib/config";
import Box from "@components/elements/Box.astro";
import Icon from "@components/elements/Icon.astro";

interface Props {
  canonicalId: string;
}

const { canonicalId } = Astro.props;
---

<Box class="mb-5">
  <h2 class="title is-5 mb-4">
    <span class="icon-text">
      <Icon icon="fa-cog" />
      <span>Admin Tools</span>
    </span>
  </h2>

  <div
    style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;"
  >
    {
      ensembleAdminTools.map((tool) => (
        <a href={tool.href(canonicalId)} class="button admin-tool-btn">
          <i class={`fas ${tool.icon} mb-1`} style="font-size: 1.25rem;" />
          <span class="is-size-7">{tool.label}</span>
        </a>
      ))
    }
  </div>
</Box>

<style>
  .admin-tool-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: auto;
    padding: 0.75rem 0.25rem;
    gap: 0.25rem;
  }
</style>
