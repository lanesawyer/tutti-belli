---
import { db, eq, EnsembleInvite } from "astro:db";
import { actions } from "astro:actions";
import { Box, Button, Icon, TextInput, Notification } from "astro-bulma";

interface Props {
  ensembleId: string;
}

const { ensembleId } = Astro.props;

const invites = await db
  .select()
  .from(EnsembleInvite)
  .where(eq(EnsembleInvite.ensembleId, ensembleId));
---

<Box>
  <h2 class="title is-5">
    <span class="icon-text">
      <Icon icon="fa-key" />
      <span>Invite Codes</span>
    </span>
  </h2>
  <p class="mb-4 is-size-7">
    Share these codes with new members to join the ensemble
  </p>

  <div class="mb-4">
    <form method="POST" action={actions.ensembles.createInvite}>
      <input type="hidden" name="ensembleId" value={ensembleId} />
      <Button type="submit" color="success" size="small" fullwidth>
        <Icon icon="fa-plus" />
        <span>Generate Code</span>
      </Button>
    </form>
  </div>

  {
    invites.length > 0 ? (
      <div class="content">
        {invites.map((invite) => {
          const inviteUrl = new URL(
            `/invite/join?code=${invite.code}`,
            Astro.site,
          ).toString();
          return (
            <Box class="p-3 mb-2">
              <div class="is-flex is-flex-direction-column">
                <div class="field has-addons mb-2">
                  <div class="control is-expanded">
                    <TextInput
                      name={`invite-url-${invite.id}`}
                      id={`invite-${invite.id}`}
                      type="text"
                      value={inviteUrl}
                      class="is-family-monospace"
                      size="small"
                      readonly
                      standalone
                    />
                  </div>
                  <div class="control">
                    <Button
                      type="button"
                      color="info"
                      size="small"
                      class="copy-invite-btn"
                      data-invite-id={invite.id}
                    >
                      <Icon icon="fa-copy" />
                      <span>Copy</span>
                    </Button>
                  </div>
                </div>
                <small class="has-text-grey mb-2">
                  Created {new Date(invite.createdAt).toLocaleDateString()}
                </small>
                <form method="POST" action={actions.ensembles.deleteInvite}>
                  <input type="hidden" name="inviteId" value={invite.id} />
                  <input type="hidden" name="ensembleId" value={ensembleId} />
                  <Button type="submit" color="danger" size="small" fullwidth>
                    Delete
                  </Button>
                </form>
              </div>
            </Box>
          );
        })}
      </div>
    ) : (
      <Notification color="info" light class="is-size-7">
        No invite codes yet.
      </Notification>
    )
  }
</Box>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".copy-invite-btn").forEach((btn) => {
      btn.addEventListener("click", function (this: HTMLButtonElement) {
        const inviteId = this.getAttribute("data-invite-id");
        const input = document.getElementById(`invite-${inviteId}`);

        if (input instanceof HTMLInputElement) {
          input.select();
          navigator.clipboard.writeText(input.value).then(() => {
            const originalHTML = this.innerHTML;
            this.innerHTML =
              '<span class="icon"><i class="fas fa-check"></i></span><span>Copied!</span>';
            this.classList.add("is-success");
            this.classList.remove("is-info");

            setTimeout(() => {
              this.innerHTML = originalHTML;
              this.classList.remove("is-success");
              this.classList.add("is-info");
            }, 2000);
          });
        }
      });
    });
  });
</script>
