---
interface Props {
  class?: string;
  /** Extra classes applied to the inner card-content wrapper. Ignored when using the raw `content` slot. */
  contentClass?: string;
}

const { class: className, contentClass } = Astro.props;

const hasHeader = Astro.slots.has("header");
const hasImage = Astro.slots.has("image");
const hasFooter = Astro.slots.has("footer");
const hasContent = Astro.slots.has("default");
---

<div class:list={["card", className]}>
  {
    hasHeader && (
      <header class="card-header">
        <slot name="header" />
      </header>
    )
  }
  {
    hasImage && (
      <div class="card-image">
        <slot name="image" />
      </div>
    )
  }
  {
    hasContent && (
      <div class:list={["card-content", contentClass]}>
        <slot />
      </div>
    )
  }
  {
    hasFooter && (
      <footer class="card-footer">
        <slot name="footer" />
      </footer>
    )
  }
</div>
