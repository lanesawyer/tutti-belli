---
import { APP_NAME } from '../lib/config';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="content has-text-centered">
    <p>
      <strong>{APP_NAME}</strong> — Managing musical ensembles with ease.
    </p>
    <p>
      <a href="https://github.com/lanesawyer/tutti-belli" target="_blank" rel="noopener noreferrer">
        <span class="icon-text">
          <span class="icon">
            <i class="fab fa-github"></i>
          </span>
          <span>Open source on GitHub</span>
        </span>
      </a>
      <span class="mx-3 has-text-grey">·</span>
      <a href="https://github.com/lanesawyer/tutti-belli/issues" target="_blank" rel="noopener noreferrer">
        <span class="icon-text">
          <span class="icon">
            <i class="fas fa-bug"></i>
          </span>
          <span>Open an issue</span>
        </span>
      </a>
      <span class="mx-3 has-text-grey">·</span>
      <a href="mailto:github@lanesawyer.dev">
        <span class="icon-text">
          <span class="icon">
            <i class="fas fa-envelope"></i>
          </span>
          <span>github@lanesawyer.dev</span>
        </span>
      </a>
    </p>
    <p class="is-size-7 has-text-grey">
      &copy; {year} {APP_NAME}. Licensed under the <a href="https://github.com/lanesawyer/tutti-belli/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">GNU AGPL v3</a>.
    </p>
  </div>
</footer>
