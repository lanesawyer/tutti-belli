---
import type { Color } from "@lib/bulma";

type Size = "normal" | "medium" | "large" | "small";

interface Props {
  color?: Color;
  size?: Size;
  light?: boolean;
  rounded?: boolean;
  /** Renders as a delete/close button with no slot content */
  isDelete?: boolean;
  title?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  color,
  size,
  light,
  rounded,
  isDelete,
  title,
  class: className,
  ...rest
} = Astro.props;

const classes = [
  "tag",
  color && `is-${color}`,
  light && "is-light",
  size && `is-${size}`,
  rounded && "is-rounded",
  isDelete && "is-delete",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<span class={classes} title={title} {...rest}>{isDelete ? null : <slot />}</span
>
