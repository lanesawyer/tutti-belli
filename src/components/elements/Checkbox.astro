---
/**
 * Checkbox component following the Bulma checkbox spec.
 * https://bulma.io/documentation/form/checkbox/
 *
 * Usage (with label prop):
 *   <Checkbox name="agree" label="I agree to the terms" required />
 *   <Checkbox name="active" label="Set as active" checked />
 *   <Checkbox name="opt" label="Optional" disabled />
 *
 * Usage (with rich slot content):
 *   <Checkbox name="agree"><strong>I agree</strong> to the <a href="#">terms</a></Checkbox>
 *
 * Extra classes on the wrapping label:
 *   <Checkbox name="foo" label="Foo" class="mb-2 is-block" />
 */

interface Props {
  /** input name attribute (required) */
  name: string;
  /** input id; defaults to name */
  id?: string;
  /** Label text shown next to the checkbox */
  label?: string;
  /** value attribute */
  value?: string;
  /** Whether the checkbox is checked */
  checked?: boolean;
  /** Whether the field is required */
  required?: boolean;
  /** Whether the checkbox is disabled */
  disabled?: boolean;
  /** Extra classes on the wrapping <label> */
  class?: string;
  /** Any other native input attributes passed through to <input> */
  [key: string]: unknown;
}

const {
  name,
  id = name,
  label,
  value,
  checked,
  required,
  disabled,
  class: className,
  ...rest
} = Astro.props;

// data-* and aria-* attrs belong on the label (the selectable element),
// not the inner input, so JS like checkbox.getAttribute("data-user-id") works.
const labelAttrs: Record<string, unknown> = {};
const inputAttrs: Record<string, unknown> = {};
for (const [k, v] of Object.entries(rest)) {
  if (k.startsWith("data-") || k.startsWith("aria-")) {
    labelAttrs[k] = v;
  } else {
    inputAttrs[k] = v;
  }
}
---

<label class:list={["checkbox", className]} {...labelAttrs}>
  <input
    type="checkbox"
    {name}
    {id}
    {value}
    {checked}
    {required}
    {disabled}
    {...inputAttrs}
  />
  {label ?? <slot />}
</label>
