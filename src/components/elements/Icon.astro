---
/**
 * Icon component following the Bulma icon spec.
 * https://bulma.io/documentation/elements/icon/
 *
 * Usage:
 *   <Icon icon="fa-plus" />
 *   <Icon icon="fa-envelope" size="small" />
 *   <Icon icon="fa-users" size="large" color="primary" />
 *   <Icon icon="fa-check-circle fa-2x" size="large" />
 *   <Icon icon="fa-github" variant="fab" />
 *   <Icon icon="fa-envelope" size="small" position="left" />
 */

interface Props {
  /** Font Awesome icon name, e.g. "fa-plus" or "fa-check-circle fa-2x" */
  icon: string;
  /** Font Awesome variant prefix. Defaults to "fas" (solid) */
  variant?: "fas" | "far" | "fab" | "fal" | "fad";
  /** Bulma size modifier for the wrapper span */
  size?: "small" | "medium" | "large";
  /** Bulma color applied as has-text-{color} on the wrapper */
  color?: string;
  /** Position inside a Bulma input control: "left" or "right" */
  position?: "left" | "right";
  /** Extra classes on the wrapper span */
  class?: string;
}

const {
  icon,
  variant = "fas",
  size,
  color,
  position,
  class: extraClass,
} = Astro.props;

const wrapperClasses = [
  "icon",
  size && `is-${size}`,
  color && `has-text-${color}`,
  position && `is-${position}`,
  extraClass,
]
  .filter(Boolean)
  .join(" ");
---

<span class={wrapperClasses}><i class={`${variant} ${icon}`}></i></span>
