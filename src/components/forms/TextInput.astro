---
import Icon from "@components/elements/Icon.astro";

/**
 * TextInput component following the Bulma input spec.
 * https://bulma.io/documentation/form/input/
 *
 * Usage (with field/label/control wrapper):
 *   <TextInput name="email" label="Email" type="email" placeholder="you@example.com" required />
 *
 * Usage (standalone — just the <input>, no wrappers):
 *   <TextInput name="url" type="url" placeholder="https://..." standalone />
 *
 * Icon support:
 *   <TextInput name="email" label="Email" iconLeft="fa-envelope" />
 *   <TextInput name="search" iconLeft="fa-search" iconRight="fa-times" />
 */

interface Props {
  /** input name attribute (required) */
  name: string;
  /** input id; defaults to name */
  id?: string;
  /** input type */
  type?:
    | "text"
    | "email"
    | "password"
    | "tel"
    | "url"
    | "number"
    | "search"
    | "date"
    | "time";
  /** label text; renders field/label/control wrappers when set */
  label?: string;
  placeholder?: string;
  value?: string | number;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  /** HTML form attribute (associates input with a form by id) */
  form?: string;
  /** additional HTML attributes like min, max, maxlength, pattern, step, etc. */
  [key: string]: unknown;

  // Bulma modifiers
  color?: "primary" | "link" | "info" | "success" | "warning" | "danger";
  size?: "small" | "normal" | "medium" | "large";
  rounded?: boolean;
  /** .is-static — removes background/border, keeps vertical spacing */
  static?: boolean;

  /** Font Awesome icon name for left icon, e.g. "fa-envelope" */
  iconLeft?: string;
  /** Font Awesome icon variant for left icon, defaults to "fas" */
  iconLeftVariant?: "fas" | "far" | "fab";
  /** Font Awesome icon name for right icon */
  iconRight?: string;
  /** Font Awesome icon variant for right icon, defaults to "fas" */
  iconRightVariant?: "fas" | "far" | "fab";

  /** Help text rendered below the control */
  help?: string;
  /** Color for the help text */
  helpColor?: "primary" | "link" | "info" | "success" | "warning" | "danger";

  /** When true, renders only the <input> element with no field/control wrappers */
  standalone?: boolean;
  /** Extra classes on the <input> element */
  class?: string;
  /** Extra classes on the control div (e.g. "is-expanded", "is-loading") */
  controlClass?: string;
}

const {
  name,
  id,
  type = "text",
  label,
  placeholder,
  value,
  required,
  disabled,
  readonly,
  form,
  color,
  size,
  rounded,
  static: isStatic,
  iconLeft,
  iconLeftVariant = "fas",
  iconRight,
  iconRightVariant = "fas",
  help,
  helpColor,
  standalone,
  class: className,
  controlClass,
  ...rest
} = Astro.props;

const inputId = id ?? name;

const inputClasses = [
  "input",
  color && `is-${color}`,
  size && `is-${size}`,
  rounded && "is-rounded",
  isStatic && "is-static",
  className,
]
  .filter(Boolean)
  .join(" ");

const controlClasses = [
  "control",
  iconLeft && "has-icons-left",
  iconRight && "has-icons-right",
  controlClass,
]
  .filter(Boolean)
  .join(" ");

const iconSize = size === "large" ? "medium" : "small";
---

{
  standalone ? (
    <input
      class={inputClasses}
      type={type}
      id={inputId}
      name={name}
      placeholder={placeholder}
      value={value}
      required={required}
      disabled={disabled}
      readonly={readonly}
      form={form}
      {...rest}
    />
  ) : (
    <div class="field">
      {label && (
        <label class="label" for={inputId}>
          {label}
        </label>
      )}
      <div class={controlClasses}>
        <input
          class={inputClasses}
          type={type}
          id={inputId}
          name={name}
          placeholder={placeholder}
          value={value}
          required={required}
          disabled={disabled}
          readonly={readonly}
          form={form}
          {...rest}
        />
        {iconLeft && (
          <Icon
            icon={iconLeft}
            variant={iconLeftVariant}
            size={iconSize}
            position="left"
          />
        )}
        {iconRight && (
          <Icon
            icon={iconRight}
            variant={iconRightVariant}
            size={iconSize}
            position="right"
          />
        )}
      </div>
      {help && (
        <p
          class={["help", helpColor && `is-${helpColor}`]
            .filter(Boolean)
            .join(" ")}
        >
          {help}
        </p>
      )}
    </div>
  )
}
