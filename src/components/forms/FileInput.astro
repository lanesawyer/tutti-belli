---
type Props = {
  name: string;
  id?: string;
  label?: string;
  accept?: string;
  required?: boolean;
  help?: string;
  ctaLabel?: string;
  placeholder?: string;
  color?: "primary" | "info" | "warning" | "danger" | "success";
  size?: "small" | "medium" | "large";
  fullwidth?: boolean;
  boxed?: boolean;
  class?: string;
};

const {
  name,
  id,
  label,
  accept,
  required,
  help,
  ctaLabel = "Choose a file…",
  placeholder = "No file selected",
  color,
  size,
  fullwidth = true,
  boxed,
  class: className,
} = Astro.props;

const inputId = id ?? name;
const nameId = `${inputId}-name`;

const fileClasses = [
  "file",
  "has-name",
  fullwidth && "is-fullwidth",
  boxed && "is-boxed",
  color && `is-${color}`,
  size && `is-${size}`,
  className,
]
  .filter(Boolean)
  .join(" ");
---

{
  label && (
    <label class="label" for={inputId}>
      {label}
      {required && " *"}
    </label>
  )
}
<div class="control">
  <div class={fileClasses}>
    <label class="file-label">
      <input
        class="file-input"
        type="file"
        id={inputId}
        name={name}
        accept={accept}
        required={required}
        data-filename-target={nameId}
      />
      <span class="file-cta">
        <span class="file-icon">
          <i class="fas fa-upload"></i>
        </span>
        <span class="file-label">{ctaLabel}</span>
      </span>
      <span class="file-name" id={nameId}>
        {placeholder}
      </span>
    </label>
  </div>
</div>
{help && <p class="help">{help}</p>}

<script>
  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll<HTMLInputElement>(".file-input[data-filename-target]")
      .forEach((input) => {
        const targetId = input.dataset.filenameTarget!;
        const nameEl = document.getElementById(targetId);
        if (!nameEl) return;
        input.addEventListener("change", () => {
          nameEl.textContent = input.files?.[0]?.name ?? "No file selected";
        });
      });
  });
</script>
