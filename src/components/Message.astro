---
type Props = {
  color?: 'dark' | 'link' | 'primary' | 'info' | 'success' | 'warning' | 'danger';
  size?: 'small' | 'medium' | 'large';
  style?: string;
  class?: string;
};

const { color, size, style, class: className } = Astro.props;

const classes = [
  'message',
  color && `is-${color}`,
  size && `is-${size}`,
  className,
].filter(Boolean).join(' ');
---

<article class={classes} style={style}>
  {Astro.slots.has('header') && (
    <div class="message-header">
      <slot name="header" />
    </div>
  )}
  <div class="message-body">
    <slot />
  </div>
</article>
