{
  "name": "ensemble-management-software",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": "22.9.0",
    "pnpm": "10.6.0"
  },
  "volta": {
    "node": "22.9.0",
    "pnpm": "10.6.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:remote": "astro dev --remote",
    "build": "astro build --remote",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "oxlint src/lib db --deny-warnings && astro check",
    "fmt": "oxlint src/lib db --fix",
    "astro:db:push": "astro db push --remote",
    "fly:deploy": "./deploy.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/db": "0.19.0",
    "@astrojs/node": "9.5.4",
    "@aws-sdk/client-s3": "3.995.0",
    "astro": "5.17.3",
    "bcryptjs": "3.0.3",
    "bulma": "1.0.4",
    "jsonwebtoken": "9.0.3",
    "qrcode": "1.5.4",
    "resend": "6.9.2",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@libsql/client": "0.17.0",
    "@playwright/test": "1.58.2",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/qrcode": "1.5.5",
    "@vitest/coverage-v8": "4.0.18",
    "drizzle-orm": "0.45.1",
    "oxlint": "0.16.12",
    "vitest": "4.0.18"
  }
}
